#print Matrix.rank

/-
If M has rank n-1, and v is in the kernel and u is in the left kernel (both non-zero), then the adjugate of M is a scalar multiple of the outer product v u^T.
-/
lemma adjugate_eq_smul_vecMulVec_of_rank_eq_card_sub_one {n : Type*} [Fintype n] [DecidableEq n] (M : Matrix n n ℝ)
    (u v : n → ℝ) (hu : u ≠ 0) (hv : v ≠ 0)
    (h_rank : Matrix.rank M = Fintype.card n - 1)
    (h_ker : M.mulVec v = 0)
    (h_left_ker : M.vecMul u = 0) :
    ∃ c : ℝ, Matrix.adjugate M = c • Matrix.vecMulVec v u := by
      by_contra h_contra;
      -- Since adj(M) has rank 1, there exists a vector w such that adj(M) = w • u^T.
      obtain ⟨w, hw⟩ : ∃ w : n → ℝ, M.adjugate = Matrix.vecMulVec w u := by
        have h_adj_rank : ∀ i : n, ∃ c : ℝ, M.adjugate i = c • u := by
          intro i
          have h_adj_row : Matrix.vecMul (M.adjugate i) M = 0 := by
            have h_adj_row : M.adjugate * M = 0 := by
              simp +decide [ Matrix.adjugate_mul ];
              have h_det_zero : Matrix.rank M < Fintype.card n := by
                exact h_rank.symm ▸ Nat.pred_lt ( ne_bot_of_gt ( Fintype.card_pos_iff.mpr ⟨ i ⟩ ) );
              contrapose! h_det_zero;
              have := Matrix.rank_mul_le_left M ( M⁻¹ ) ; simp_all +decide [ isUnit_iff_ne_zero ] ;
            exact funext fun j => by simpa [ Matrix.mul_apply ] using congr_fun ( congr_fun h_adj_row i ) j;
          have h_adj_row : ∀ w : n → ℝ, Matrix.vecMul w M = 0 → ∃ c : ℝ, w = c • u := by
            have h_adj_row : Module.finrank ℝ (LinearMap.ker (Matrix.toLin' (Matrix.transpose M))) = 1 := by
              have := LinearMap.finrank_range_add_finrank_ker ( Matrix.toLin' M.transpose ) ; simp_all +decide [ Matrix.rank ] ;
              have h_adj_row : Module.finrank ℝ (LinearMap.range (Matrix.toLin' M.transpose)) = Fintype.card n - 1 := by
                convert h_rank using 1;
                convert Matrix.rank_transpose M using 1;
              linarith [ Nat.sub_add_cancel ( show 1 ≤ Fintype.card n from Fintype.card_pos_iff.mpr ⟨ i ⟩ ) ];
            have h_adj_row : Submodule.span ℝ {u} = LinearMap.ker (Matrix.toLin' (Matrix.transpose M)) := by
              refine' Submodule.eq_of_le_of_finrank_eq _ _;
              · simp_all +decide [ ← Matrix.mulVec_transpose ];
              · rw [ h_adj_row, finrank_span_singleton ] ; aesop;
            intro w hw; replace h_adj_row := SetLike.ext_iff.mp h_adj_row w; simp_all +decide [ Submodule.mem_span_singleton ] ;
            simp_all +decide [ funext_iff, Matrix.vecMul, Matrix.mulVec ];
            simp_all +decide [ dotProduct, mul_comm ];
            exact ⟨ h_adj_row.choose, fun x => h_adj_row.choose_spec x ▸ rfl ⟩;
          exact h_adj_row _ ‹_›;
        choose c hc using h_adj_rank;
        use c;
        ext i j; simp +decide [ hc, Matrix.vecMulVec ] ;
      -- Since $M * adj(M) = 0$, substituting $adj(M) = w • u^T$ gives $M * (w • u^T) = 0$. This implies that $w$ is in the kernel of $M$.
      have h_w_kernel : M.mulVec w = 0 := by
        have h_w_kernel : M * Matrix.vecMulVec w u = 0 := by
          simp +decide [ ← hw, Matrix.mul_adjugate ];
          exact Or.inl ( by rw [ Matrix.rank ] at h_rank; exact Matrix.exists_mulVec_eq_zero_iff.mp ⟨ v, hv, h_ker ⟩ );
        simp_all +decide [ ← Matrix.ext_iff, Matrix.mulVec, Matrix.vecMulVec ];
        simp_all +decide [ funext_iff, Matrix.mul_apply ];
        simp_all +decide [ ← mul_assoc, ← Finset.mul_sum _ _ _, ← Finset.sum_mul, Matrix.mulVec, dotProduct ];
        exact fun i => Or.resolve_right ( h_w_kernel i hu.choose ) hu.choose_spec;
      -- Since $v$ spans the kernel of $M$, there exists a scalar $c$ such that $w = c • v$.
      obtain ⟨c, hc⟩ : ∃ c : ℝ, w = c • v := by
        have h_kernel : LinearMap.ker (Matrix.mulVecLin M) = Submodule.span ℝ {v} := by
          refine' Submodule.eq_of_le_of_finrank_eq _ _;
          · intro x hx; have := LinearMap.finrank_range_add_finrank_ker ( Matrix.mulVecLin M ) ; simp_all +decide [ Matrix.rank ] ;
            have h_kernel : Module.finrank ℝ (LinearMap.ker (Matrix.mulVecLin M)) = 1 := by
              linarith [ Nat.sub_add_cancel ( show 1 ≤ Fintype.card n from Fintype.card_pos_iff.mpr ⟨ Classical.choose ( Function.ne_iff.mp hv ) ⟩ ) ];
            have h_kernel : Submodule.span ℝ {v} = LinearMap.ker (Matrix.mulVecLin M) := by
              exact Submodule.eq_of_le_of_finrank_eq ( Submodule.span_le.mpr ( Set.singleton_subset_iff.mpr ( by aesop ) ) ) ( by rw [ h_kernel, finrank_span_singleton ] ; aesop );
            exact h_kernel.symm ▸ hx;
          · rw [ finrank_span_singleton ];
            · have := LinearMap.finrank_range_add_finrank_ker ( Matrix.mulVecLin M );
              simp_all +decide [ Matrix.rank ];
              linarith [ Nat.sub_add_cancel ( show 1 ≤ Fintype.card n from Fintype.card_pos_iff.mpr ⟨ Classical.choose ( Function.ne_iff.mp hv ) ⟩ ) ];
            · exact hv
        exact Submodule.mem_span_singleton.mp ( h_kernel ▸ LinearMap.mem_ker.mpr h_w_kernel ) |> fun ⟨ c, hc ⟩ => ⟨ c, hc.symm ⟩;
      simp_all +decide [ Matrix.vecMulVec, funext_iff ];
      exact h_contra c |> fun ⟨ x, y, hxy ⟩ => hxy <| by ring;

/-
If a matrix has rank k, there exists a k x k submatrix with non-zero determinant.
-/
lemma exists_submatrix_det_ne_zero_of_rank_eq {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ) (k : ℕ) (h_rank : Matrix.rank A = k) :
    ∃ (r c : Fin k → n), (A.submatrix r c).det ≠ 0 := by
      by_contra! h_contra;
      -- Since the rank of A is k, there exist k linearly independent rows in A.
      obtain ⟨rows, hrows⟩ : ∃ rows : Fin k → n, LinearIndependent ℝ (fun i => A.row (rows i)) := by
        have := h_rank ▸ Matrix.rank_eq_finrank_span_row A;
        have := ( exists_linearIndependent ℝ ( Set.range A.row ) );
        obtain ⟨ b, hb₁, hb₂, hb₃ ⟩ := this;
        have h_card : Set.ncard b = k := by
          have h_card : Set.ncard b = Module.finrank ℝ (Submodule.span ℝ b) := by
            have h_card : Set.Finite b := by
              exact Set.Finite.subset ( Set.toFinite ( Set.range A.row ) ) hb₁;
            have := h_card.fintype;
            rw [ Set.ncard_eq_toFinset_card' ];
            rw [ finrank_span_set_eq_card ] ; aesop;
          rw [ h_card, hb₂, this ];
        -- Since $b$ is a subset of the range of $A.row$ with cardinality $k$, we can choose $k$ distinct elements from $b$.
        obtain ⟨rows, hrows⟩ : ∃ rows : Fin k → n → ℝ, (∀ i, rows i ∈ b) ∧ LinearIndependent ℝ rows := by
          have h_card : ∃ rows : Fin k → n → ℝ, (∀ i, rows i ∈ b) ∧ Function.Injective rows := by
            have h_card : Nonempty (Fin k ≃ b) := by
              have h_card : Fintype b := by
                exact Set.Finite.fintype ( Set.Finite.subset ( Set.toFinite ( Set.range A.row ) ) hb₁ );
              exact ⟨ Fintype.equivOfCardEq <| by simp +decide [ ← ‹Set.ncard b = k›, Set.ncard_eq_toFinset_card' ] ⟩;
            exact ⟨ _, fun i => h_card.some i |>.2, Subtype.coe_injective.comp h_card.some.injective ⟩;
          obtain ⟨ rows, hrows₁, hrows₂ ⟩ := h_card;
          refine' ⟨ rows, hrows₁, _ ⟩;
          convert hb₃.comp _ _;
          rotate_left;
          exacts [ fun i => ⟨ rows i, hrows₁ i ⟩, fun i j hij => hrows₂ <| by simpa using hij, funext fun i => rfl ];
        choose f hf using fun i => hb₁ ( hrows.1 i );
        exact ⟨ f, by simpa only [ hf ] using hrows.2 ⟩;
      -- Consider the k x k matrix B formed by these rows. B has rank k.
      set B : Matrix (Fin k) n ℝ := fun i j => A (rows i) j;
      -- Since B has rank k, there exist k linearly independent columns in B.
      obtain ⟨cols, hcols⟩ : ∃ cols : Fin k → n, LinearIndependent ℝ (fun i => B.col (cols i)) := by
        have hB_rank : Matrix.rank B = k := by
          have hB_rank : LinearMap.range (Matrix.mulVecLin B.transpose) = Submodule.span ℝ (Set.range (fun i => A.row (rows i))) := by
            ext; simp [B];
            simp +decide [ funext_iff, Matrix.vecMul, Submodule.mem_span_range_iff_exists_fun ];
            rfl;
          have hB_rank : Module.finrank ℝ (Submodule.span ℝ (Set.range (fun i => A.row (rows i)))) = k := by
            rw [ finrank_span_eq_card ] <;> aesop;
          convert hB_rank using 1;
          rw [ ← ‹LinearMap.range B.transpose.mulVecLin = Submodule.span ℝ ( Set.range fun i => A.row ( rows i ) ) ›, Matrix.rank ];
          rw [ ← Matrix.rank, ← Matrix.rank, Matrix.rank_transpose ];
        have hB_col_rank : Module.finrank ℝ (Submodule.span ℝ (Set.range (fun j => B.col j))) = k := by
          convert hB_rank using 1;
          exact?;
        have := ( exists_linearIndependent ℝ ( Set.range fun j => B.col j ) );
        obtain ⟨ b, hb₁, hb₂, hb₃ ⟩ := this;
        have h_card_b : Set.ncard b = k := by
          have h_card_b : Module.finrank ℝ (Submodule.span ℝ b) = k := by
            rw [ hb₂, hB_col_rank ];
          have h_card_b : Module.finrank ℝ (Submodule.span ℝ b) = Set.ncard b := by
            have h_finite : Set.Finite b := by
              exact Set.Finite.subset ( Set.toFinite ( Set.range fun j => B.col j ) ) hb₁
            have := h_finite.fintype;
            rw [ Set.ncard_eq_toFinset_card' ];
            rw [ finrank_span_set_eq_card ] ; aesop;
          linarith;
        obtain ⟨cols, hcols⟩ : ∃ cols : Fin k → n, b = Set.range (fun i => B.col (cols i)) := by
          have h_card_b : ∃ cols : Fin k → n, b = Set.range (fun i => B.col (cols i)) := by
            have h_card_b : ∃ cols : Fin k → (Fin k → ℝ), b = Set.range cols := by
              have h_card_b : Nonempty (Fin k ≃ b) := by
                have h_card_b : Fintype b := by
                  exact Set.Finite.fintype ( Set.Finite.subset ( Set.toFinite ( Set.range fun j => B.col j ) ) hb₁ );
                exact ⟨ Fintype.equivOfCardEq <| by simp +decide [ Set.ncard_eq_toFinset_card' ] at *; linarith ⟩;
              obtain ⟨ e ⟩ := h_card_b;
              use fun i => e i |>.1;
              ext x; simp [Set.mem_range];
              exact ⟨ fun hx => ⟨ e.symm ⟨ x, hx ⟩, by simp +decide ⟩, by rintro ⟨ y, rfl ⟩ ; exact e y |>.2 ⟩
            obtain ⟨ cols, hcols ⟩ := h_card_b;
            choose f hf using fun i => hb₁ ( hcols.symm ▸ Set.mem_range_self i );
            exact ⟨ f, by aesop ⟩;
          exact h_card_b;
        use cols;
        convert hb₃.comp _ _;
        rotate_left;
        use fun i => ⟨ B.col ( cols i ), hcols.symm ▸ Set.mem_range_self i ⟩;
        · intro i j hij;
          have := Finset.card_image_iff.mp ( show Finset.card ( Finset.image ( fun i => B.col ( cols i ) ) Finset.univ ) = Finset.card ( Finset.univ : Finset ( Fin k ) ) from ?_ ) ; aesop;
          rw [ ← Set.ncard_coe_finset ] ; aesop;
        · rfl;
      -- Consider the k x k matrix C formed by these columns of B. C is A.submatrix rows cols.
      set C : Matrix (Fin k) (Fin k) ℝ := fun i j => A (rows i) (cols j);
      -- Since C is a k x k matrix with rank k, its determinant is non-zero.
      have hC_det : C.det ≠ 0 := by
        rw [ Fintype.linearIndependent_iff ] at hcols;
        intro h_det_zero
        have h_lin_dep : ∃ g : Fin k → ℝ, g ≠ 0 ∧ ∑ i, g i • B.col (cols i) = 0 := by
          obtain ⟨ g, hg ⟩ := Matrix.exists_mulVec_eq_zero_iff.mpr h_det_zero;
          exact ⟨ g, hg.1, by ext i; simpa [ Matrix.mulVec, dotProduct, mul_comm ] using congr_fun hg.2 i ⟩;
        exact h_lin_dep.elim fun g hg => hg.1 ( funext fun i => hcols g hg.2 i );
      exact hC_det ( h_contra rows cols )

/-
If a n x n submatrix of a (n+1) x (n+1) matrix has non-zero determinant, then there exists a standard submatrix (obtained by deleting one row and one column) with non-zero determinant.
-/
lemma exists_submatrix_succAbove_det_ne_zero_of_det_ne_zero {n : ℕ} (A : Matrix (Fin (n + 1)) (Fin (n + 1)) ℝ)
    (r c : Fin n → Fin (n + 1)) (h_det : (A.submatrix r c).det ≠ 0) :
    ∃ i j : Fin (n + 1), (A.submatrix i.succAbove j.succAbove).det ≠ 0 := by
      -- Since $r$ and $c$ are injective, their ranges omit exactly one element each.
      have hr_range : ∃ i : Fin (n + 1), ∀ j : Fin n, r j ≠ i := by
        by_contra! h_contra;
        exact absurd ( Fintype.card_le_of_surjective r fun x => by obtain ⟨ j, rfl ⟩ := h_contra x; exact ⟨ j, rfl ⟩ ) ( by simp +decide )
      have hc_range : ∃ j : Fin (n + 1), ∀ k : Fin n, c k ≠ j := by
        by_contra! h_contra;
        exact absurd ( Fintype.card_le_of_surjective c fun x => by obtain ⟨ k, rfl ⟩ := h_contra x; exact ⟨ k, rfl ⟩ ) ( by simp +decide );
      obtain ⟨ i, hi ⟩ := hr_range
      obtain ⟨ j, hj ⟩ := hc_range
      have h_submatrix : ∃ σ : Fin n ≃ { x : Fin (n + 1) // x ≠ i }, ∀ k : Fin n, r k = σ k := by
        have h_submatrix : Function.Injective r := by
          intro i j hij;
          exact Classical.not_not.1 fun hi => h_det <| Matrix.det_zero_of_row_eq hi <| by aesop;
        have h_submatrix : Finset.image r Finset.univ = Finset.univ.erase i := by
          exact Finset.eq_of_subset_of_card_le ( Finset.image_subset_iff.mpr fun x _ => Finset.mem_erase_of_ne_of_mem ( hi x ) ( Finset.mem_univ _ ) ) ( by rw [ Finset.card_image_of_injective _ h_submatrix ] ; simp +decide [ Finset.card_erase_of_mem ( Finset.mem_univ i ) ] );
        have h_submatrix : Finset.image (fun k : Fin n => ⟨r k, hi k⟩ : Fin n → { x : Fin (n + 1) // x ≠ i }) Finset.univ = Finset.univ := by
          simp_all +decide [ Finset.ext_iff ];
        have h_submatrix : Function.Bijective (fun k : Fin n => ⟨r k, hi k⟩ : Fin n → { x : Fin (n + 1) // x ≠ i }) := by
          exact ⟨ fun x y hxy => by simpa [ Fin.ext_iff ] using ‹Function.Injective r› ( by simpa [ Fin.ext_iff ] using congr_arg Subtype.val hxy ), fun x => by replace h_submatrix := Finset.ext_iff.mp h_submatrix x; aesop ⟩;
        exact ⟨ Equiv.ofBijective _ h_submatrix, fun k => rfl ⟩
      have h_submatrix' : ∃ τ : Fin n ≃ { x : Fin (n + 1) // x ≠ j }, ∀ k : Fin n, c k = τ k := by
        have h_submatrix' : Function.Injective c := by
          intro k l hkl; have := Matrix.det_ne_zero_of_left_inverse ( show ( A.submatrix r c ) * ( ( A.submatrix r c ) ⁻¹ ) = 1 from ?_ ) ; simp_all +decide [ Matrix.det_eq_zero_of_row_eq_zero ] ;
          · contrapose! h_det;
            exact Matrix.det_zero_of_column_eq h_det ( by aesop );
          · exact Matrix.mul_nonsing_inv _ ( show IsUnit _ from isUnit_iff_ne_zero.mpr h_det );
        exact ⟨ Equiv.ofBijective ( fun k => ⟨ c k, hj k ⟩ ) ⟨ fun a b h => h_submatrix' <| by simpa using h, fun a => by
          have := Finset.eq_of_subset_of_card_le ( show Finset.image c Finset.univ ⊆ Finset.univ.erase j from Finset.image_subset_iff.mpr fun k _ => Finset.mem_erase_of_ne_of_mem ( hj k ) ( Finset.mem_univ _ ) ) ; simp_all +decide [ Finset.card_image_of_injective _ h_submatrix' ] ;
          replace this := Finset.ext_iff.mp this a; aesop; ⟩, fun k => rfl ⟩
      obtain ⟨ σ, hσ ⟩ := h_submatrix
      obtain ⟨ τ, hτ ⟩ := h_submatrix';
      -- The submatrix $A.submatrix r c$ is equivalent to $A.submatrix i.succAbove j.succAbove$ up to permutation of rows and columns.
      have h_submatrix_eq : ∃ P Q : Matrix (Fin n) (Fin n) ℝ, P.det ≠ 0 ∧ Q.det ≠ 0 ∧ A.submatrix r c = P * A.submatrix i.succAbove j.succAbove * Q := by
        use Matrix.of (fun k l => if σ k = Fin.succAbove i l then 1 else 0), Matrix.of (fun k l => if τ l = Fin.succAbove j k then 1 else 0);
        refine' ⟨ _, _, _ ⟩;
        · -- Since σ is a permutation, the matrix P is a permutation matrix, and its determinant is ±1.
          have hP_perm : ∃ σ' : Equiv.Perm (Fin n), ∀ k l, (if σ k = Fin.succAbove i l then 1 else 0 : ℝ) = if σ' k = l then 1 else 0 := by
            have hP_perm : ∀ k : Fin n, ∃ l : Fin n, σ k = Fin.succAbove i l := by
              intro k; have := σ k |>.2; simp_all +decide [ Fin.succAbove ] ;
              use ⟨ if ( σ k : Fin ( n + 1 ) ) < i then ( σ k : Fin ( n + 1 ) ) |> Fin.val else ( σ k : Fin ( n + 1 ) ) |> Fin.val - 1, by
                split_ifs <;> simp_all +decide [ Fin.val_add, Fin.coe_sub_one ];
                · exact lt_of_lt_of_le ‹_› ( Nat.le_of_lt_succ ( Fin.is_lt i ) );
                · exact Nat.lt_of_lt_of_le ( Nat.pred_lt ( ne_bot_of_gt ( Fin.pos_iff_ne_zero.mpr ( by specialize hi k; aesop ) ) ) ) ( Nat.le_of_lt_succ ( Fin.is_lt _ ) ) ⟩
              generalize_proofs at *;
              split_ifs <;> simp_all +decide [ Fin.ext_iff, Fin.val_add, Fin.val_one ];
              grind;
            choose f hf using hP_perm;
            have hP_perm : Function.Injective f := by
              intro k l hkl; have := σ.injective ( show σ k = σ l from Subtype.ext <| by aesop ) ; aesop;
            exact ⟨ Equiv.ofBijective f ⟨ hP_perm, Finite.injective_iff_surjective.mp hP_perm ⟩, fun k l => by aesop ⟩;
          obtain ⟨ σ', hσ' ⟩ := hP_perm; simp_all +decide [ Matrix.det_apply' ] ;
          rw [ Finset.sum_eq_single ( σ'⁻¹ ) ] <;> simp_all +decide [ Equiv.Perm.sign_inv ];
          intro b hb; rw [ Finset.prod_eq_zero_iff ] ; simp_all +decide [ Equiv.Perm.ext_iff ] ;
          exact hb.imp fun x hx => by contrapose! hx; simpa using σ'.injective ( by aesop ) ;
        · -- Since τ is a bijection, the matrix Q is a permutation matrix.
          have hQ_perm : ∃ P : Equiv.Perm (Fin n), ∀ k l, (Matrix.of (fun k l => if ↑(τ l) = j.succAbove k then 1 else 0)) k l = if P l = k then 1 else 0 := by
            have hQ_perm : ∀ l : Fin n, ∃ k : Fin n, τ l = j.succAbove k := by
              intro l; exact (by
              have := Fin.exists_succAbove_eq ( show ( τ l : Fin ( n + 1 ) ) ≠ j from τ l |>.2 ) ; tauto;);
            choose P hP using hQ_perm;
            use Equiv.ofBijective P (by
            have hP_inj : Function.Injective P := by
              intro l l' h; have := τ.injective ( Subtype.ext <| by aesop : τ l = τ l' ) ; aesop;
            generalize_proofs at *;
            exact ⟨ hP_inj, Finite.injective_iff_surjective.mp hP_inj ⟩)
            generalize_proofs at *;
            simp +decide [ hP ];
          obtain ⟨ P, hP ⟩ := hQ_perm; simp_all +decide [ Matrix.det_apply' ] ;
          simp_all +decide [ Finset.prod_ite ];
          rw [ Finset.sum_eq_single ( P ) ] <;> simp_all +decide [ Finset.ext_iff ];
          · intro k; specialize hP ( P k ) k; aesop;
          · grind;
        · ext k l; simp +decide [ Matrix.mul_apply, hσ, hτ ] ;
          rw [ Finset.sum_eq_single ( Classical.choose ( Fin.exists_succAbove_eq ( show ( τ l : Fin ( n + 1 ) ) ≠ j from by aesop ) ) ) ] <;> simp +decide [ Classical.choose_spec ( Fin.exists_succAbove_eq ( show ( τ l : Fin ( n + 1 ) ) ≠ j from by aesop ) ) ];
          · rw [ Finset.sum_eq_single ( Classical.choose ( Fin.exists_succAbove_eq ( show ( σ k : Fin ( n + 1 ) ) ≠ i from by aesop ) ) ) ] <;> simp +decide [ Classical.choose_spec ( Fin.exists_succAbove_eq ( show ( σ k : Fin ( n + 1 ) ) ≠ i from by aesop ) ) ];
            intro b hb h; have := Classical.choose_spec ( Fin.exists_succAbove_eq ( show ( σ k : Fin ( n + 1 ) ) ≠ i from by aesop ) ) ; aesop;
          · intro b hb h; have := Classical.choose_spec ( Fin.exists_succAbove_eq ( show ( τ l : Fin ( n + 1 ) ) ≠ j from by aesop ) ) ; aesop;
      obtain ⟨ P, Q, hP, hQ, h ⟩ := h_submatrix_eq; use i, j; simp_all +decide [ Matrix.det_mul ] ;

/-
If a standard submatrix (obtained by deleting row i and column j) has non-zero determinant, then the adjugate is non-zero.
-/
lemma adjugate_ne_zero_of_exists_submatrix_succAbove_det_ne_zero {n : ℕ} (A : Matrix (Fin (n + 1)) (Fin (n + 1)) ℝ)
    (i j : Fin (n + 1)) (h : (A.submatrix i.succAbove j.succAbove).det ≠ 0) :
    Matrix.adjugate A ≠ 0 := by
      intro h_zero;
      have h_adj_zero : A.adjugate j i = (-1) ^ (i.val + j.val) * (A.submatrix i.succAbove j.succAbove).det := by
        rw [ Matrix.adjugate_apply, Matrix.det_succ_row _ i ];
        rw [ Finset.sum_eq_single j ] <;> aesop;
      replace h_zero := congr_fun ( congr_fun h_zero j ) i; aesop;

/-
If a matrix over Fin n (n > 0) has rank n-1, its adjugate is not zero.
-/
lemma adjugate_ne_zero_of_rank_eq_card_sub_one_fin {n : ℕ} (hn : n ≠ 0) (A : Matrix (Fin n) (Fin n) ℝ)
    (h_rank : Matrix.rank A = n - 1) :
    Matrix.adjugate A ≠ 0 := by
      rcases n with ( _ | n ) <;> simp_all +decide [ Matrix.adjugate_apply ];
      obtain ⟨ r, c, h ⟩ := exists_submatrix_det_ne_zero_of_rank_eq A n h_rank;
      exact fun h' => by have := adjugate_ne_zero_of_exists_submatrix_succAbove_det_ne_zero A _ _ ( exists_submatrix_succAbove_det_ne_zero_of_det_ne_zero A r c h |> Classical.choose_spec |> Classical.choose_spec ) ; aesop;

/-
If a matrix has rank n-1, its adjugate is not zero.
-/
lemma adjugate_ne_zero_of_rank_eq_card_sub_one {n : Type*} [Fintype n] [DecidableEq n] [Nonempty n] (A : Matrix n n ℝ)
    (h_rank : Matrix.rank A = Fintype.card n - 1) :
    Matrix.adjugate A ≠ 0 := by
      obtain ⟨e, he⟩ : ∃ e : n ≃ Fin (Fintype.card n), True := by
        exact ⟨ Fintype.equivFin n, trivial ⟩;
      have h_reindex : Matrix.rank (Matrix.reindex e e A) = Matrix.rank A := by
        exact?;
      have h_adj_ne_zero : Matrix.adjugate (Matrix.reindex e e A) ≠ 0 := by
        apply adjugate_ne_zero_of_rank_eq_card_sub_one_fin;
        · exact Fintype.card_ne_zero;
        · exact h_reindex.trans h_rank;
      contrapose! h_adj_ne_zero;
      rw [ Matrix.adjugate_reindex ] ; aesop

/-
The adjugate of (rI - A) is a non-zero scalar multiple of the outer product of the Perron vector and the left Perron vector.
-/
lemma adjugate_perron_root_eq_smul_vecMulVec {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    ∃ c : ℝ, c ≠ 0 ∧ Matrix.adjugate (perronRoot A hA • 1 - A) = c • Matrix.vecMulVec (perronVector A hA) (leftPerronVector A hA) := by
      obtain ⟨c, hc⟩ : ∃ c : ℝ, Matrix.adjugate (perronRoot A hA • 1 - A) = c • Matrix.vecMulVec (perronVector A hA) (leftPerronVector A hA) := by
        apply adjugate_eq_smul_vecMulVec_of_rank_eq_card_sub_one;
        · exact fun h => by have := leftPerronVector_pos A hA; simp_all +decide [ funext_iff, Matrix.IsPositiveVec ] ;
        · exact ne_of_apply_ne ( fun v => v ( Classical.arbitrary n ) ) ( ne_of_gt ( perronVector_pos A hA _ ) );
        · convert rank_eq_card_sub_one_of_geometric_multiplicity_one A ( perronRoot A hA ) ( geometric_multiplicity_one A hA ) using 1;
        · have := perronVector_is_eigenvector A hA; simp_all +decide [ Matrix.sub_mulVec, Matrix.smul_eq_diagonal_mul ] ;
        · have := leftPerronVector_is_eigenvector A hA;
          simp_all +decide [ ← Matrix.mulVec_transpose, Matrix.vecMul_sub, Matrix.vecMul_smul ];
          simp_all +decide [ Matrix.sub_mulVec, Matrix.smul_eq_diagonal_mul ];
      have h_adj_ne_zero : Matrix.adjugate (perronRoot A hA • 1 - A) ≠ 0 := by
        apply adjugate_ne_zero_of_rank_eq_card_sub_one;
        apply rank_eq_card_sub_one_of_geometric_multiplicity_one;
        exact?;
      aesop

/-
The trace of the adjugate of (rI - A) is non-zero.
-/
lemma trace_adjugate_perron_root_ne_zero {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    Matrix.trace (Matrix.adjugate (perronRoot A hA • 1 - A)) ≠ 0 := by
      -- By `adjugate_perron_root_eq_smul_vecMulVec`, the adjugate is `c * (v u^T)` for some `c \ne 0`.
      obtain ⟨c, hc_ne_zero, hc⟩ : ∃ c : ℝ, c ≠ 0 ∧ Matrix.adjugate (perronRoot A hA • 1 - A) = c • Matrix.vecMulVec (perronVector A hA) (leftPerronVector A hA) := by
        exact?;
      -- The trace is `c * trace(v u^T)`.
      have h_trace : Matrix.trace (Matrix.adjugate (perronRoot A hA • 1 - A)) = c * ∑ i, (perronVector A hA) i * (leftPerronVector A hA) i := by
        simp +decide [ hc, Matrix.trace, Matrix.vecMulVec ];
        rw [ Finset.mul_sum _ _ _ ];
      -- Since `v` and `u` are strictly positive vectors, their dot product is strictly positive.
      have h_dot_pos : 0 < ∑ i, (perronVector A hA) i * (leftPerronVector A hA) i := by
        exact Finset.sum_pos ( fun i _ => mul_pos ( perronVector_pos A hA i ) ( leftPerronVector_pos A hA i ) ) Finset.univ_nonempty;
      exact h_trace.symm ▸ mul_ne_zero hc_ne_zero h_dot_pos.ne'

#check charpoly_derivative_eval_eq_trace_adjugate

/-
The derivative of the characteristic polynomial evaluated at the Perron root is non-zero.
-/
lemma charpoly_derivative_eval_perronRoot_ne_zero {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    (Matrix.charpoly A).derivative.eval (perronRoot A hA) ≠ 0 := by
      rw [ charpoly_derivative_eval_eq_trace_adjugate ] ; exact trace_adjugate_perron_root_ne_zero A hA;

/-
The algebraic multiplicity of the Perron root is 1.
-/
lemma algebraic_multiplicity_one {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    (Matrix.charpoly A).rootMultiplicity (perronRoot A hA) = 1 := by
      -- By definition of $perronRoot$, we know that $perronRoot$ is a root of the characteristic polynomial of $A$.
      have h_root : Polynomial.IsRoot (Matrix.charpoly A) (perronRoot A hA) := by
        have h_cauchy_interlace : Matrix.det (perronRoot A hA • 1 - A) = 0 := by
          have h_det_zero : ∃ v : n → ℝ, v ≠ 0 ∧ (perronRoot A hA • 1 - A).mulVec v = 0 := by
            have h_eigenvalue : ∃ v : n → ℝ, v ≠ 0 ∧ A.mulVec v = (perronRoot A hA) • v := by
              exact ⟨ perronVector A hA, fun h => by simpa [ h ] using perronVector_mem_stdSimplex A hA |>.2, perronVector_is_eigenvector A hA ⟩;
            obtain ⟨ v, hv_ne_zero, hv_eigenvalue ⟩ := h_eigenvalue; use v; simp_all +decide [ sub_smul, Matrix.sub_mulVec ] ;
            simp +decide [ Matrix.smul_eq_diagonal_mul ];
          exact Matrix.exists_mulVec_eq_zero_iff.mp h_det_zero;
        simp_all +decide [ Matrix.charpoly, Matrix.det_apply' ];
        simp_all +decide [ Polynomial.eval_finset_sum, Polynomial.eval_mul, Polynomial.eval_prod, Polynomial.eval_sub, Polynomial.eval_X, Polynomial.eval_one, Matrix.charmatrix, Matrix.one_apply ];
        convert h_cauchy_interlace using 4 ; aesop;
      have h_deriv_ne_zero : (Matrix.charpoly A).derivative.eval (perronRoot A hA) ≠ 0 := by
        exact?;
      exact le_antisymm ( Nat.le_of_not_lt fun h => h_deriv_ne_zero <| by simpa [ h_root ] using Polynomial.isRoot_iterate_derivative_of_lt_rootMultiplicity h ) ( Nat.one_le_iff_ne_zero.mpr <| by aesop )

/-
The Perron-Frobenius theorem for positive matrices:
1. There exists a positive real eigenvalue (Perron root) with a positive eigenvector (Perron vector).
2. The algebraic multiplicity of the Perron root is 1.
3. The Perron root is strictly greater than the magnitude of any other eigenvalue.
4. The only eigenvalue with magnitude equal to the Perron root is the Perron root itself.
-/
theorem perron_frobenius_positive {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    (0 < perronRoot A hA) ∧
    (Matrix.IsPositiveVec (perronVector A hA)) ∧
    (A.mulVec (perronVector A hA) = (perronRoot A hA) • (perronVector A hA)) ∧
    ((Matrix.charpoly A).rootMultiplicity (perronRoot A hA) = 1) ∧
    (∀ μ : ℂ, ∀ w : n → ℂ, w ≠ 0 → (A.map Complex.ofReal).mulVec w = μ • w → ‖μ‖ ≤ perronRoot A hA) ∧
    (∀ μ : ℂ, ∀ w : n → ℂ, w ≠ 0 → (A.map Complex.ofReal).mulVec w = μ • w → ‖μ‖ = perronRoot A hA → μ = perronRoot A hA) := by
      refine' ⟨ perronRoot_pos A hA, perronVector_pos A hA, perronVector_is_eigenvector A hA, algebraic_multiplicity_one A hA, _, _ ⟩;
      · exact?;
      · exact?
