/-
Definitions of positive and irreducible matrices over Real.
-/
def Matrix.IsPositive {n : Type*} [Fintype n] (A : Matrix n n ℝ) : Prop :=
  ∀ i j, 0 < A i j

def Matrix.IsIrreducible {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ) : Prop :=
  ∀ i j : n, ∃ k : ℕ, (A ^ k) i j > 0

/-
Definition of non-negative matrix.
-/
def Matrix.IsNonneg {n : Type*} [Fintype n] (A : Matrix n n ℝ) : Prop :=
  ∀ i j, 0 ≤ A i j

/-
Definitions of irreducible matrix (corrected) and positive vector.
-/
def Matrix.IsIrreducible' {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ) : Prop :=
  ∀ i j : n, ∃ k : ℕ, k > 0 ∧ (A ^ k) i j > 0

def Matrix.IsPositiveVec {n : Type*} [Fintype n] (v : n → ℝ) : Prop :=
  ∀ i, 0 < v i

/-
Definition of non-negative vector and basic lemmas relating positive and irreducible matrices.
-/
def Matrix.IsNonnegVec {n : Type*} [Fintype n] (v : n → ℝ) : Prop :=
  ∀ i, 0 ≤ v i

lemma Matrix.isNonneg_of_isPositive {n : Type*} [Fintype n] (A : Matrix n n ℝ) (h : A.IsPositive) : A.IsNonneg := by
  intro i j
  exact le_of_lt (h i j)

lemma Matrix.isIrreducible_of_isPositive {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ) (h : A.IsPositive) : A.IsIrreducible' := by
  intro i j
  use 1
  constructor
  · norm_num
  · simp
    exact h i j

/-
If A is irreducible and non-negative, and v is a non-negative non-zero eigenvector, then v is strictly positive.
-/
lemma Matrix.isPositiveVec_of_eigenvector {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv_nonneg : Matrix.IsNonnegVec v) (hv_ne_zero : v ≠ 0)
    (r : ℝ) (h_eig : A.mulVec v = r • v) :
    Matrix.IsPositiveVec v := by
      -- Consider the set $I$ of indices where $v_i = 0$. Since $v \neq 0$, $I$ is non-empty.
      set I := {i | v i = 0} with hI_def
      by_cases hI_empty : I = ∅;
      · exact fun i => lt_of_le_of_ne ( hv_nonneg i ) ( Ne.symm <| by rw [ Set.ext_iff ] at hI_empty; specialize hI_empty i; aesop );
      · -- Since $A$ is irreducible, there exists some $j \in I$ and $k \notin I$ such that $(A^m)_{jk} > 0$ for some $m$.
        obtain ⟨j, hjI, k, hkI, hm⟩ : ∃ j ∈ I, ∃ k ∉ I, ∃ m : ℕ, m > 0 ∧ (A ^ m) j k > 0 := by
          obtain ⟨j, hjI⟩ : ∃ j, j ∈ I := by
            exact Set.nonempty_iff_ne_empty.2 hI_empty
          obtain ⟨k, hkI⟩ : ∃ k, k ∉ I := by
            exact Function.ne_iff.mp hv_ne_zero |> Exists.imp fun k hk => by aesop;
          obtain ⟨m, hm_pos, hm⟩ : ∃ m : ℕ, m > 0 ∧ (A ^ m) j k > 0 := by
            exact hA_irr j k
          use j, hjI, k, hkI, m, hm_pos, hm;
        -- Since $v$ is an eigenvector of $A$, we have $(A^m v)_j = r^m v_j$.
        obtain ⟨m, hm_pos, hm_gt⟩ := hm;
        have h_eig_m : (A ^ m).mulVec v j = r ^ m * v j := by
          have h_eig_m : ∀ m : ℕ, (A ^ m).mulVec v = r ^ m • v := by
            intro m; induction m <;> simp_all +decide [ pow_succ', Matrix.mulVec_smul ] ;
            simp_all +decide [ ← Matrix.mulVec_mulVec, Matrix.mulVec_smul ];
            rw [ smul_smul, mul_comm ];
          exact congr_fun ( h_eig_m m ) j;
        simp_all +decide [ Matrix.mulVec, dotProduct ];
        contrapose! h_eig_m;
        refine' ne_of_gt ( lt_of_lt_of_le _ ( Finset.single_le_sum ( fun i _ => mul_nonneg ( show 0 ≤ ( A ^ m ) j i from _ ) ( hv_nonneg i ) ) ( Finset.mem_univ k ) ) );
        · exact mul_pos hm_gt ( lt_of_le_of_ne ( hv_nonneg k ) ( Ne.symm hkI ) );
        · -- Since $A$ is non-negative, each entry of $A^m$ is non-negative.
          have hA_pow_nonneg : ∀ m : ℕ, ∀ i j, 0 ≤ (A ^ m) i j := by
            intro m i j; induction' m with m ih generalizing i j <;> simp_all +decide [ pow_succ', Matrix.mul_apply ] ;
            · exact?;
            · exact Finset.sum_nonneg fun _ _ => mul_nonneg ( hA_nonneg _ _ ) ( ih _ _ );
          exact hA_pow_nonneg m j i

/-
For a non-negative matrix A, |Av| <= A|v|.
-/
def vecAbs {n : Type*} (v : n → ℝ) : n → ℝ := fun i => |v i|

lemma Matrix.abs_mulVec_le_mulVec_abs {n : Type*} [Fintype n] (A : Matrix n n ℝ) (hA : A.IsNonneg) (v : n → ℝ) :
    vecAbs (A.mulVec v) ≤ A.mulVec (vecAbs v) := by
      intro i
      simp [Matrix.mulVec, vecAbs];
      convert Finset.abs_sum_le_sum_abs _ _ |> le_trans <| Finset.sum_le_sum fun j _ => ?_ using 1;
      · infer_instance;
      · infer_instance;
      · simp [vecAbs];
        rw [ abs_of_nonneg ( hA i j ) ]

/-
If A is irreducible and non-negative, and v is a non-negative non-zero eigenvector, then its eigenvalue is positive.
-/
lemma Matrix.eigenvalue_pos_of_nonneg_eigenvector {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv_nonneg : Matrix.IsNonnegVec v) (hv_ne_zero : v ≠ 0)
    (r : ℝ) (h_eig : A.mulVec v = r • v) :
    r > 0 := by
      -- By Lemma 25, $v$ is strictly positive.
      have hv_strict_pos : Matrix.IsPositiveVec v := by
        exact?;
      have h_r_pos : ∀ i, 0 < (A.mulVec v) i := by
        intro i
        have h_sum_pos : ∃ j, 0 < A i j ∧ 0 < v j := by
          obtain ⟨ k, hk ⟩ := hA_irr i i;
          induction' k with k ih generalizing i <;> simp_all +decide [ pow_succ', Matrix.mul_apply ];
          obtain ⟨ j, hj ⟩ := Finset.exists_ne_zero_of_sum_ne_zero hk.ne';
          exact ⟨ j, lt_of_le_of_ne ( hA_nonneg i j ) ( Ne.symm <| by aesop ), hv_strict_pos j ⟩;
        obtain ⟨ j, hj₁, hj₂ ⟩ := h_sum_pos; exact lt_of_lt_of_le ( mul_pos hj₁ hj₂ ) ( Finset.single_le_sum ( fun a _ => mul_nonneg ( hA_nonneg i a ) ( hv_nonneg a ) ) ( Finset.mem_univ j ) ) ;
      rcases isEmpty_or_nonempty n with ( h | h ) <;> simp_all +decide [ funext_iff ];
      exact lt_of_not_ge fun hr => by nlinarith [ h_r_pos h.some, hv_strict_pos h.some ] ;

