#check Complex

/-
If A is irreducible and non-negative, and v is a non-negative non-zero vector, then Av is not zero.
-/
lemma Matrix.mulVec_ne_zero_of_nonneg_of_ne_zero {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv_nonneg : Matrix.IsNonnegVec v) (hv_ne_zero : v ≠ 0) :
    A.mulVec v ≠ 0 := by
      -- By contradiction, assume $A.mulVec v = 0$.
      by_contra h_contra;
      -- Apply the lemma Matrix.isPositiveVec_of_eigenvector to conclude that v is strictly positive.
      have h_pos_eigenvec : ∃ r : ℝ, A.mulVec v = r • v ∧ r > 0 := by
        exact ⟨ 0, by simp +decide [ h_contra ], by linarith [ eigenvalue_pos_of_nonneg_eigenvector A hA_nonneg hA_irr v hv_nonneg hv_ne_zero 0 ( by simp +decide [ h_contra ] ) ] ⟩;
      simp_all +decide [ funext_iff ];
      exact hv_ne_zero.elim fun x hx => hx ( by obtain ⟨ r, hr₁, hr₂ ⟩ := h_pos_eigenvec; cases hr₁ x <;> linarith )

/-
Define the map on the simplex.
-/
def simplexMap {n : Type*} [Fintype n] (A : Matrix n n ℝ) (v : n → ℝ) : n → ℝ :=
  (1 / ∑ i, (A.mulVec v) i) • A.mulVec v

/-
The map simplexMap sends the standard simplex to itself.
-/
lemma simplexMap_mem_stdSimplex {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv : v ∈ stdSimplex ℝ n) :
    simplexMap A v ∈ stdSimplex ℝ n := by
      refine' ⟨ _, _ ⟩;
      · intro i
        simp [simplexMap];
        exact mul_nonneg ( inv_nonneg.2 ( Finset.sum_nonneg fun _ _ => by rw [ Matrix.mulVec, dotProduct ] ; exact Finset.sum_nonneg fun _ _ => mul_nonneg ( hA_nonneg _ _ ) ( hv.1 _ ) ) ) ( by rw [ Matrix.mulVec, dotProduct ] ; exact Finset.sum_nonneg fun _ _ => mul_nonneg ( hA_nonneg _ _ ) ( hv.1 _ ) );
      · unfold simplexMap;
        by_cases h : ∑ i, A.mulVec v i = 0 <;> simp_all +decide [ Matrix.mulVec, dotProduct ];
        · rw [ Finset.sum_eq_zero_iff_of_nonneg ] at h;
          · -- Since $A$ is irreducible and non-negative, and $v$ is a non-negative non-zero vector, $A.mulVec v$ cannot be zero.
            have h_mulVec_ne_zero : A.mulVec v ≠ 0 := by
              apply Matrix.mulVec_ne_zero_of_nonneg_of_ne_zero A hA_nonneg hA_irr v (fun i => by
                exact hv.1 i) (by
              rintro rfl; simp_all +decide [ stdSimplex ]);
            exact h_mulVec_ne_zero ( funext fun i => by simpa [ Matrix.mulVec, dotProduct ] using h i ( Finset.mem_univ i ) );
          · exact fun i _ => Finset.sum_nonneg fun j _ => mul_nonneg ( hA_nonneg i j ) ( hv.1 j );
        · simp +decide [ ← Finset.mul_sum _ _ _, ← Finset.sum_mul, h ]

/-
The map simplexMap is continuous on the standard simplex.
-/
lemma continuousOn_simplexMap {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible') :
    ContinuousOn (simplexMap A) (stdSimplex ℝ n) := by
      refine' ContinuousOn.smul _ _;
      · refine' ContinuousOn.div continuousOn_const _ _;
        · exact Continuous.continuousOn ( continuous_finset_sum _ fun i _ => Continuous.dotProduct ( continuous_const ) continuous_id' );
        · intro x hx
          have h_pos : ∀ i, 0 ≤ (A.mulVec x) i := by
            exact fun i => Finset.sum_nonneg fun j _ => mul_nonneg ( hA_nonneg i j ) ( hx.1 j );
          have h_nonzero : A.mulVec x ≠ 0 := by
            apply Matrix.mulVec_ne_zero_of_nonneg_of_ne_zero A hA_nonneg hA_irr x (fun i => hx.1 i) (by
            rintro rfl; simp_all +decide [ stdSimplex ]);
          exact fun h => h_nonzero <| funext fun i => le_antisymm ( le_trans ( Finset.single_le_sum ( fun i _ => h_pos i ) ( Finset.mem_univ i ) ) h.le ) ( h_pos i );
      · exact Continuous.continuousOn ( continuous_const.matrix_mulVec continuous_id' )

/-
If v is a fixed point of simplexMap A, then v is an eigenvector of A.
-/
lemma eigenvector_of_fixed_point_simplexMap {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv : v ∈ stdSimplex ℝ n) (h_fixed : simplexMap A v = v) :
    A.mulVec v = (∑ i, (A.mulVec v) i) • v := by
      unfold simplexMap at h_fixed;
      by_cases h : ∑ i, A.mulVec v i = 0 <;> simp_all +decide [ funext_iff, Matrix.mulVec ];
      · simp_all +decide [ show v = 0 by ext; simp +decide [ ← h_fixed ] ];
      · exact fun x => by rw [ ← h_fixed x, inv_mul_eq_div, mul_div_cancel₀ _ h ] ;

/-
The sum of the entries of Av is positive for v in the standard simplex.
-/
lemma sum_mulVec_pos {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ)
    (hA_nonneg : A.IsNonneg) (hA_irr : A.IsIrreducible')
    (v : n → ℝ) (hv : v ∈ stdSimplex ℝ n) :
    0 < ∑ i, (A.mulVec v) i := by
      have h_pos : A.mulVec v ≠ 0 := by
        apply Matrix.mulVec_ne_zero_of_nonneg_of_ne_zero A hA_nonneg hA_irr v hv.1 (by
        exact fun h => by simpa [ h ] using hv.2;);
      -- Since $A$ is non-negative and $v$ is in the standard simplex, each entry of $A.mulVec v$ is non-negative.
      have h_nonneg : ∀ i, 0 ≤ (A.mulVec v) i := by
        exact fun i => by rw [ Matrix.mulVec, dotProduct ] ; exact Finset.sum_nonneg fun j _ => mul_nonneg ( hA_nonneg i j ) ( hv.1 j ) ;
      exact lt_of_lt_of_le ( lt_of_le_of_ne ( h_nonneg ( Classical.choose ( Function.ne_iff.mp h_pos ) ) ) ( Ne.symm ( Classical.choose_spec ( Function.ne_iff.mp h_pos ) ) ) ) ( Finset.single_le_sum ( fun i _ => h_nonneg i ) ( Finset.mem_univ _ ) )

