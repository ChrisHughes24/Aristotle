/-
If the rank of a matrix is n-1, its determinant is 0.
-/
lemma det_eq_zero_of_rank_eq_card_sub_one {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ)
    (h_rank : Matrix.rank A = Fintype.card n - 1) :
    Matrix.det A = 0 := by
      rw [ Matrix.rank ] at h_rank;
      contrapose! h_rank;
      rw [ @LinearMap.finrank_range_of_inj ];
      · simp +decide [ Module.finrank_pi ];
        exact ne_of_gt ( Nat.sub_lt ( Fintype.card_pos ) zero_lt_one );
      · exact fun x y hxy => by simpa [ h_rank, isUnit_iff_ne_zero ] using congr_arg ( fun z => A⁻¹.mulVec z ) hxy;

/-
If the rank of a matrix is n-1, the rank of its adjugate is at most 1.
-/
lemma rank_adjugate_le_one_of_rank_eq_card_sub_one {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ)
    (h_rank : Matrix.rank A = Fintype.card n - 1) :
    Matrix.rank (Matrix.adjugate A) ≤ 1 := by
      -- Since the rank of A is n-1, the determinant of A is zero.
      have h_det_zero : Matrix.det A = 0 := by
        exact?
      generalize_proofs at *; (
      -- Since $A * \text{adj}(A) = 0$, the image of $\text{adj}(A)$ is contained in the kernel of $A$.
      have h_image_adj_subset_kernel_A : LinearMap.range (Matrix.toLin' A.adjugate) ≤ LinearMap.ker (Matrix.toLin' A) := by
        have h_image_adj_subset_kernel_A : A * A.adjugate = 0 := by
          simp +decide [ h_det_zero, Matrix.mul_adjugate ]
        generalize_proofs at * ; (
        intro x hx; obtain ⟨ y, rfl ⟩ := hx; simp +decide [ ← Matrix.mul_assoc, h_image_adj_subset_kernel_A ] ;)
      generalize_proofs at *; (
      have := LinearMap.finrank_range_add_finrank_ker ( Matrix.toLin' A ) ; simp_all +decide [ Matrix.rank ] ;
      exact le_trans ( Submodule.finrank_mono h_image_adj_subset_kernel_A ) ( by linarith! [ Nat.sub_add_cancel ( show 1 ≤ Fintype.card n from Fintype.card_pos ) ] ) ;))

