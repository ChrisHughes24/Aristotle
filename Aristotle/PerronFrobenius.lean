/-
Define the left Perron vector and prove it is a positive eigenvector of A transpose with the same eigenvalue.
-/
noncomputable def leftPerronVector {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) : n → ℝ :=
  perronVector A.transpose (Matrix.transpose_isPositive A hA)

lemma leftPerronVector_pos {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    Matrix.IsPositiveVec (leftPerronVector A hA) :=
  perronVector_pos A.transpose (Matrix.transpose_isPositive A hA)

lemma leftPerronVector_is_eigenvector {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    A.transpose.mulVec (leftPerronVector A hA) = (perronRoot A hA) • (leftPerronVector A hA) := by
  rw [← perronRoot_transpose_eq A hA]
  exact perronVector_is_eigenvector A.transpose (Matrix.transpose_isPositive A hA)

/-
The geometric multiplicity of the Perron root is 1.
-/
lemma geometric_multiplicity_one {n : Type*} [Fintype n] [Nonempty n] [DecidableEq n] (A : Matrix n n ℝ) (hA : A.IsPositive) :
    Module.finrank ℝ (LinearMap.ker (Matrix.toLin' (perronRoot A hA • 1 - A))) = 1 := by
      -- By `eigenvector_eq_smul_perronVector`, any such eigenvector is a scalar multiple of the Perron vector.
      have h_ker_eq_span : LinearMap.ker (Matrix.toLin' ((perronRoot A hA) • 1 - A)) = Submodule.span ℝ {perronVector A hA} := by
        refine' le_antisymm _ _;
        · intro v hv; simp_all +decide [ Matrix.sub_mulVec, Matrix.smul_eq_diagonal_mul ] ;
          obtain ⟨ c, hc ⟩ := eigenvector_eq_smul_perronVector A hA v ( by
            exact eq_of_sub_eq_zero hv ▸ rfl );
          exact hc.symm ▸ Submodule.smul_mem _ _ ( Submodule.subset_span ( Set.mem_singleton _ ) );
        · simp +decide [ Matrix.sub_mulVec, perronVector_is_eigenvector ];
      rw [ h_ker_eq_span, finrank_span_singleton ];
      exact fun h => by have := perronVector_mem_stdSimplex A hA; simp_all +decide [ stdSimplex ] ;

/-
If the geometric multiplicity is 1, the rank of (rI - A) is n - 1.
-/
lemma rank_eq_card_sub_one_of_geometric_multiplicity_one {n : Type*} [Fintype n] [DecidableEq n] (A : Matrix n n ℝ) (r : ℝ)
    (h_geom : Module.finrank ℝ (LinearMap.ker (Matrix.toLin' (r • 1 - A))) = 1) :
    Matrix.rank (r • 1 - A) = Fintype.card n - 1 := by
      have := LinearMap.finrank_range_add_finrank_ker ( Matrix.toLin' ( r • 1 - A ) ) ; simp_all +decide [ Matrix.rank ] ;
      exact eq_tsub_of_add_eq this

