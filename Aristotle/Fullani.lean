theorem frullani_constant_term {a b C : ℝ} (ha : 0 < a) (hb : 0 < b) :
    ∫ u in a..b, C / u = C * Real.log (b / a) := by
      simp +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm, ha, hb, Real.log_div, ne_of_gt ]

