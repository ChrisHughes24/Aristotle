/-
Lemma: $\int_{aT}^{bT} \frac{f(x)}{x} dx = \int_a^b \frac{f(uT)}{u} du$ for $T > 0$.
-/
theorem frullani_substitution_lemma {f : ℝ → ℝ} {a b T : ℝ} (hT : 0 < T) :
    ∫ x in a * T..b * T, f x / x = ∫ u in a..b, f (u * T) / u := by
      -- Apply the substitution $x = uT$ to the integral.
      have h_subst : ∀ a b : ℝ, ∫ x in a..b, f x / x = ∫ u in (a / T).. (b / T), f (u * T) / (u * T) * T := by
        simp +decide [ div_eq_mul_inv, mul_assoc, mul_comm, mul_left_comm, intervalIntegral.integral_comp_mul_right, hT.ne' ];
        intro a b; convert intervalIntegral.integral_comp_div _ _ using 3 <;> ring ; norm_num [ hT.ne' ] ;
        · ring ; norm_num [ hT.ne' ];
        · positivity;
      convert h_subst ( a * T ) ( b * T ) using 1 ; ring_nf ; norm_num [ hT.ne' ];
      simp +decide [ mul_assoc, mul_comm T, hT.ne' ]

/-
Lemma: $\int_a^b \frac{C}{u} du = C \ln(b/a)$.
