/-
A group is finitely presented if it is isomorphic to a group presented by a finite set of generators and a finite set of relations.
-/
universe u

def IsFinitelyPresentedGroup (G : Type u) [Group G] : Prop :=
  ∃ (α : Type u) (_ : Finite α) (rels : Set (FreeGroup α)) (_ : rels.Finite),
    Nonempty (G ≃* PresentedGroup rels)

/-
The free group on a finite type is finitely generated.
-/
lemma free_group_finite_type_is_fg {α : Type u} [Finite α] : Group.FG (FreeGroup α) := by
  obtain ⟨ s, hs ⟩ := Finite.exists_equiv_fin α;
  refine' ⟨ _, _ ⟩;
  exact Finset.image ( fun g : Fin s => FreeGroup.of ( hs.some.symm g ) ) Finset.univ;
  simp +decide [ Subgroup.closure, Set.ext_iff ];
  intro a ha; ext x; induction x using FreeGroup.induction_on; aesop;
  · exact iff_of_true ( ha ⟨ hs.some ‹_›, by simp +decide ⟩ ) trivial;
  · aesop;
  · aesop

/-
The free group on a set is isomorphic to the group presented by that set with empty relations.
-/
lemma free_group_equiv_presented_group_empty {α : Type u} :
    Nonempty (FreeGroup α ≃* PresentedGroup (∅ : Set (FreeGroup α))) := by
      refine' ⟨ _ ⟩;
      symm;
      refine' { Equiv.ofBijective _ ⟨ _, _ ⟩ with .. };
      refine' fun x => Quotient.liftOn' x ( fun x => x ) _;
      all_goals simp +decide [ QuotientGroup.leftRel_apply, Subgroup.normalClosure ];
      all_goals norm_num [ Group.conjugatesOfSet ];
      all_goals norm_num [ Function.Injective, Function.Surjective, mul_eq_one_iff_eq_inv ];
      · intro x y hxy
        generalize_proofs at *;
        induction x using Quotient.inductionOn' ; induction y using Quotient.inductionOn' ; aesop;
      · exact fun b => ⟨ Quotient.mk'' b, rfl ⟩;
      · rintro ⟨ x ⟩ ⟨ y ⟩ ; rfl

