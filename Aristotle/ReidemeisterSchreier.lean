        refine' ⟨ S, _ ⟩;
        simp_all +decide [ SetLike.ext_iff, Subgroup.mem_closure, AddSubgroup.mem_closure ];
        intro x K hK; specialize hS x ( K.toSubgroup ) ; aesop;
      convert finite_basis_of_fg_free_abelian_group_v8 _;
      obtain ⟨ S, hS ⟩ := h_abelianization_fg;
      refine' ⟨ S.image h_abelianization.toFun, _ ⟩;
      simp_all +decide [ SetLike.ext_iff, AddSubgroup.mem_closure ];
      intro x K hK; specialize hS ( h_abelianization.symm x |> Additive.toMul ) ( K.comap h_abelianization.toAddMonoidHom ) ; aesop;

/-
The abelianization of a free group is isomorphic to the free abelian group.
-/
noncomputable def abelianizationToFreeAbelianGroup (α : Type u) :
    Additive (Abelianization (FreeGroup α)) →+ FreeAbelianGroup α :=
  let to_fun : FreeGroup α →* Multiplicative (FreeAbelianGroup α) :=
    FreeGroup.lift (fun x => Multiplicative.ofAdd (FreeAbelianGroup.of x))
  let f : Abelianization (FreeGroup α) →* Multiplicative (FreeAbelianGroup α) :=
    Abelianization.lift to_fun
  { toFun := fun x => Multiplicative.toAdd (f (Additive.toMul x))
    map_zero' := by simp [f]
    map_add' := by
      intro x y
      simp [f] }

noncomputable def freeAbelianGroupToAbelianization (α : Type u) :
    FreeAbelianGroup α →+ Additive (Abelianization (FreeGroup α)) :=
  FreeAbelianGroup.lift (fun x => Additive.ofMul (Abelianization.of (FreeGroup.of x)))

lemma abelianizationToFreeAbelianGroup_comp_freeAbelianGroupToAbelianization (α : Type u) :
    (abelianizationToFreeAbelianGroup α).comp (freeAbelianGroupToAbelianization α) = AddMonoidHom.id _ := by
      refine' AddMonoidHom.ext fun x => _;
      induction x using FreeAbelianGroup.induction_on <;> aesop

lemma freeAbelianGroupToAbelianization_comp_abelianizationToFreeAbelianGroup (α : Type u) :
    (freeAbelianGroupToAbelianization α).comp (abelianizationToFreeAbelianGroup α) = AddMonoidHom.id _ := by
      ext x;
      simp +decide [ freeAbelianGroupToAbelianization, abelianizationToFreeAbelianGroup ]

noncomputable def abelianizationFreeGroupEquiv (α : Type u) :
    Additive (Abelianization (FreeGroup α)) ≃+ FreeAbelianGroup α :=
  AddMonoidHom.toAddEquiv (abelianizationToFreeAbelianGroup α) (freeAbelianGroupToAbelianization α)
    (freeAbelianGroupToAbelianization_comp_abelianizationToFreeAbelianGroup α)
    (abelianizationToFreeAbelianGroup_comp_freeAbelianGroupToAbelianization α)

