          have h_iso : G ≃* (FreeGroup (IsFreeGroup.Generators G)) := by
            exact?
          have h_abelianization : (Abelianization G) ≃* (Abelianization (FreeGroup (IsFreeGroup.Generators G))) := by
            exact?;
          exact?;
        exact h_abelianization.toAdditive;
      -- Since $G$ is finitely generated, its abelianization is also finitely generated.
      have h_abelianization_fg : AddGroup.FG (Additive (Abelianization G)) := by
        have h_abelianization_fg : Group.FG (Abelianization G) := by
          have h_surjective : Function.Surjective (Abelianization.of : G → Abelianization G) := by
            exact QuotientGroup.mk_surjective
          refine' ⟨ S.image ( Abelianization.of ), _ ⟩;
          simp_all +decide [ Subgroup.eq_top_iff', Subgroup.mem_closure ];
          intro x K hK; obtain ⟨ y, rfl ⟩ := h_surjective x; specialize hS y ( K.comap ( Abelianization.of ) ) ; aesop;
