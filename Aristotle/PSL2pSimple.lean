instance PSL2_mulAction (p : ℕ) [Fact p.Prime] : MulAction (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) where
  smul := PSL2_action_map p
  one_smul := PSL2_one_smul p
