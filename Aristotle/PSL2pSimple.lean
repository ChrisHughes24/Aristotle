def check_PSL_group (p : ℕ) [Fact p.Prime] : Group (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) := by infer_instance

/-
The linear map corresponding to a matrix in SL(2, p) is injective.
-/
lemma SL2_toLin'_injective (p : ℕ) [Fact p.Prime] (A : Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) :
  Function.Injective (Matrix.toLin' (A : Matrix (Fin 2) (Fin 2) (ZMod p))) := by
    intro x y hxy;
    apply_fun fun z => ( A : Matrix ( Fin 2 ) ( Fin 2 ) ( ZMod p ) ) ⁻¹.mulVec z at hxy ; simp_all +decide [ Matrix.nonsing_inv_apply_not_isUnit, isUnit_iff_ne_zero ]

/-
Projectivization.map is congruent with respect to the linear map argument.
-/
universe u v w z

lemma Projectivization.map_congr {K : Type u} {V : Type v} [DivisionRing K] [AddCommGroup V] [Module K V] {L : Type w} {W : Type z} [DivisionRing L] [AddCommGroup W] [Module L W] {σ : K →+* L} {f g : V →ₛₗ[σ] W} (hf : Function.Injective f) (hg : Function.Injective g) (h : f = g) : Projectivization.map f hf = Projectivization.map g hg := by
  subst h
  rfl

/-
Define the map representing the action of an element of SL(2, p) on the projective line.
-/
def SL2_action_map (p : ℕ) [Fact p.Prime] (g : Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) :
  Projectivization (ZMod p) (Fin 2 → ZMod p) → Projectivization (ZMod p) (Fin 2 → ZMod p) :=
  Projectivization.map (Matrix.toLin' (g : Matrix (Fin 2) (Fin 2) (ZMod p))) (SL2_toLin'_injective p g)

/-
The action of the identity matrix is the identity map.
-/
lemma SL2_action_map_one (p : ℕ) [Fact p.Prime] (x : Projectivization (ZMod p) (Fin 2 → ZMod p)) :
  SL2_action_map p 1 x = x := by
    unfold SL2_action_map;
    induction x using Quotient.inductionOn' ; aesop

/-
The action of SL(2, p) on the projective line respects multiplication.
-/
lemma SL2_action_map_mul (p : ℕ) [Fact p.Prime] (g h : Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) (x : Projectivization (ZMod p) (Fin 2 → ZMod p)) :
  SL2_action_map p (g * h) x = SL2_action_map p g (SL2_action_map p h x) := by
    -- By definition of SL2_action_map, we have that it is a projectivization map.
    unfold SL2_action_map;
    induction x using Quotient.inductionOn' ; aesop

/-
Define the action of SL(2, p) on the projective line.
-/
instance SL2_mulAction (p : ℕ) [Fact p.Prime] : MulAction (Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) where
  smul g x := SL2_action_map p g x
  one_smul := SL2_action_map_one p
  mul_smul := SL2_action_map_mul p

/-
The center of SL(2, p) acts trivially on the projective line.
-/
lemma SL2_center_acts_trivially (p : ℕ) [Fact p.Prime] (g : Subgroup.center (Matrix.SpecialLinearGroup (Fin 2) (ZMod p))) (x : Projectivization (ZMod p) (Fin 2 → ZMod p)) :
  g • x = x := by
  obtain ⟨g, hg⟩ := g
  rw [Subgroup.mem_center_iff] at hg
  -- The center of SL(2, p) is {I, -I}
  -- But we don't strictly need to know the elements, just that they are scalar matrices.
  -- Actually, for SL(n), the center consists of scalar matrices cI where c^n = 1.
  -- For n=2, c^2 = 1.
  -- A scalar matrix cI acts as multiplication by c on vectors.
  -- Projectivization identifies v and c*v.
  -- So scalar matrices act trivially.
  -- We need to show g is a scalar matrix.
  -- Mathlib should have a theorem about the center of SL(n).
  -- Since $g$ commutes with all elements of $SL(2, p)$, it must be a scalar matrix.
  have h_scalar : ∃ c : ZMod p, g = Matrix.diagonal ![c, c] := by
    simp_all +decide [ Matrix.SpecialLinearGroup.ext_iff, Matrix.mul_apply ];
    have := hg ⟨ Matrix.of ![![1, 1], ![0, 1]], by simp +decide [ Matrix.det_fin_two ] ⟩ ; have := hg ⟨ Matrix.of ![![1, 0], ![1, 1]], by simp +decide [ Matrix.det_fin_two ] ⟩ ; simp_all +decide [ ← Matrix.ext_iff, Fin.forall_fin_two ] ;
  rcases h_scalar with ⟨ c, hc ⟩ ; simp_all +decide [ Matrix.SpecialLinearGroup.ext_iff ] ; (
  -- Since $c$ is a unit in $ZMod p$, multiplication by $c$ is an invertible operation on the projective line.
  have h_unit : IsUnit c := by
    have := g.2; aesop;
  generalize_proofs at *; (
  rcases x with ⟨ x, hx ⟩ ; rcases h_unit with ⟨ u, rfl ⟩ ; simp_all +decide [ Matrix.SpecialLinearGroup.ext_iff ] ; (
  erw [ Quotient.eq ] ; simp_all +decide [ Projectivization.map ] ; (
  refine' ⟨ u, _ ⟩ ; ext i ; fin_cases i <;> simp +decide [ Matrix.mulVec ] ; ring!;
  · exact?;
  · exact?))));

/-
Define the action of PSL(2, p) on the projective line.
-/
def PSL2_action_map (p : ℕ) [Fact p.Prime] :
  Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p) → Projectivization (ZMod p) (Fin 2 → ZMod p) → Projectivization (ZMod p) (Fin 2 → ZMod p) :=
  Quotient.lift (SL2_action_map p) (by
    intro g1 g2 h
    have h_rel : g1⁻¹ * g2 ∈ Subgroup.center (Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) := by
      change (QuotientGroup.leftRel (Subgroup.center (Matrix.SpecialLinearGroup (Fin 2) (ZMod p)))).r g1 g2 at h
      rw [QuotientGroup.leftRel_apply] at h
      exact h
    let z := g1⁻¹ * g2
    have h_eq : g2 = g1 * z := by
      simp [z]
    funext x
    rw [h_eq, SL2_action_map_mul]
    have h_z_act : SL2_action_map p z x = x := SL2_center_acts_trivially p ⟨z, h_rel⟩ x
    rw [h_z_act]
  )

/-
The action of PSL(2, p) on the projective line respects multiplication.
-/
lemma PSL2_mul_smul (p : ℕ) [Fact p.Prime] (g h : Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (x : Projectivization (ZMod p) (Fin 2 → ZMod p)) :
  PSL2_action_map p (g * h) x = PSL2_action_map p g (PSL2_action_map p h x) := by
    obtain ⟨ g, rfl ⟩ := QuotientGroup.mk_surjective g; obtain ⟨ h, rfl ⟩ := QuotientGroup.mk_surjective h;
    convert SL2_action_map_mul p g h x using 1

/-
The identity element of PSL(2, p) acts as the identity map on the projective line.
-/
lemma PSL2_one_smul (p : ℕ) [Fact p.Prime] (x : Projectivization (ZMod p) (Fin 2 → ZMod p)) :
  PSL2_action_map p 1 x = x := by
  have h1 : (1 : Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) = QuotientGroup.mk 1 := rfl
  rw [h1]
  -- PSL2_action_map is defined as Quotient.lift ...
  -- So PSL2_action_map p (QuotientGroup.mk 1) = SL2_action_map p 1
  rw [PSL2_action_map, Quotient.lift_mk]
  apply SL2_action_map_one

