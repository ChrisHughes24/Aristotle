def check_PSL2_smul (p : ℕ) [Fact p.Prime] : SMul (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) := by infer_instance

/-
If an element of SL(2, p) acts trivially on the projective line, it is in the center.
-/
lemma SL2_act_trivial_implies_center (p : ℕ) [Fact p.Prime] (g : Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) (h : ∀ x : Projectivization (ZMod p) (Fin 2 → ZMod p), SL2_action_map p g x = x) :
  g ∈ Subgroup.center (Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) := by
  -- If g acts trivially on the projective line, then g v is a scalar multiple of v for all v.
  -- This implies g is a scalar matrix.
  -- Since det(g) = 1, g must be c • I where c^2 = 1.
  -- Such matrices are exactly the center of SL(2, p).
  have h_center : ∀ x : Projectivization (ZMod p) (Fin 2 → ZMod p), Projectivization.map (Matrix.toLin' (g : Matrix (Fin 2) (Fin 2) (ZMod p))) (SL2_toLin'_injective p g) x = x := by
    exact h;
  -- If g acts trivially on the projective line, then for any vector v, g(v) is a scalar multiple of v. This implies that g commutes with any matrix in SL(2, p), hence g is in the center.
  have h_scalar : ∀ v : Fin 2 → ZMod p, v ≠ 0 → ∃ c : ZMod p, g.val.mulVec v = c • v := by
    intro v hv_nonzero
    specialize h_center (Projectivization.mk (ZMod p) v hv_nonzero);
    rw [ Projectivization.map_mk, Projectivization.mk_eq_mk_iff ] at h_center;
    exact ⟨ h_center.choose.val, by simpa [ mul_comm ] using h_center.choose_spec.symm ⟩;
  -- Since g is a scalar matrix, we can write g = cI for some scalar c.
  obtain ⟨c, hc⟩ : ∃ c : ZMod p, g.val = c • 1 := by
    obtain ⟨c₁, hc₁⟩ := h_scalar (Pi.single 0 1) (by
    exact ne_of_apply_ne ( fun x => x 0 ) one_ne_zero)
    obtain ⟨c₂, hc₂⟩ := h_scalar (Pi.single 1 1) (by
    exact ne_of_apply_ne ( fun x => x 1 ) one_ne_zero);
    simp_all +decide [ funext_iff, Fin.forall_fin_two, Matrix.mulVec, dotProduct ];
    obtain ⟨ c, hc ⟩ := h_scalar ( fun i => if i = 0 then 1 else 1 ) ( by simp +decide ) ; use c ; ext i j ; fin_cases i <;> fin_cases j <;> aesop;
  rw [ Subgroup.mem_center_iff ] ; aesop

/-
The action of PSL(2, p) on the projective line is faithful.
-/
lemma PSL2_faithful_action (p : ℕ) [Fact p.Prime] (hp : 5 ≤ p) :
  FaithfulSMul (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) := by
    constructor;
    intro m₁ m₂ h_eq
    obtain ⟨g₁, hg₁⟩ : ∃ g₁ : Matrix.SpecialLinearGroup (Fin 2) (ZMod p), m₁ = Quotient.mk'' g₁ := by
      exact Quotient.exists_rep m₁ |> fun ⟨ g₁, hg₁ ⟩ => ⟨ g₁, hg₁.symm ⟩
    obtain ⟨g₂, hg₂⟩ : ∃ g₂ : Matrix.SpecialLinearGroup (Fin 2) (ZMod p), m₂ = Quotient.mk'' g₂ := by
      obtain ⟨ g₂, rfl ⟩ := Quotient.exists_rep m₂; exact ⟨ g₂, rfl ⟩ ;
    have h_center : g₁⁻¹ * g₂ ∈ Subgroup.center (Matrix.SpecialLinearGroup (Fin 2) (ZMod p)) := by
      have h_center : ∀ x : Projectivization (ZMod p) (Fin 2 → ZMod p), SL2_action_map p (g₁⁻¹ * g₂) x = x := by
        intro x
        have h_eq' : SL2_action_map p g₁ x = SL2_action_map p g₂ x := by
          aesop;
        have h_eq'' : SL2_action_map p g₁⁻¹ (SL2_action_map p g₁ x) = x := by
          rw [ ← SL2_action_map_mul p ] ; simp +decide [ hg₁ ] ;
          exact?;
        convert h_eq'' using 1;
        rw [h_eq'];
        exact?;
      exact?;
    rw [ hg₁, hg₂, QuotientGroup.eq ];
    exact h_center

def check_PSL2_SMul (p : ℕ) [Fact p.Prime] : SMul (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) := by infer_instance

/-
For any two distinct points in the projective line, there exist representatives with determinant 1.
-/
lemma exists_rep_det_one (p : ℕ) [Fact p.Prime] (P1 P2 : Projectivization (ZMod p) (Fin 2 → ZMod p)) (h : P1 ≠ P2) :
  ∃ (v1 v2 : Fin 2 → ZMod p) (h1 : v1 ≠ 0) (h2 : v2 ≠ 0),
    Projectivization.mk (ZMod p) v1 h1 = P1 ∧
    Projectivization.mk (ZMod p) v2 h2 = P2 ∧
    Matrix.det (Matrix.of ![![v1 0, v2 0], ![v1 1, v2 1]]) = 1 := by
      rcases P1 with ⟨v1, hv1⟩; rcases P2 with ⟨v2, hv2⟩; simp_all +decide [ Projectivization.mk_eq_mk_iff ] ;
      -- Since $v1$ and $v2$ are linearly independent, we can scale $v2$ by a scalar $c$ such that the determinant of the matrix formed by $v1$ and $c*v2$ is 1.
      obtain ⟨c, hc⟩ : ∃ c : ZMod p, c * (v1 0 * v2 1 - v2 0 * v1 1) = 1 := by
        have h_det_nonzero : v1 0 * v2 1 - v2 0 * v1 1 ≠ 0 := by
          contrapose! h;
          -- Since $v1$ and $v2$ are linearly dependent, there exists a scalar $c$ such that $v1 = c • v2$.
          obtain ⟨c, hc⟩ : ∃ c : ZMod p, v1 = c • v2 := by
            by_cases hv20 : v2 0 = 0 <;> by_cases hv21 : v2 1 = 0 <;> simp_all +decide [ funext_iff, Fin.forall_fin_two ];
            · exact ⟨ v1 1 / v2 1, by rw [ div_mul_cancel₀ _ hv21 ] ⟩;
            · exact ⟨ v1 0 / v2 0, by rw [ div_mul_cancel₀ _ hv20 ] ⟩;
            · use v1 1 / v2 1;
              grind;
          exact Quotient.sound ⟨ Units.mk0 c ( by aesop ), by aesop ⟩;
        exact ⟨ _, inv_mul_cancel₀ h_det_nonzero ⟩;
      refine' ⟨ v1, _, c • v2, _, _ ⟩ <;> simp_all +decide [ funext_iff, Fin.forall_fin_two ];
      · rfl;
      · refine' ⟨ _, _ ⟩;
        exact fun h => by simp +decide [ h ] at hc;
        exact Quotient.sound ⟨ Units.mk0 c ( by aesop_cat ), by aesop_cat ⟩;
      · linear_combination' hc

/-
SL(2, p) acts 2-transitively on the projective line.
-/
lemma SL2_exists_g_of_pairs (p : ℕ) [Fact p.Prime] (x1 x2 y1 y2 : Projectivization (ZMod p) (Fin 2 → ZMod p)) (hx : x1 ≠ x2) (hy : y1 ≠ y2) :
  ∃ g : Matrix.SpecialLinearGroup (Fin 2) (ZMod p), SL2_action_map p g x1 = y1 ∧ SL2_action_map p g x2 = y2 := by
  obtain ⟨vx1, vx2, hvx1, hvx2, hx1_eq, hx2_eq, h_det_x⟩ := exists_rep_det_one p x1 x2 hx
  obtain ⟨vy1, vy2, hvy1, hvy2, hy1_eq, hy2_eq, h_det_y⟩ := exists_rep_det_one p y1 y2 hy
  let Mx := Matrix.of ![![vx1 0, vx2 0], ![vx1 1, vx2 1]]
  let My := Matrix.of ![![vy1 0, vy2 0], ![vy1 1, vy2 1]]
  have h_det_Mx : Mx.det = 1 := h_det_x
  have h_det_My : My.det = 1 := h_det_y
  let g_x : Matrix.SpecialLinearGroup (Fin 2) (ZMod p) := ⟨Mx, h_det_Mx⟩
  let g_y : Matrix.SpecialLinearGroup (Fin 2) (ZMod p) := ⟨My, h_det_My⟩
  let g := g_y * g_x⁻¹
  use g
  constructor
  · -- g • x1 = y1
    -- g • x1 = g_y • (g_x⁻¹ • x1)
    -- We need to show g_x • e1 = x1 (or something similar)
    -- Actually, g_x maps basis vectors to vx1, vx2.
    -- Let e1 = ![1, 0], e2 = ![0, 1].
    -- g_x.val.mulVec e1 = vx1
    -- g_x.val.mulVec e2 = vx2
    -- So g_x • [e1] = [vx1] = x1
    -- g_x • [e2] = [vx2] = x2
    -- Similarly for g_y.
    -- Then g • x1 = g_y • g_x⁻¹ • x1 = g_y • [e1] = y1
    rw [ ← hx1_eq, ← hy1_eq ];
    unfold SL2_action_map;
    erw [ Projectivization.map_mk ];
    rw [ Projectivization.mk_eq_mk_iff ];
    simp +zetaDelta at *;
    use 1; ext i; fin_cases i <;> norm_num [ Matrix.vecHead, Matrix.vecTail ] <;> ring;
    · linear_combination' -h_det_x * vy1 0;
    · linear_combination -h_det_x * vy1 1
  · -- g • x2 = y2
    convert hy2_eq using 1;
    rw [ ← hx2_eq ];
    unfold SL2_action_map;
    erw [ Projectivization.map_mk ];
    rw [ Projectivization.mk_eq_mk_iff ];
    refine' ⟨ 1, _ ⟩ ; ext i ; fin_cases i <;> norm_num [ Matrix.mulVec ];
    · simp +zetaDelta at *;
      linear_combination -h_det_x * vy2 0;
    · simp +zetaDelta at *;
      linear_combination -h_det_x * vy2 1

/-
The action of PSL(2, p) on the projective line is 2-transitive.
-/
lemma PSL2_two_transitive (p : ℕ) [Fact p.Prime] (hp : 5 ≤ p) :
  MulAction.IsMultiplyPretransitive (Matrix.ProjectiveSpecialLinearGroup (Fin 2) (ZMod p)) (Projectivization (ZMod p) (Fin 2 → ZMod p)) 2 := by
    refine' ⟨ _ ⟩;
    intro x y
    obtain ⟨g, hg⟩ : ∃ g : Matrix.SpecialLinearGroup (Fin 2) (ZMod p), ∀ i : Fin 2, SL2_action_map p g (x i) = y i := by
      convert SL2_exists_g_of_pairs p ( x 0 ) ( x 1 ) ( y 0 ) ( y 1 ) ?_ ?_ using 1 <;> simp +decide [ Fin.forall_fin_two ];
    use Quotient.mk'' g; ext i; exact (by
    convert hg i using 1);

/-
For p >= 5, there exists a unit u such that u^2 != 1.
-/
lemma exists_unit_sq_ne_one (p : ℕ) [Fact p.Prime] (hp : 5 ≤ p) :
  ∃ u : (ZMod p)ˣ, u ^ 2 ≠ 1 := by
  have h_card_fin : Fintype.card (ZMod p)ˣ = p - 1 := ZMod.card_units p
  have h_card_nat : Nat.card (ZMod p)ˣ = p - 1 := by
    rw [Nat.card_eq_fintype_card, h_card_fin]
  have h_sols : ({x : (ZMod p)ˣ | x ^ 2 = 1}).ncard ≤ 2 := by
    -- x^2 - 1 = 0 has at most 2 roots in a field
    -- The set of solutions to $x^2 = 1$ in a field is exactly $\{1, -1\}$.
    have h_solutions : {x : (ZMod p)ˣ | x^2 = 1} ⊆ {1, -1} := by
      intro x hx
      have h_eq : (x : ZMod p) ^ 2 = 1 := by
        simpa using congr_arg ( fun x : ( ZMod p ) ˣ => ( x : ZMod p ) ) hx;
      aesop;
    exact le_trans ( Set.ncard_le_ncard h_solutions ) ( Set.ncard_insert_le _ _ ) |> le_trans <| by norm_num;
  have h_univ : (Set.univ : Set (ZMod p)ˣ).ncard = p - 1 := by
    rw [Set.ncard_univ, h_card_nat]
  -- p - 1 >= 4
  have h_ineq : 4 ≤ p - 1 := by
    exact Nat.le_sub_one_of_lt hp
  -- So ncard univ > ncard sols
  -- Thus there exists x in univ \ sols
  have h_univ : Set.ncard (Set.univ \ { x : (ZMod p)ˣ | x^2 = 1 }) > 0 := by
    rw [ Set.ncard_diff ] <;> norm_num [ Set.ncard_univ ] at * ; omega;
  obtain ⟨ u, hu ⟩ := Set.nonempty_of_ncard_ne_zero h_univ.ne'; use u; aesop;

/-
The commutator of a diagonal matrix and a transvection is a transvection.
-/
lemma commutator_of_diagonal_and_transvection (p : ℕ) [Fact p.Prime] (u : (ZMod p)ˣ) (y : ZMod p) :
  let u_val : ZMod p := u
  let u_inv : ZMod p := u⁻¹
  let B := Matrix.of ![![u_val, 0], ![0, u_inv]]
  let C := Matrix.of ![![1, y], ![0, 1]]
  let B_inv := Matrix.of ![![u_inv, 0], ![0, u_val]]
  let C_inv := Matrix.of ![![1, -y], ![0, 1]]
  B * C * B_inv * C_inv = Matrix.of ![![1, (u_val ^ 2 - 1) * y], ![0, 1]] := by
    rw [ inv_eq_of_mul_eq_one_right ];
    norm_num [ ← Matrix.one_fin_two, ← Matrix.ext_iff ];
    rw [ mul_inv_cancel₀ ];
    · exact ⟨ ⟨ rfl, by ring ⟩, inv_mul_cancel₀ ( Units.ne_zero u ) ⟩;
    · aesop;
    · exact mul_inv_cancel₀ ( Units.ne_zero u )

/-
The commutator of a diagonal matrix and a transvection is a transvection.
-/
lemma commutator_of_diagonal_and_transvection' (p : ℕ) [Fact p.Prime] (u : (ZMod p)ˣ) (y : ZMod p) :
  let u_val : ZMod p := u
  let u_inv : ZMod p := u⁻¹
  let B := Matrix.of ![![u_val, 0], ![0, u_inv]]
  let C := Matrix.of ![![1, y], ![0, 1]]
  let B_inv := Matrix.of ![![u_inv, 0], ![0, u_val]]
  let C_inv := Matrix.of ![![1, -y], ![0, 1]]
  B * C * B_inv * C_inv = Matrix.of ![![1, (u_val ^ 2 - 1) * y], ![0, 1]] := by
    convert commutator_of_diagonal_and_transvection p u y using 1

/-
