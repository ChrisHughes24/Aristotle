set_option autoImplicit false

noncomputable section

/-
Two sets s and t are equidecomposable if they can be partitioned into finitely many pieces such that each piece of s can be moved by an element of G to the corresponding piece of t.
-/
def Equidecomposable {G X : Type*} [Group G] [MulAction G X] (s t : Set X) : Prop :=
  ∃ (n : ℕ) (f : Fin n → G) (s_parts t_parts : Fin n → Set X),
    (⋃ i, s_parts i) = s ∧
    (⋃ i, t_parts i) = t ∧
    (∀ i j, i ≠ j → Disjoint (s_parts i) (s_parts j)) ∧
    (∀ i j, i ≠ j → Disjoint (t_parts i) (t_parts j)) ∧
    (∀ i, f i • s_parts i = t_parts i)

/-
A set s is paradoxical if it contains two disjoint subsets a and b such that s is equidecomposable to a and s is equidecomposable to b.
-/
def Paradoxical {G X : Type*} [Group G] [MulAction G X] (s : Set X) : Prop :=
  ∃ (a b : Set X),
    Disjoint a b ∧
    a ⊆ s ∧
    b ⊆ s ∧
    @Equidecomposable G X _ _ s a ∧
    @Equidecomposable G X _ _ s b

/-
Defining the action of affine isometries on Euclidean space.
-/
instance : MulAction (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3)) where
  smul g x := g x
  one_smul := by
    bound
  mul_smul := by
    aesop

/-
Checking if FreeGroup is available.
-/
#check FreeGroup (Fin 2)

/-
Checking FreeGroup functions.
-/
#check FreeGroup.toWord
#check FreeGroup.reduce

/-
W(i, b) is the set of elements in the free group whose reduced word representation starts with the generator (i, b).
-/
def W (i : Fin 2) (b : Bool) : Set (FreeGroup (Fin 2)) :=
  {w | match FreeGroup.toWord w with
       | [] => False
       | (h :: _) => h = (i, b)}

/-
Defining the generator elements and stating that the sets W(x) are pairwise disjoint.
-/
def generator (i : Fin 2) (b : Bool) : FreeGroup (Fin 2) :=
  if b then FreeGroup.of i else (FreeGroup.of i)⁻¹

theorem W_disjoint : ∀ x y : Fin 2 × Bool, x ≠ y → Disjoint (W x.1 x.2) (W y.1 y.2) := by
  intro x y hxy; rw [ Set.disjoint_left ] ; intro w hw1 hw2; simp_all +decide [ W ] ;
  cases h : w.toWord <;> aesop

/-
The entire group is the union of W(i, b) and the translate of W(i, !b) by the generator (i, b).
-/
theorem decomposition_union (i : Fin 2) (b : Bool) :
  Set.univ = W i b ∪ (generator i b) • (W i (!b)) := by
    ext w;
    by_cases hi : w ∈ W i b <;> simp_all +decide [ Set.mem_smul_set, Set.mem_union ];
    use ( generator i b ) ⁻¹ * w;
    cases b <;> simp_all +decide [ generator ];
    · unfold W at *;
      rcases w with ⟨ ⟨ l ⟩ ⟩ <;> simp_all +decide [ FreeGroup.of, FreeGroup.toWord ];
      rename_i k hk;
      rcases h : FreeGroup.reduce hk with ( _ | ⟨ a, _ | ⟨ b, l ⟩ ⟩ ) <;> simp_all +decide;
      · grind;
      · split_ifs <;> simp_all +decide;
        grind;
      · split_ifs <;> simp_all +decide [ List.rec ];
        · grind;
        · grind;
    · unfold W at *;
      rcases w with ⟨ l ⟩ ; simp_all +decide [ FreeGroup.of, FreeGroup.toWord ];
      simp_all +decide [ FreeGroup.invRev ];
      cases h : FreeGroup.reduce l <;> aesop

/-
A group is paradoxical if it is paradoxical as a set under its own left action.
-/
def GroupParadoxical (G : Type*) [Group G] : Prop :=
  @Paradoxical G G _ _ Set.univ

/-
If a list (x :: y :: L) is reduced, then x and y are not inverses of each other.
-/
theorem reduced_head_not_inv {α} [DecidableEq α] (x y : α × Bool) (L : List (α × Bool)) :
  FreeGroup.IsReduced (x :: y :: L) → ¬ (x.1 = y.1 ∧ x.2 = !y.2) := by
    aesop

/-
If a list starts with the inverse of x and is reduced, then reducing the list prepended with x results in the tail.
-/
theorem reduce_cons_inv_eq_tail {α} [DecidableEq α] (x : α × Bool) (tail : List (α × Bool)) :
  FreeGroup.IsReduced ((x.1, !x.2) :: tail) → FreeGroup.reduce (x :: (x.1, !x.2) :: tail) = tail := by
    -- By definition of `FreeGroup.IsReduced`, if the word `(x.1, !x.2) :: tail` is reduced, then `x.1` and `x.2` are not inverses of each other.
    intro h_reduced
    simp [FreeGroup.IsReduced] at h_reduced;
    -- By definition of `reduce`, we know that if the list is reduced, then the reduction of the list is the list itself.
    have h_reduced_tail : FreeGroup.reduce ((x.1, !x.2) :: tail) = (x.1, !x.2) :: tail := by
      have h_reduced_tail : ∀ (L : List (α × Bool)), List.IsChain (fun (a b : α × Bool) => a.1 = b.1 → a.2 = b.2) L → FreeGroup.reduce L = L := by
        intro L hL;
        induction' L with a L ih;
        · rfl;
        · induction' L with b L ih generalizing a <;> simp_all +decide [ List.IsChain ];
      exact h_reduced_tail _ h_reduced;
    cases x ; aesop

/-
Proving lemma_disjoint_aux using the helper lemma reduce_cons_inv_eq_tail.
-/
theorem lemma_disjoint_aux (i : Fin 2) (b : Bool) (w : FreeGroup (Fin 2)) :
  w ∈ W i (!b) → (generator i b) * w ∉ W i b := by
    intro hw hw';
    -- By definition of $W$, we know that if $w \in W i !b$, then the reduced word representation of $w$ starts with $(i, !b)$.
    obtain ⟨L, hL⟩ : ∃ L : List (Fin 2 × Bool), FreeGroup.toWord w = (i, !b) :: L := by
      unfold W at hw; aesop;
    -- By definition of $W$, we know that if $w \in W i !b$, then the reduced word representation of $generator i b * w$ starts with $(i, b)$.
    have h_reduced_word : FreeGroup.toWord (generator i b * w) = FreeGroup.reduce ((i, b) :: (i, !b) :: L) := by
      convert FreeGroup.toWord_mul _ _ using 2;
      unfold generator; aesop;
    -- By definition of $W$, we know that if $w \in W i !b$, then the reduced word representation of $generator i b * w$ starts with $(i, b)$ and is reduced.
    have h_reduced_word_reduced : FreeGroup.IsReduced ((i, !b) :: L) := by
      have h_reduced_word_reduced : FreeGroup.IsReduced (FreeGroup.toWord w) := by
        exact?;
      aesop;
    have h_reduced_word_reduced : FreeGroup.reduce ((i, b) :: (i, !b) :: L) = L := by
      convert reduce_cons_inv_eq_tail ( i, b ) L h_reduced_word_reduced using 1;
    unfold W at hw'; aesop;

/-
Proving that W(i, b) and the translate of W(i, !b) are disjoint using the helper lemma.
-/
theorem decomposition_disjoint (i : Fin 2) (b : Bool) :
  Disjoint (W i b) ((generator i b) • (W i (!b))) := by
  rw [Set.disjoint_left]
  intro x hx h_smul
  rw [Set.mem_smul_set] at h_smul
  rcases h_smul with ⟨w, hw, rfl⟩
  have h_not_mem := lemma_disjoint_aux i b w hw
  contradiction

/-
Proving that the free group on two generators is paradoxical.
We define A = W(a) U W(a^-1) and B = W(b) U W(b^-1).
A and B are disjoint because the W sets are disjoint.
We show Set.univ is equidecomposable to A using the decomposition Set.univ = W(a) U a W(a^-1).
We show Set.univ is equidecomposable to B using the decomposition Set.univ = W(b) U b W(b^-1).
-/
theorem FreeGroup_paradoxical : GroupParadoxical (FreeGroup (Fin 2)) := by
  -- Let's define the subsets A and B as described in the decomposition.
  set A : Set (FreeGroup (Fin 2)) := W 0 true ∪ W 0 false
  set B : Set (FreeGroup (Fin 2)) := W 1 true ∪ W 1 false;
  -- We need to show that the free group is equidecomposable to both A and B.
  have h_equidecomp_A : @Equidecomposable (FreeGroup (Fin 2)) (FreeGroup (Fin 2)) _ _ Set.univ A := by
    -- We can decompose the universal set into $W(a)$ and $a W(a^{-1})$.
    have h_decomp_A : Set.univ = W 0 true ∪ (generator 0 true) • W 0 false := by
      exact decomposition_union 0 Bool.true;
    use 2, ![1, (generator 0 true)⁻¹], ![W 0 true, (generator 0 true) • W 0 false], ![W 0 true, W 0 false];
    simp_all +decide [ Fin.forall_fin_two, Set.ext_iff ];
    simp +zetaDelta at *;
    exact ⟨ ⟨ decomposition_disjoint 0 Bool.true, decomposition_disjoint 0 Bool.true |> Disjoint.symm ⟩, W_disjoint ( 0, Bool.true ) ( 0, Bool.false ) ( by decide ), W_disjoint ( 0, Bool.false ) ( 0, Bool.true ) ( by decide ) ⟩
  have h_equidecomp_B : @Equidecomposable (FreeGroup (Fin 2)) (FreeGroup (Fin 2)) _ _ Set.univ B := by
    -- We can decompose the universal set into $W(b)$ and $bW(b^{-1})$.
    have h_decomp_B : Set.univ = W 1 true ∪ (generator 1 true) • (W 1 false) := by
      exact decomposition_union _ _;
    -- By definition of equidecomposability, we can use the decomposition of the universal set into $W(1, \text{true})$ and $(\text{generator } 1 \text{ true}) \cdot W(1, \text{false})$ to show that the universal set is equidecomposable to $B$.
    use 2, ![1, (generator 1 true)⁻¹], ![W 1 true, (generator 1 true) • W 1 false], ![W 1 true, W 1 false];
    simp_all +decide [ Fin.forall_fin_two, Set.ext_iff ];
    refine' ⟨ _, _, _, _ ⟩ <;> norm_num [ Set.disjoint_left ];
    · aesop;
    · constructor <;> intro x hx₁ hx₂ <;> simp_all +decide [ Set.mem_smul_set ];
      · obtain ⟨ y, hy₁, hy₂ ⟩ := hx₂; have := lemma_disjoint_aux 1 Bool.true y hy₁; aesop;
      · obtain ⟨ y, hy₁, rfl ⟩ := hx₁; exact lemma_disjoint_aux 1 Bool.true y hy₁ ( by simpa using hx₂ ) ;
    · intro x hx₁ hx₂; have := W_disjoint ( 1, Bool.true ) ( 1, Bool.false ) ; simp_all +decide [ Set.disjoint_left ] ;
    · intro x hx₁ hx₂; have := W_disjoint ( 1, Bool.false ) ( 1, Bool.true ) ; simp_all +decide [ Set.disjoint_left ] ;
  -- Since A and B are disjoint, we can conclude that the free group is paradoxical.
  have h_disjoint : Disjoint A B := by
    simp +zetaDelta at *;
    exact ⟨ ⟨ W_disjoint ( 0, Bool.true ) ( 1, Bool.true ) ( by decide ), W_disjoint ( 0, Bool.false ) ( 1, Bool.true ) ( by decide ) ⟩, W_disjoint ( 0, Bool.true ) ( 1, Bool.false ) ( by decide ), W_disjoint ( 0, Bool.false ) ( 1, Bool.false ) ( by decide ) ⟩;
  exact ⟨ A, B, h_disjoint, by tauto, by tauto, h_equidecomp_A, h_equidecomp_B ⟩

/-
Defining two rotation matrices in SO(3) that will generate a free subgroup. rot_x is a rotation about the x-axis by arccos(1/3), and rot_z is a rotation about the z-axis by arccos(1/3).
-/
noncomputable def rot_x : Matrix (Fin 3) (Fin 3) ℝ :=
  !![1, 0, 0;
     0, 1/3, -2*Real.sqrt 2 / 3;
     0, 2*Real.sqrt 2 / 3, 1/3]

noncomputable def rot_z : Matrix (Fin 3) (Fin 3) ℝ :=
  !![1/3, -2*Real.sqrt 2 / 3, 0;
     2*Real.sqrt 2 / 3, 1/3, 0;
     0, 0, 1]

theorem rot_x_mem_SO3 : rot_x ∈ Matrix.specialOrthogonalGroup (Fin 3) ℝ := by
  unfold rot_x;
  constructor <;> norm_num [ ← List.ofFn_inj ];
  · constructor <;> ext i j <;> fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Fin.sum_univ_succ ] <;> ring_nf <;> norm_num;
  · norm_num [ Matrix.det_fin_three ] ; ring;
    repeat erw [ Matrix.cons_val_succ' ] ; norm_num;
    ring ; norm_num
theorem rot_z_mem_SO3 : rot_z ∈ Matrix.specialOrthogonalGroup (Fin 3) ℝ := by
  -- To prove that rot_z is in the special orthogonal group, we need to show that it is orthogonal and has determinant 1.
  have h_orthogonal : rot_z * Matrix.transpose rot_z = 1 := by
    ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Matrix.transpose_apply ];
    all_goals norm_num [ Fin.sum_univ_succ, rot_z ];
    · ring_nf; norm_num;
    · ring;
    · ring;
    · ring_nf; norm_num;
  constructor;
  · constructor;
    · exact?;
    · convert h_orthogonal using 1;
  · simp +zetaDelta at *;
    unfold rot_z;
    norm_num [ Matrix.det_fin_three ] ; ring ; norm_num;
    repeat erw [ Matrix.cons_val_succ' ] ; norm_num;

#check EuclideanSpace
#check Metric.sphere
#check Metric.ball
#check FreeGroup.lift

#synth Group (Matrix.specialOrthogonalGroup (Fin 3) ℝ)
#synth MulAction (Matrix.specialOrthogonalGroup (Fin 3) ℝ) (EuclideanSpace ℝ (Fin 3))

/-
Define the map from the generators of the free group to the specific rotation matrices `rot_x` and `rot_z`, and extend this to a group homomorphism from the free group to SO(3).
-/
def rotations : Fin 2 → Matrix.specialOrthogonalGroup (Fin 3) ℝ :=
  fun i => if i = 0 then ⟨rot_x, rot_x_mem_SO3⟩ else ⟨rot_z, rot_z_mem_SO3⟩

def free_group_to_SO3 : FreeGroup (Fin 2) →* Matrix.specialOrthogonalGroup (Fin 3) ℝ :=
  FreeGroup.lift rotations

/-
Define the unit sphere S2 and the action of SO(3) on it.
-/
def S2 : Set (EuclideanSpace ℝ (Fin 3)) := Metric.sphere 0 1

instance : MulAction (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 where
  smul g x := ⟨g • x.1, by
    -- By definition of $S2$, we know that $||x|| = 1$.
    have h_norm : ‖(x : EuclideanSpace ℝ (Fin 3))‖ = 1 := by
      aesop;
    convert h_norm using 1;
    have h_norm_preserved : ∀ (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (x : EuclideanSpace ℝ (Fin 3)), ‖g • x‖ = ‖x‖ := by
      simp +decide [ EuclideanSpace.norm_eq, Fin.sum_univ_three ];
      intro a ha x; refine' congr_arg Real.sqrt _; have := ha.2; simp_all +decide [ Matrix.mulVec, dotProduct ] ; ring;
      -- Since $a$ is in the special orthogonal group, we have $a^T a = I$, which implies that $a$ preserves the dot product.
      have h_dot_product : ∀ (x y : EuclideanSpace ℝ (Fin 3)), (a.mulVec x) ⬝ᵥ (a.mulVec y) = x ⬝ᵥ y := by
        have h_dot_product : a.transpose * a = 1 := by
          have := ha.1; simp_all +decide [ Matrix.mul_eq_one_comm ] ;
          exact this.2;
        simp +decide [ Matrix.dotProduct_mulVec, Matrix.vecMul_mulVec, h_dot_product ];
      convert h_dot_product x x using 1 <;> norm_num [ Matrix.mulVec, dotProduct ] ; ring;
      · rw [ Fin.sum_univ_three ] ; ring!;
      · rw [ Fin.sum_univ_three ] ; ring!;
    simp_all +decide [ S2 ];
    convert h_norm_preserved g g.2 x using 1;
    exact Eq.symm ( by simp [ EuclideanSpace.norm_eq ] )⟩
  one_smul := by
    all_goals generalize_proofs at *;
    simp +zetaDelta at *;
    intro a ha;
    convert Subtype.ext ?_;
    convert one_smul _ _
  mul_smul := by
    all_goals generalize_proofs at *;
    intros x y b;
    -- By definition of matrix multiplication and the action of SO(3) on Euclidean space, we have:
    have h_assoc : ∀ (g h : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (v : EuclideanSpace ℝ (Fin 3)), (g * h) • v = g • (h • v) := by
      simp +decide [ Matrix.mulVec_smul, MulAction.mul_smul ];
    exact Subtype.ext <| h_assoc x y b

#check Set.Countable
#check MulAction.fixedPoints

/-
The image of a paradoxical group under an injective homomorphism is a paradoxical set.
-/
theorem paradoxical_image {G H : Type*} [Group G] [Group H] (f : G →* H) (hf : Function.Injective f) (hG : GroupParadoxical G) : @Paradoxical H H _ _ (Set.range f) := by
  obtain ⟨ a, b, hab, ha, hb, ha', hb' ⟩ := hG;
  refine' ⟨ f '' a, f '' b, _, _, _, _, _ ⟩;
  · exact Set.disjoint_image_of_injective hf hab;
  · exact Set.image_subset_range _ _;
  · exact Set.image_subset_range _ _;
  · obtain ⟨ n, f_parts, s_parts, t_parts, hs, ht, hs_disjoint, ht_disjoint, h_parts ⟩ := ha';
    refine' ⟨ n, fun i => f ( f_parts i ), fun i => f '' s_parts i, fun i => f '' t_parts i, _, _, _, _, _ ⟩ <;> simp_all +decide [ Set.ext_iff ];
    · exact fun x => ⟨ fun ⟨ i, y, hy, hx ⟩ => ⟨ y, hx ⟩, fun ⟨ y, hy ⟩ => by obtain ⟨ i, hi ⟩ := hs y; exact ⟨ i, y, hi, hy ⟩ ⟩;
    · grind;
    · simp +decide [ ← h_parts, Set.mem_smul_set, hf.eq_iff ];
  · obtain ⟨ n, f', s_parts, t_parts, hs, ht, hs', ht', h ⟩ := hb';
    refine' ⟨ n, fun i => f ( f' i ), fun i => f '' s_parts i, fun i => f '' t_parts i, _, _, _, _, _ ⟩ <;> simp_all +decide [ Set.ext_iff ];
    · exact fun x => ⟨ fun ⟨ i, y, hy, hx ⟩ => ⟨ y, hx ⟩, fun ⟨ y, hy ⟩ => by obtain ⟨ i, hi ⟩ := hs y; exact ⟨ i, y, hi, hy ⟩ ⟩;
    · grind;
    · simp +decide [ ← h, Set.mem_smul_set, hf.eq_iff ]

/-
The intersection of a subspace of dimension at most 1 with the unit sphere is finite.
-/
theorem finite_inter_sphere (V : Submodule ℝ (EuclideanSpace ℝ (Fin 3))) (h : Module.finrank ℝ V ≤ 1) :
  Set.Finite (Metric.sphere (0 : EuclideanSpace ℝ (Fin 3)) 1 ∩ (V : Set (EuclideanSpace ℝ (Fin 3)))) := by
    by_cases h_zero : V = ⊥;
    · exact Set.Finite.to_subtype <| Set.Finite.subset ( Set.finite_singleton 0 ) fun x hx => by aesop;
    · -- Since $V$ is not the zero subspace, it must be one-dimensional.
      have h_one_dim : Module.finrank ℝ V = 1 := by
        exact le_antisymm h ( Nat.pos_of_ne_zero fun con => h_zero <| Submodule.finrank_eq_zero.mp con );
      -- Since $V$ is one-dimensional, there exists a nonzero vector $v$ such that $V = \text{span}(v)$.
      obtain ⟨v, hv⟩ : ∃ v : EuclideanSpace ℝ (Fin 3), v ≠ 0 ∧ ∀ w : EuclideanSpace ℝ (Fin 3), w ∈ V ↔ ∃ t : ℝ, w = t • v := by
        obtain ⟨ v, hv ⟩ := finrank_eq_one_iff'.mp h_one_dim;
        simp +zetaDelta at *;
        exact ⟨ v, by simpa using hv.1, fun w => ⟨ fun hw => by obtain ⟨ t, ht ⟩ := hv.2 w hw; exact ⟨ t, by simpa [ Subtype.ext_iff ] using ht.symm ⟩, fun hw => by obtain ⟨ t, rfl ⟩ := hw; exact Submodule.smul_mem _ _ v.2 ⟩ ⟩;
      -- Since $V$ is one-dimensional, the intersection of $V$ with the unit sphere is finite.
      have h_finite : ∀ t : ℝ, t • v ∈ Metric.sphere 0 1 → t = 1 / ‖v‖ ∨ t = -1 / ‖v‖ := by
        simp_all +decide [ norm_smul, div_eq_inv_mul ];
        exact fun t ht => eq_or_eq_neg_of_abs_eq ( by rw [ inv_eq_of_mul_eq_one_left ht ] );
      exact Set.Finite.subset ( Set.toFinite { ( 1 / ‖v‖ ) • v, ( -1 / ‖v‖ ) • v } ) fun x hx => by rcases hx with ⟨ hx₁, hx₂ ⟩ ; rcases hv.2 x |>.1 hx₂ with ⟨ t, rfl ⟩ ; specialize h_finite t; aesop;

#check crossProduct
#check Matrix.det_fin_three

/-
A vector v is special at level k if its components are of the form (a*sqrt(2)/3^k, b/3^k, c*sqrt(2)/3^k) where b is not divisible by 3.
-/
def IsSpecial (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) : Prop :=
  ∃ a b c : ℤ,
    v 0 = a * Real.sqrt 2 / 3^k ∧
    v 1 = b / 3^k ∧
    v 2 = c * Real.sqrt 2 / 3^k ∧
    ¬ (3 ∣ b)

/-
Applying rot_x to a vector with components (a*sqrt(2)/3^k, b/3^k, c*sqrt(2)/3^k) results in a vector with components ((3a)*sqrt(2)/3^(k+1), (b-4c)/3^(k+1), (2b+c)*sqrt(2)/3^(k+1)).
-/
theorem rot_x_map_special (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) (a b c : ℤ) :
  v 0 = a * Real.sqrt 2 / 3^k →
  v 1 = b / 3^k →
  v 2 = c * Real.sqrt 2 / 3^k →
  (rot_x • v) 0 = (3 * a) * Real.sqrt 2 / 3^(k+1) ∧
  (rot_x • v) 1 = (b - 4 * c) / 3^(k+1) ∧
  (rot_x • v) 2 = (2 * b + c) * Real.sqrt 2 / 3^(k+1) := by
    unfold rot_x; intro h₀ h₁ h₂; norm_num [ h₀, h₁, h₂, Matrix.mulVec ] ; ring_nf ;
    -- By definition of matrix multiplication, we can compute each component of the resulting vector.
    simp [Matrix.mulVec, h₀, h₁, h₂];
    erw [ show ( !![1, 0, 0; 0, 3⁻¹, Real.sqrt 2 * ( -2 / 3 ) ; 0, Real.sqrt 2 * ( 2 / 3 ), 3⁻¹ ] • v ) = fun i => ( Matrix.mulVec ( !![1, 0, 0; 0, 3⁻¹, Real.sqrt 2 * ( -2 / 3 ) ; 0, Real.sqrt 2 * ( 2 / 3 ), 3⁻¹ ] ) v ) i from rfl ] ; norm_num [ Matrix.mulVec, h₀, h₁, h₂ ] ; ring ; norm_num;
    norm_num [ Matrix.vecHead, Matrix.vecTail, dotProduct, h₀, h₁, h₂ ] ; ring ; norm_num;
    erw [ Fin.sum_univ_three ] ; norm_num ; ring ; norm_num [ h₀, h₁, h₂ ] ;
    erw [ Matrix.cons_val_succ' ] ; norm_num ; ring ; norm_num [ h₀, h₁, h₂ ] ;
    erw [ Matrix.cons_val_succ' ] ; norm_num ; ring ; norm_num [ h₀, h₁, h₂ ] ;
    erw [ Matrix.cons_val_succ' ] ; norm_num ; ring ; norm_num [ h₀, h₁, h₂ ] ;
    erw [ Matrix.cons_val_succ' ] ; norm_num ; ring ; norm_num [ h₀, h₁, h₂ ] ;
    erw [ h₁, h₂ ] ; ring!;
    norm_num ; ring

/-
Applying rot_z to a vector with components (a*sqrt(2)/3^k, b/3^k, c*sqrt(2)/3^k) results in a vector with components ((a-2b)*sqrt(2)/3^(k+1), (4a+b)/3^(k+1), (3c)*sqrt(2)/3^(k+1)).
-/
theorem rot_z_map_special (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) (a b c : ℤ) :
  v 0 = a * Real.sqrt 2 / 3^k →
  v 1 = b / 3^k →
  v 2 = c * Real.sqrt 2 / 3^k →
  (rot_z • v) 0 = (a - 2 * b) * Real.sqrt 2 / 3^(k+1) ∧
  (rot_z • v) 1 = (4 * a + b) / 3^(k+1) ∧
  (rot_z • v) 2 = (3 * c) * Real.sqrt 2 / 3^(k+1) := by
    intro hv0 hv1 hv2
    have h_comp0 : (rot_z • v) 0 = (1/3 : ℝ) * v 0 - (2 * Real.sqrt 2 / 3) * v 1 := by
      exact show ( ∑ i : Fin 3, ( if i = 0 then 1 / 3 else if i = 1 then -2 * Real.sqrt 2 / 3 else 0 ) * v i ) = 1 / 3 * v 0 - 2 * Real.sqrt 2 / 3 * v 1 from by simp +decide [ Fin.sum_univ_three ] ; ring;
    have h_comp1 : (rot_z • v) 1 = (2 * Real.sqrt 2 / 3) * v 0 + (1/3 : ℝ) * v 1 := by
      convert congr_arg ( fun x : EuclideanSpace ℝ ( Fin 3 ) => x 1 ) ( show rot_z • v = fun i => ∑ j, rot_z i j * v j from ?_ ) using 1 ; norm_num [ Fin.sum_univ_three ] ; ring!;
      · unfold rot_z; norm_num; ring;
        aesop;
      · exact?
    have h_comp2 : (rot_z • v) 2 = v 2 := by
      -- By definition of matrix multiplication, the third component of the rotated vector is the dot product of the third row of rot_z and the vector v.
      have h_comp2 : (rot_z • v) 2 = (0 : ℝ) * v 0 + (0 : ℝ) * v 1 + (1 : ℝ) * v 2 := by
        convert congr_arg ( fun x : EuclideanSpace ℝ ( Fin 3 ) => x 2 ) ( show rot_z • v = fun i => ∑ j, rot_z i j * v j from ?_ ) using 1 ; norm_num [ Fin.sum_univ_three ] ; ring!;
        · unfold rot_z ;
          simp +zetaDelta at *;
        · exact?;
      linarith
    simp_all +decide [ div_eq_mul_inv, pow_succ', mul_assoc, mul_comm, mul_left_comm ] ; ring!;
    norm_num

/-
Applying rot_x inverse to a vector with components (a*sqrt(2)/3^k, b/3^k, c*sqrt(2)/3^k) results in a vector with components ((3a)*sqrt(2)/3^(k+1), (b+4c)/3^(k+1), (-2b+c)*sqrt(2)/3^(k+1)).
-/
theorem rot_x_inv_map_special (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) (a b c : ℤ) :
  v 0 = a * Real.sqrt 2 / 3^k →
  v 1 = b / 3^k →
  v 2 = c * Real.sqrt 2 / 3^k →
  (rot_x⁻¹ • v) 0 = (3 * a) * Real.sqrt 2 / 3^(k+1) ∧
  (rot_x⁻¹ • v) 1 = (b + 4 * c) / 3^(k+1) ∧
  (rot_x⁻¹ • v) 2 = (-2 * b + c) * Real.sqrt 2 / 3^(k+1) := by
    intro hv₀ hv₁ hv₂;
    -- By definition of matrix multiplication and the given form of rot_x⁻¹,
    -- we can calculate each component of rot_x⁻¹ • v.
    have h_comp : ∀ i, (rot_x⁻¹ • v) i = ∑ j, (rot_x⁻¹ : Matrix (Fin 3) (Fin 3) ℝ) i j * v j := by
      exact?;
    simp_all +decide [ Fin.sum_univ_three ];
    rw [ Matrix.inv_eq_left_inv ] ; ring_nf ; norm_num;
    rotate_right;
    exact Matrix.of ![![1, 0, 0], ![0, 1 / 3, 2 * Real.sqrt 2 / 3], ![0, -2 * Real.sqrt 2 / 3, 1 / 3]];
    · simp +zetaDelta at *;
      constructor <;> ring ; norm_num ; ring;
    · unfold rot_x; ext i j; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Fin.sum_univ_succ ] <;> ring_nf <;> norm_num;

/-
Applying rot_z inverse to a vector with components (a*sqrt(2)/3^k, b/3^k, c*sqrt(2)/3^k) results in a vector with components ((a+2b)*sqrt(2)/3^(k+1), (-4a+b)/3^(k+1), (3c)*sqrt(2)/3^(k+1)).
-/
theorem rot_z_inv_map_special (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) (a b c : ℤ) :
  v 0 = a * Real.sqrt 2 / 3^k →
  v 1 = b / 3^k →
  v 2 = c * Real.sqrt 2 / 3^k →
  (rot_z⁻¹ • v) 0 = (a + 2 * b) * Real.sqrt 2 / 3^(k+1) ∧
  (rot_z⁻¹ • v) 1 = (-4 * a + b) / 3^(k+1) ∧
  (rot_z⁻¹ • v) 2 = (3 * c) * Real.sqrt 2 / 3^(k+1) := by
    intro h₀ h₁ h₂;
    -- Let's compute the dot product of the i-th row of rot_z⁻¹ with the vector v.
    have h_dot : ∀ i : Fin 3, (rot_z⁻¹ • v) i = ∑ j, (rot_z⁻¹ i j) * (v j) := by
      exact?;
    simp_all +decide [ Fin.sum_univ_three ];
    erw [ Matrix.inv_eq_left_inv ] ; ring_nf ; norm_num;
    any_goals exact Matrix.of ![![1 / 3, 2 * Real.sqrt 2 / 3, 0], ![-2 * Real.sqrt 2 / 3, 1 / 3, 0], ![0, 0, 1]];
    · simp +zetaDelta at *;
      grind;
    · unfold rot_z; ext i j; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Fin.sum_univ_succ ] <;> ring_nf <;> norm_num;

/-
MatchesInvariant describes the modular arithmetic properties of the vector components after applying a reduced word ending in g. rotation_matrix returns the matrix corresponding to a generator g.
-/
def MatchesInvariant (g : Fin 2 × Bool) (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) : Prop :=
  ∃ a b c : ℤ,
    v 0 = a * Real.sqrt 2 / 3^k ∧
    v 1 = b / 3^k ∧
    v 2 = c * Real.sqrt 2 / 3^k ∧
    ¬ (3 ∣ b) ∧
    match g with
    | (0, true)  => (3 ∣ a) ∧ (3 ∣ (b + c))
    | (0, false) => (3 ∣ a) ∧ (3 ∣ (b - c))
    | (1, true)  => (3 ∣ c) ∧ (3 ∣ (b - a))
    | (1, false) => (3 ∣ c) ∧ (3 ∣ (b + a))

def rotation_matrix (g : Fin 2 × Bool) : Matrix (Fin 3) (Fin 3) ℝ :=
  if g.2 then
    if g.1 = 0 then rot_x else rot_z
  else
    if g.1 = 0 then rot_x⁻¹ else rot_z⁻¹

/-
If a vector v satisfies the invariant for generator g, and h is not the inverse of g, then applying h to v results in a vector satisfying the invariant for h.
-/
theorem step_invariant (g h : Fin 2 × Bool) (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) :
  h ≠ (g.1, !g.2) →
  MatchesInvariant g k v →
  MatchesInvariant h (k + 1) (rotation_matrix h • v) := by
    -- By definition of rotation_matrix, we can split into cases based on the value of h.
    by_cases h_case : h = (0, true) ∨ h = (0, false) ∨ h = (1, true) ∨ h = (1, false);
    · rcases h_case with ( rfl | rfl | rfl | rfl ) <;> simp_all +decide [ rotation_matrix ];
      · rintro hg ⟨ a, b, c, ha, hb, hc, h ⟩;
        obtain ⟨ ha₁, ha₂ ⟩ := rot_x_map_special k v a b c ha hb hc;
        use 3 * a, b - 4 * c, 2 * b + c;
        fin_cases g <;> simp_all +decide [ dvd_add_right, dvd_add_left, dvd_sub_right, dvd_sub_left, dvd_mul_of_dvd_right ];
        · exact ⟨ by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega, by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega ⟩;
        · exact Int.dvd_of_emod_eq_zero ( by obtain ⟨ d, hd ⟩ := h.2.1; obtain ⟨ e, he ⟩ := h.2.2; omega );
        · exact Int.dvd_of_emod_eq_zero ( by obtain ⟨ d, hd ⟩ := h.2.1; obtain ⟨ e, he ⟩ := h.2.2; omega );
      · intro hg hv; rcases hv with ⟨ a, b, c, hv₀, hv₁, hv₂, hv₃, hv₄ ⟩ ; rcases g with ⟨ g₁, g₂ ⟩ ; fin_cases g₁ <;> fin_cases g₂ <;> simp_all +decide [ MatchesInvariant ] ;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h. We'll handle each case separately.
          use 3 * a, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, b + 4 * c, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; push_cast ; ring, -2 * b + c, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.right using 1 ; push_cast ; ring;
          exact ⟨ by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega, by norm_num, by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega ⟩;
        · -- By definition of rot_x⁻¹, we have:
          have h_rot_x_inv : (rot_x⁻¹ • v) 0 = (3 * a) * Real.sqrt 2 / 3^(k+1) ∧ (rot_x⁻¹ • v) 1 = (b + 4 * c) / 3^(k+1) ∧ (rot_x⁻¹ • v) 2 = (-2 * b + c) * Real.sqrt 2 / 3^(k+1) := by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ using 1;
          refine' ⟨ 3 * a, _, b + 4 * c, _, -2 * b + c, _, _ ⟩ <;> norm_num [ h_rot_x_inv ];
          exact ⟨ by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega, by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega ⟩;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h and apply the corresponding lemma.
          use 3 * a, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, b + 4 * c, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; push_cast ; ring, -2 * b + c, by
            convert rot_x_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.right using 1 ; push_cast ; ring;
          exact ⟨ by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega, by norm_num, by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega ⟩;
      · intro hg hv; rcases hv with ⟨ a, b, c, hv₀, hv₁, hv₂, hv₃, hv₄ ⟩ ; rcases g with ⟨ g₁, g₂ ⟩ ; fin_cases g₁ <;> fin_cases g₂ <;> simp_all +decide [ MatchesInvariant ] ;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h and use the helper lemmas to get the form of the new vector.
          use a - 2 * b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, 4 * a + b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |>.2.1 using 1 ; push_cast ; ring, 3 * c, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |>.2.2 using 1 ; push_cast ; ring;
          grind;
        · use a - 2 * b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; ring;
            push_cast; ring;, 4 * a + b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |>.2.1 using 1 ; push_cast ; ring, 3 * c, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |>.2.2 using 1 ; push_cast ; ring;
          grind;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h and apply the corresponding lemma.
          use a - 2 * b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, 4 * a + b, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; push_cast ; ring, 3 * c, by
            convert rot_z_map_special k v a b c hv₀ hv₁ hv₂ |>.2.2 using 1 ; ring;
            push_cast; ring;
          rw [ Int.dvd_iff_emod_eq_zero ] at *; omega;
      · intro hg hv; rcases hv with ⟨ a, b, c, hv₀, hv₁, hv₂, hv₃, hv₄ ⟩ ; rcases g with ⟨ g₁, g₂ ⟩ ; fin_cases g₁ <;> fin_cases g₂ <;> simp_all +decide [ MatchesInvariant ] ;
        · -- Let's simplify the expression for the new vector after applying the rotation matrix.
          use a + 2 * b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, -4 * a + b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; ring;
            push_cast; ring, 3 * c, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.right using 1 ; push_cast ; ring;
          grind;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h and apply the corresponding lemma.
          use a + 2 * b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; ring;
            push_cast; ring, -4 * a + b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; ring;
            push_cast; ring, 3 * c, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.right using 1 ; push_cast ; ring;
          grind;
        · -- By definition of rotation_matrix, we can split into cases based on the value of h and apply the corresponding lemma.
          use a + 2 * b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.left using 1 ; push_cast ; ring, -4 * a + b, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.left using 1 ; push_cast ; ring, 3 * c, by
            convert rot_z_inv_map_special k v a b c hv₀ hv₁ hv₂ |> And.right |> And.right using 1 ; push_cast ; ring;
          exact ⟨ by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega, by norm_num, by rw [ Int.dvd_iff_emod_eq_zero ] at *; omega ⟩;
    · fin_cases h <;> contradiction

/-
Applying any generator to the vector (0, 1, 0) results in a vector satisfying the invariant at level 1.
-/
theorem base_case_invariant (g : Fin 2 × Bool) :
  MatchesInvariant g 1 (rotation_matrix g • ![0, 1, 0]) := by
    fin_cases g <;> simp +decide [ rotation_matrix ];
    · use 0, 1, 2;
      field_simp;
      rw [ show rot_x • _ = Matrix.mulVec rot_x _ from rfl ] ; norm_num [ Matrix.mulVec ] ; ring_nf ;
      unfold rot_x; norm_num [ Matrix.vecHead, Matrix.vecTail ] ; ring;
      exact show ( Real.sqrt 2 * ( 2 / 3 ) ) * 3 = Real.sqrt 2 * 2 by ring;
    · use 0, 1, -2;
      norm_num [ Matrix.inv_def, dotProduct ];
      unfold rot_x;
      norm_num [ Matrix.det_fin_three, Matrix.adjugate_apply, Matrix.mulVec ];
      simp +decide [ Matrix.vecHead, Matrix.vecTail, Matrix.updateRow_apply ] ; ring_nf ; norm_num;
    · use -2, 1, 0 ; norm_num [ Matrix.mulVec ] ; ring ; norm_num;
      rw [ show ( rot_z • _ : EuclideanSpace ℝ ( Fin 3 ) ) = ( Matrix.mulVec rot_z ![0, 1, 0] ) by rfl ] ; norm_num [ Matrix.mulVec ] ; ring ;
      unfold rot_z; norm_num [ Matrix.vecHead, Matrix.vecTail ] ; ring ; norm_num;
      rfl;
    · -- By definition of matrix multiplication and the properties of the rotation matrix, we can compute the components of the resulting vector.
      use 2, 1, 0
      simp [rot_z_inv_map_special];
      convert rot_z_inv_map_special 0 _ _ _ _ _ _ using 1 <;> norm_num;
      rotate_left;
      exact fun i => if i = 0 then 0 else if i = 1 then 1 else 0;
      exact 0;
      exact 1;
      exact 0;
      · norm_num;
      · norm_num [ Fin.ext_iff ];
      · simp +decide [ Matrix.mulVec, dotProduct ];
        congr! 2

/-
If a vector satisfies the invariant at level k >= 1, it cannot be the vector (0, 1, 0).
-/
theorem invariant_implies_ne_axis (g : Fin 2 × Bool) (k : ℕ) (v : EuclideanSpace ℝ (Fin 3)) :
  MatchesInvariant g k v → k ≥ 1 → v ≠ ![0, 1, 0] := by
    intro hv hk hv'; obtain ⟨ a, b, c, ha, hb, hc, hb', h ⟩ := hv; have := congr_fun hv' 1; norm_num at this; simp_all +decide [ division_def ] ;
    fin_cases g <;> contradiction

/-
For a non-empty reduced word L, the matrix corresponding to L maps (0, 1, 0) to a vector satisfying the invariant for the first generator in L.
-/
theorem reduced_word_invariant (L : List (Fin 2 × Bool)) (h_red : FreeGroup.IsReduced L) (h_ne : L ≠ []) :
  let g := L.head h_ne
  let M := List.foldl (fun M (g : Fin 2 × Bool) => M * rotation_matrix g) 1 L
  MatchesInvariant g L.length (M • ![0, 1, 0]) := by
    rcases L with ( _ | ⟨ g, _ | ⟨ h, L ⟩ ⟩ ) <;> simp_all +decide [ Matrix.mulVec ];
    · contradiction;
    · exact base_case_invariant g;
    · -- By the induction hypothesis, we know that the vector after applying the tail satisfies the invariant for h.
      have h_ind : MatchesInvariant h (L.length + 1) (List.foldl (fun M g => M * rotation_matrix g) (1 : Matrix (Fin 3) (Fin 3) ℝ) (h :: L) • ![0, 1, 0]) := by
        have h_ind : ∀ (L : List (Fin 2 × Bool)), FreeGroup.IsReduced L → L ≠ [] → ∀ (g : Fin 2 × Bool), g = L.head! → MatchesInvariant g L.length (List.foldl (fun M g => M * rotation_matrix g) (1 : Matrix (Fin 3) (Fin 3) ℝ) L • ![0, 1, 0]) := by
          intros L h_red h_ne g hg
          induction' L with g L ih generalizing g;
          · contradiction;
          · by_cases hL : L = [] <;> simp_all +decide [ FreeGroup.IsReduced ];
            · exact base_case_invariant _;
            · have := ih ( by
                exact h_red.tail )
              generalize_proofs at *;
              convert step_invariant _ _ _ _ _ this using 1;
              · have h_assoc : ∀ (L : List (Fin 2 × Bool)) (M : Matrix (Fin 3) (Fin 3) ℝ), List.foldl (fun M g => M * rotation_matrix g) M L = M * List.foldl (fun M g => M * rotation_matrix g) 1 L := by
                  intro L M; induction' L using List.reverseRecOn with L ih <;> simp +decide [ *, Matrix.mul_assoc ] ;
                generalize_proofs at *; (
                rw [ h_assoc ];
                exact?);
              · cases L <;> aesop;
        simpa using h_ind ( h :: L ) h_red.2 ( by aesop ) h rfl;
      convert step_invariant h g (L.length + 1) _ _ using 1;
      any_goals exact List.foldl ( fun M g => M * rotation_matrix g ) 1 ( h :: L ) • ![0, 1, 0];
      · norm_num +zetaDelta at *;
        rw [ show List.foldl ( fun M g => M * rotation_matrix g ) ( rotation_matrix g * rotation_matrix h ) L = rotation_matrix g * List.foldl ( fun M g => M * rotation_matrix g ) ( rotation_matrix h ) L from ?_ ];
        · simp +decide [ ← MulAction.mul_smul ];
          exact Or.inl h_ind;
        · clear h_ind h_red h_ne;
          induction' L using List.reverseRecOn with L ih <;> simp_all +decide [ ← mul_assoc ];
      · cases h ; aesop

/-
For a non-empty reduced word L, the matrix corresponding to L maps (0, 1, 0) to a vector satisfying the invariant for the first generator in L.
-/
theorem reduced_word_invariant_aux (L : List (Fin 2 × Bool)) (h_red : FreeGroup.IsReduced L) (h_ne : L ≠ []) :
  let g := L.head h_ne
  let M := List.foldl (fun M (g : Fin 2 × Bool) => M * rotation_matrix g) 1 L
  MatchesInvariant g L.length (M • ![0, 1, 0]) := by
    convert reduced_word_invariant L h_red h_ne using 1

/-
The foldl of rotation matrices starting with A is equal to A multiplied by the foldl starting with 1.
-/
theorem foldl_rotation_matrix_mul (L : List (Fin 2 × Bool)) (A : Matrix (Fin 3) (Fin 3) ℝ) :
  List.foldl (fun M g => M * rotation_matrix g) A L = A * List.foldl (fun M g => M * rotation_matrix g) 1 L := by
    induction' L using List.reverseRecOn with L ih;
    · norm_num +zetaDelta at *;
    · simp +decide [ *, mul_assoc ]

/-
The image of a single generator (or its inverse) under free_group_to_SO3 is the corresponding rotation matrix.
-/
theorem lift_mk_singleton (g : Fin 2 × Bool) :
  (free_group_to_SO3 (FreeGroup.mk [g]) : Matrix (Fin 3) (Fin 3) ℝ) = rotation_matrix g := by
    fin_cases g <;> simp +decide [ * ];
    · unfold free_group_to_SO3; aesop;
    · -- By definition of `free_group_to_SO3`, we have `(free_group_to_SO3 (FreeGroup.mk [(0, false)]) : Matrix (Fin 3) (Fin 3) ℝ) = rotations (0, false)`.
      simp [free_group_to_SO3, rotations];
      unfold rotation_matrix;
      unfold rot_x; norm_num [ Matrix.det_fin_three, Matrix.adjugate_apply, Matrix.inv_def ] ;
      simp +decide [ Matrix.inv_def ];
      ring_nf; norm_num;
      ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.inv_def ];
      exact?;
      exact?;
      exact?;
      exact?;
      · exact?;
      · exact?;
      · exact?;
      · exact?;
      · exact?;
    · unfold free_group_to_SO3 rotation_matrix; aesop;
    · unfold free_group_to_SO3 rotation_matrix; simp +decide [ FreeGroup.lift ] ;
      unfold rot_z; norm_num [ FreeGroup.Lift.aux ] ;
      unfold rotations; norm_num [ FreeGroup.lift ] ;
      rw [ Matrix.inv_eq_left_inv ] ; norm_num [ Matrix.vecMul, Matrix.mul_apply ] ; ring_nf ; norm_num [ ← List.ofFn_inj ] ;
      erw [ Subtype.coe_mk ] ; norm_num [ Matrix.inv_def ] ; ring ; norm_num [ ← List.ofFn_inj ] ;
      unfold rot_z; norm_num [ ← List.ofFn_inj ] ; ring_nf ; norm_num [ ← List.ofFn_inj ] ;
      ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Fin.sum_univ_succ ] <;> ring <;> norm_num

/-
The image of a word represented by a list L under free_group_to_SO3 is equal to the product of the rotation matrices corresponding to the elements of L.
-/
theorem lift_mk_eq_foldl (L : List (Fin 2 × Bool)) :
  (free_group_to_SO3 (FreeGroup.mk L) : Matrix (Fin 3) (Fin 3) ℝ) = List.foldl (fun M (g : Fin 2 × Bool) => M * rotation_matrix g) 1 L := by
    induction' L using List.reverseRecOn with L ih <;> simp_all +decide [ sub_eq_add_neg, add_assoc ] ;
    · exact MonoidHom.map_one _;
    · convert congr_arg₂ ( · * · ) ‹_› rfl using 1;
      convert congr_arg ( fun x : Matrix.specialOrthogonalGroup ( Fin 3 ) ℝ => x.val ) ( free_group_to_SO3.map_mul ( FreeGroup.mk L ) ( FreeGroup.mk [ ih ] ) ) using 1;
      simp +zetaDelta at *;
      congr! 2;
      exact?

/-
The homomorphism from the free group to SO(3) is injective.
-/
theorem free_group_to_SO3_injective : Function.Injective free_group_to_SO3 := by
  -- By definition of free_group_to_SO3, if free_group_to_SO3 w = 1, then w must be the identity element in the free group.
  have h_kernel : ∀ w : FreeGroup (Fin 2), free_group_to_SO3 w = 1 → w = 1 := by
    intro w hw
    by_contra h_nonempty
    generalize_proofs at *;
    -- Let L = FreeGroup.toWord w.
    set L := FreeGroup.toWord w with hL_def
    have hL_ne_empty : L ≠ [] := by
      aesop
    generalize_proofs at *;
    -- By reduced_word_invariant, M • (0, 1, 0) satisfies MatchesInvariant at level length L.
    have hM_invariant : MatchesInvariant (L.head hL_ne_empty) L.length ((free_group_to_SO3 w : Matrix (Fin 3) (Fin 3) ℝ) • ![0, 1, 0]) := by
      convert reduced_word_invariant L _ hL_ne_empty using 1
      generalize_proofs at *; (
      rw [ ← lift_mk_eq_foldl ];
      congr! 2
      generalize_proofs at *; (
      exact congr_arg _ ( by exact? )));
      exact?
    generalize_proofs at *; (
    -- Since L is not empty, length L >= 1.
    have hL_length : 1 ≤ L.length := by
      exact List.length_pos_iff.mpr hL_ne_empty
    generalize_proofs at *; (
    exact absurd hM_invariant ( by erw [ hw ] ; exact fun h => invariant_implies_ne_axis _ _ _ h hL_length <| by ext i; fin_cases i <;> norm_num )))
  generalize_proofs at *;
  exact?

/-
D is the set of points in S2 that are fixed by some non-trivial element of the free group.
-/
def D : Set S2 := ⋃ (g : FreeGroup (Fin 2)) (hg : g ≠ 1), MulAction.fixedBy (↥S2) (free_group_to_SO3 g)

#synth Countable (FreeGroup (Fin 2))

#check Matrix.toLin'

/-
Rotation matrices preserve the cross product.
-/
theorem crossProduct_map_so3 (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (u v : EuclideanSpace ℝ (Fin 3)) :
  g • (crossProduct u v) = crossProduct (g • u) (g • v) := by
    have h_det : ∀ (w : EuclideanSpace ℝ (Fin 3)), (g • w) ⬝ᵥ (crossProduct (g • u) (g • v)) = (g • w) ⬝ᵥ (g • (crossProduct u v)) := by
      intro w;
      have h_det : ∀ (w : EuclideanSpace ℝ (Fin 3)), (g.val.mulVec w) ⬝ᵥ (crossProduct (g.val.mulVec u) (g.val.mulVec v)) = (w ⬝ᵥ (crossProduct u v)) := by
        intro w
        have h_det : Matrix.det (Matrix.of ![![w 0, u 0, v 0], ![w 1, u 1, v 1], ![w 2, u 2, v 2]]) = Matrix.det (Matrix.of ![![g.val.mulVec w 0, g.val.mulVec u 0, g.val.mulVec v 0], ![g.val.mulVec w 1, g.val.mulVec u 1, g.val.mulVec v 1], ![g.val.mulVec w 2, g.val.mulVec u 2, g.val.mulVec v 2]]) := by
          have h_det : Matrix.det (Matrix.of ![![w 0, u 0, v 0], ![w 1, u 1, v 1], ![w 2, u 2, v 2]]) = Matrix.det (g.val * Matrix.of ![![w 0, u 0, v 0], ![w 1, u 1, v 1], ![w 2, u 2, v 2]]) := by
            have := g.2.2; simp_all +decide [ Matrix.det_fin_three ] ;
          convert h_det using 1;
        simp_all +decide [ Matrix.det_fin_three, cross_apply ];
        linarith!;
      have h_dot_product : ∀ (x y : EuclideanSpace ℝ (Fin 3)), (g.val.mulVec x) ⬝ᵥ (g.val.mulVec y) = x ⬝ᵥ y := by
        intro x y; have := g.2; simp_all +decide [ Matrix.mulVec, dotProduct ] ; ring;
        have h_dot_product : ∀ (x y : EuclideanSpace ℝ (Fin 3)), (g.val.mulVec x) ⬝ᵥ (g.val.mulVec y) = x ⬝ᵥ y := by
          intro x y
          have h_ortho : g.val.transpose * g.val = 1 := by
            have := g.2.2; simp_all +decide [ Matrix.mul_eq_one_comm ] ;
            have := g.2.1; simp_all +decide [ Matrix.mul_eq_one_comm ] ;
            exact this.2
          simp +decide [ Matrix.dotProduct_mulVec, Matrix.vecMul_mulVec, h_ortho ];
        simpa [ Matrix.mulVec, dotProduct ] using h_dot_product x y
      generalize_proofs at *;
      convert h_det w using 1;
      convert h_dot_product w ( crossProduct u v ) using 1;
    -- By the properties of the dot product and the surjectivity of g, we can conclude that the vectors are equal.
    have h_eq : ∀ (a b : EuclideanSpace ℝ (Fin 3)), (∀ w : EuclideanSpace ℝ (Fin 3), (g • w) ⬝ᵥ a = (g • w) ⬝ᵥ b) → a = b := by
      intros a b h_eq
      have h_surj : Function.Surjective (fun w : EuclideanSpace ℝ (Fin 3) => g • w) := by
        exact fun w => ⟨ g⁻¹ • w, by simp +decide ⟩;
      exact funext fun i => by simpa using h_eq ( Classical.choose ( h_surj ( Pi.single i 1 ) ) ) |> fun h => by simpa [ Classical.choose_spec ( h_surj ( Pi.single i 1 ) ) ] using h;
    exact h_eq _ _ fun w => h_det w ▸ rfl

/-
If two vectors are linearly independent, adding their cross product preserves linear independence.
-/
theorem linearIndependent_crossProduct (u v : EuclideanSpace ℝ (Fin 3)) (h : LinearIndependent ℝ ![u, v]) :
  LinearIndependent ℝ ![u, v, crossProduct u v] := by
    by_contra h_contra;
    -- Since $u$ and $v$ are linearly independent, $u \times v \neq 0$.
    have h_cross_ne_zero : crossProduct u v ≠ 0 := by
      exact crossProduct_ne_zero_iff_linearIndependent.mpr h;
    -- Since $u$ and $v$ are linearly independent, $u \times v$ is orthogonal to both $u$ and $v$.
    have h_cross_orthogonal : dotProduct (crossProduct u v) u = 0 ∧ dotProduct (crossProduct u v) v = 0 := by
      simp +decide [ crossProduct, dotProduct ];
      constructor <;> norm_num [ Fin.sum_univ_three ] <;> ring;
      · erw [ Matrix.cons_val_succ' ] ; norm_num ; ring;
      · erw [ Matrix.cons_val_succ' ] ; norm_num ; ring;
    rw [ Fintype.linearIndependent_iff ] at *;
    refine' h_contra fun g hg => _;
    -- Taking the dot product of both sides of the equation with $u \times v$, we get $c_2 \|u \times v\|^2 = 0$.
    have h_dot : g 2 * dotProduct (crossProduct u v) (crossProduct u v) = 0 := by
      convert congr_arg ( fun x => dotProduct ( crossProduct u v ) x ) hg using 1 ; norm_num [ Fin.sum_univ_three, dotProduct ] ; ring;
      · simp_all +decide [ Fin.sum_univ_three, dotProduct ] ; ring!;
        linear_combination -h_cross_orthogonal.1 * g 0 - h_cross_orthogonal.2 * g 1;
      · norm_num [ dotProduct ];
    simp_all +decide [ Fin.sum_univ_three, dotProduct ];
    cases h_dot <;> simp_all +decide [ Fin.forall_fin_succ ];
    · exact h ( fun i => if i = 0 then g 0 else g 1 ) ( by simpa [ Fin.forall_fin_succ ] using hg );
    · exact False.elim <| h_cross_ne_zero <| by ext i; fin_cases i <;> norm_num <;> nlinarith! only [ ‹_› ] ;

/-
If a rotation in SO(3) fixes two linearly independent vectors, it must be the identity.
-/
theorem so3_eq_one_of_fixes_two_independent (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (u v : EuclideanSpace ℝ (Fin 3))
  (hu : g • u = u) (hv : g • v = v) (h_indep : LinearIndependent ℝ ![u, v]) : g = 1 := by
    -- Since $g$ fixes linearly independent vectors $u$ and $v$, it must also fix their cross product $w$.
    have h_cross : g • crossProduct u v = crossProduct u v := by
      have := crossProduct_map_so3 g u v; aesop;
    -- Since $u$, $v$, and $w$ are linearly independent, they form a basis of $\mathbb{R}^3$.
    have h_basis : LinearIndependent ℝ ![u, v, crossProduct u v] := by
      exact?
    generalize_proofs at *; (
    -- Since $g$ fixes a basis of $\mathbb{R}^3$, it must be the identity matrix.
    have h_id : ∀ (x : Fin 3 → ℝ), g.1.mulVec x = x := by
      have h_id : ∀ (x : Fin 3 → ℝ), x ∈ Submodule.span ℝ (Set.range ![u, v, crossProduct u v]) → g.1.mulVec x = x := by
        intro x hx
        induction' hx using Submodule.span_induction with x hx ih
        generalize_proofs at *; (
        rcases hx with ⟨ i, rfl ⟩ ; fin_cases i <;> tauto;);
        · norm_num +zetaDelta at *;
        · rw [ Matrix.mulVec_add, ‹ ( g : Matrix ( Fin 3 ) ( Fin 3 ) ℝ ).mulVec ih = ih ›, ‹ ( g : Matrix ( Fin 3 ) ( Fin 3 ) ℝ ).mulVec _ = _ › ];
        · rw [ Matrix.mulVec_smul, ‹Matrix.mulVec ( g : Matrix ( Fin 3 ) ( Fin 3 ) ℝ ) _ = _› ]
      generalize_proofs at *; (
      have h_span : Submodule.span ℝ (Set.range ![u, v, crossProduct u v]) = ⊤ := by
        refine' Submodule.eq_top_of_finrank_eq _ ; simp_all +decide [ finrank_span_eq_card ] ;
      generalize_proofs at *; (
      exact fun x => h_id x <| h_span.symm ▸ Submodule.mem_top))
    generalize_proofs at *; (
    exact Subtype.ext <| Matrix.toLin'.injective <| LinearMap.ext fun x => by simpa using h_id x;))

/-
The dimension of the subspace of fixed points of a non-trivial rotation is at most 1.
-/
theorem dim_fixed_points_le_one (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (h : g ≠ 1) :
  Module.finrank ℝ (LinearMap.ker (Matrix.toLin' (g.1 - 1))) ≤ 1 := by
    -- By contradiction, assume the dimension of the subspace of fixed points is greater than 1.
    by_contra h_contra
    have h_indep : ∃ u v : EuclideanSpace ℝ (Fin 3), LinearIndependent ℝ ![u, v] ∧ u ∈ LinearMap.ker (Matrix.toLin' (g.val - 1)) ∧ v ∈ LinearMap.ker (Matrix.toLin' (g.val - 1)) := by
      obtain ⟨s, hs⟩ : ∃ s : Submodule ℝ (EuclideanSpace ℝ (Fin 3)), s = LinearMap.ker (Matrix.toLin' (g.val - 1)) ∧ Module.finrank ℝ s > 1 := by
        exact ⟨ _, rfl, not_le.mp h_contra ⟩;
      obtain ⟨u, hu⟩ : ∃ u : EuclideanSpace ℝ (Fin 3), u ∈ s ∧ u ≠ 0 := by
        exact ( Submodule.ne_bot_iff _ ).mp ( by aesop_cat );
      obtain ⟨v, hv⟩ : ∃ v : EuclideanSpace ℝ (Fin 3), v ∈ s ∧ v ∉ Submodule.span ℝ {u} := by
        by_cases h_span : s = Submodule.span ℝ {u};
        · exact absurd hs.2 ( by rw [ h_span, finrank_span_singleton hu.2 ] ; norm_num );
        · exact SetLike.exists_of_lt ( lt_of_le_of_ne ( Submodule.span_le.mpr ( Set.singleton_subset_iff.mpr hu.1 ) ) ( Ne.symm h_span ) );
      refine' ⟨ u, v, _, _, _ ⟩ <;> simp_all +decide [ linearIndependent_fin2 ];
      exact ⟨ by aesop_cat, fun a ha => hv.2 <| ha ▸ Submodule.mem_span_singleton.mpr ⟨ a⁻¹, by by_cases ha' : a = 0 <;> aesop ⟩ ⟩;
    obtain ⟨ u, v, h_indep, hu, hv ⟩ := h_indep; have := so3_eq_one_of_fixes_two_independent g u v; simp_all +decide [ sub_eq_iff_eq_add ] ;
    exact this hu hv

/-
The set of fixed points of a non-trivial rotation on the sphere is finite.
-/
theorem fixed_points_of_rotation_finite (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (h : g ≠ 1) :
  Set.Finite (MulAction.fixedBy (↥S2) g) := by
    -- The set of fixed points of a non-trivial rotation on the sphere is finite because it is the intersection of the sphere with a subspace of dimension at most 1.
    have h_fixed_points_finite : Set.Finite (S2 ∩ {x : EuclideanSpace ℝ (Fin 3) | g.1.mulVec x = x}) := by
      convert finite_inter_sphere ( LinearMap.ker ( Matrix.toLin' ( g.1 - 1 ) ) ) _ using 1;
      · ext; simp [S2, LinearMap.mem_ker];
        exact?;
      · convert dim_fixed_points_le_one g h using 1
    generalize_proofs at *; (
    convert h_fixed_points_finite.preimage _ using 1;
    all_goals norm_num [ Set.ext_iff, MulAction.fixedBy ];
    rotate_left;
    use fun x => x.val
    all_goals generalize_proofs at *; simp +decide [ Set.InjOn ] ;
    exact fun x hx => ⟨ fun h => ⟨ hx, by simpa [ Subtype.ext_iff ] using h ⟩, fun h => Subtype.ext h.2 ⟩)

/-
The set D of points in S2 fixed by some non-trivial element of the free group is countable.
-/
theorem D_countable : Set.Countable D := by
  convert Set.countable_iUnion fun g => Set.countable_iUnion fun hg => ?_;
  · infer_instance;
  · convert Set.Finite.countable _;
    convert fixed_points_of_rotation_finite ( free_group_to_SO3 g ) _;
    exact fun h => hg <| free_group_to_SO3_injective <| by aesop;
  · exact fun g => by infer_instance;

/-
The image of an equidecomposable set under an injective homomorphism is equidecomposable.
-/
theorem Equidecomposable_image {G H : Type*} [Group G] [Group H] (f : G →* H) (hf : Function.Injective f) (s t : Set G) (h : @Equidecomposable G G _ _ s t) :
  @Equidecomposable H H _ _ (f '' s) (f '' t) := by
    obtain ⟨ n, g, s_parts, t_parts, hs, ht, hs_parts, ht_parts, h ⟩ := h;
    refine' ⟨ n, fun i => f ( g i ), fun i => f '' s_parts i, fun i => f '' t_parts i, _, _, _, _, _ ⟩;
    · simp +decide [ ← hs, Set.ext_iff ];
      exact fun x => ⟨ fun ⟨ i, y, hy, hx ⟩ => ⟨ y, ⟨ i, hy ⟩, hx ⟩, fun ⟨ y, ⟨ i, hy ⟩, hx ⟩ => ⟨ i, y, hy, hx ⟩ ⟩;
    · simp +decide [ ← ht, Set.image_iUnion ];
    · exact fun i j hij => Set.disjoint_image_of_injective hf ( hs_parts i j hij );
    · exact fun i j hij => Set.disjoint_image_of_injective hf ( ht_parts i j hij );
    · simp +decide [ ← h, Set.ext_iff, Set.mem_smul_set ]

/-
The set D of fixed points is invariant under the group action.
-/
theorem D_invariant (g : FreeGroup (Fin 2)) :
  free_group_to_SO3 g • D = D := by
    apply Set.ext
    intro y
    simp [D];
    constructor <;> intro h;
    · obtain ⟨ x, hx, rfl ⟩ := h;
      obtain ⟨ h, hh, hx ⟩ := Set.mem_iUnion₂.mp hx;
      refine' ⟨ g * h * g⁻¹, _, _ ⟩ <;> simp_all +decide [ MulAction.mul_smul, MulAction.fixedBy ];
    · obtain ⟨ i, hi, hi' ⟩ := h; use ( free_group_to_SO3 g⁻¹ ) • y; simp_all +decide [ Set.mem_smul_set, MulAction.mul_smul ] ;
      refine' ⟨ g⁻¹ * i * g, _, _ ⟩ <;> simp_all +decide [ mul_assoc, MulAction.mul_smul ];
      simp_all +decide [ mul_eq_one_iff_eq_inv ]

/-
The action of the free group on S2 \ D is free.
-/
theorem free_action_on_S2_diff_D (g : FreeGroup (Fin 2)) (hg : g ≠ 1) (x : S2) (hx : x ∉ D) :
  free_group_to_SO3 g • x ≠ x := by
    exact fun h => hx <| Set.mem_iUnion₂.mpr ⟨ g, hg, h ⟩

/-
If a paradoxical group acts freely on a set, then the set is paradoxical.
-/
theorem paradoxical_of_free_action {G X : Type*} [Group G] [MulAction G X] (hG : GroupParadoxical G) (h_free : ∀ g : G, g ≠ 1 → ∀ x : X, g • x ≠ x) :
  @Paradoxical G X _ _ (Set.univ : Set X) := by
    obtain ⟨ a, b, hab ⟩ := hG;
    -- Let $M$ be a set of representatives for the cosets of $G$.
    obtain ⟨M, hM⟩ : ∃ M : Set X, ∀ x : X, ∃! m : X, m ∈ M ∧ ∃ g : G, x = g • m := by
      -- By the axiom of choice, we can select one element from each orbit.
      have h_choice : ∃ M : Set X, (∀ x : X, ∃ m ∈ M, ∃ g : G, x = g • m) ∧ (∀ m₁ m₂ : X, m₁ ∈ M → m₂ ∈ M → (∃ g : G, m₁ = g • m₂) → m₁ = m₂) := by
        have h_choice : ∃ M : Set X, (∀ x : X, ∃ m ∈ M, ∃ g : G, x = g • m) ∧ (∀ m₁ m₂ : X, m₁ ∈ M → m₂ ∈ M → (∃ g : G, m₁ = g • m₂) → m₁ = m₂) := by
          have h_orbit_partition : ∃ P : Set (Set X), (∀ x : X, ∃ p ∈ P, x ∈ p) ∧ (∀ p₁ p₂ : Set X, p₁ ∈ P → p₂ ∈ P → p₁ ≠ p₂ → Disjoint p₁ p₂) ∧ (∀ p : Set X, p ∈ P → ∃ x : X, p = MulAction.orbit G x) := by
            refine' ⟨ Set.range fun x : X => MulAction.orbit G x, _, _, _ ⟩ <;> simp +decide [ Set.disjoint_left ];
            · exact fun x => ⟨ x, MulAction.mem_orbit_self x ⟩;
            · rintro p₁ p₂ x rfl y rfl hxy a ha₁ ha₂;
              exact hxy ( by rw [ show MulAction.orbit G x = MulAction.orbit G a by rw [ MulAction.orbit_eq_iff.mpr ha₁ ] ] ; rw [ show MulAction.orbit G y = MulAction.orbit G a by rw [ MulAction.orbit_eq_iff.mpr ha₂ ] ] )
          obtain ⟨ P, hP₁, hP₂, hP₃ ⟩ := h_orbit_partition
          obtain ⟨ M, hM ⟩ : ∃ M : Set X, (∀ p ∈ P, ∃ m ∈ M, m ∈ p) ∧ (∀ m₁ m₂ : X, m₁ ∈ M → m₂ ∈ M → (∃ g : G, m₁ = g • m₂) → m₁ = m₂) := by
            have h_choice : ∀ p ∈ P, ∃ m ∈ p, True := by
              exact fun p hp => by obtain ⟨ x, rfl ⟩ := hP₃ p hp; exact ⟨ x, MulAction.mem_orbit_self x, trivial ⟩ ;
            choose! f hf₁ hf₂ using h_choice;
            refine' ⟨ Set.image ( fun p : P => f p p.2 ) Set.univ, _, _ ⟩ <;> simp +decide [ Set.image ];
            · exact fun p hp => ⟨ f p hp, ⟨ p, hp, rfl ⟩, hf₁ p hp ⟩;
            · intro m₁ m₂ p₁ hp₁ hm₁ p₂ hp₂ hm₂ g hg
              have h_orbit_eq : p₁ = p₂ := by
                contrapose! hP₂;
                refine' ⟨ p₁, p₂, hp₁, hp₂, hP₂, _ ⟩;
                obtain ⟨ x₁, rfl ⟩ := hP₃ p₁ hp₁; obtain ⟨ x₂, rfl ⟩ := hP₃ p₂ hp₂; simp +decide [ Set.disjoint_left ] ;
                use m₁;
                have := hf₁ ( MulAction.orbit G x₁ ) hp₁; have := hf₁ ( MulAction.orbit G x₂ ) hp₂; simp_all +decide [ MulAction.mem_orbit_iff ] ;
                obtain ⟨ x, hx ⟩ := this; use g * x; simp +decide [ hx, MulAction.mul_smul ] ;
              grind;
          use M;
          refine' ⟨ fun x => _, hM.2 ⟩;
          obtain ⟨ p, hp₁, hp₂ ⟩ := hP₁ x;
          obtain ⟨ m, hm₁, hm₂ ⟩ := hM.1 p hp₁;
          obtain ⟨ y, rfl ⟩ := hP₃ p hp₁;
          obtain ⟨ g, rfl ⟩ := hp₂;
          obtain ⟨ h, rfl ⟩ := hm₂;
          exact ⟨ _, hm₁, g * h⁻¹, by simp +decide [ MulAction.mul_smul ] ⟩;
        exact h_choice;
      obtain ⟨ M, hM₁, hM₂ ⟩ := h_choice;
      use M;
      intro x
      obtain ⟨ m, hm₁, hm₂ ⟩ := hM₁ x
      use m;
      simp +zetaDelta at *;
      refine' ⟨ ⟨ hm₁, hm₂ ⟩, fun y hy g hg => _ ⟩;
      obtain ⟨ g', hg' ⟩ := hm₂;
      specialize hM₂ _ _ hy hm₁ ( g⁻¹ * g' ) ; simp_all +decide [ mul_assoc, MulAction.mul_smul ];
    refine' ⟨ _, _, _, _, _ ⟩;
    exact { x | ∃ m ∈ M, ∃ g ∈ a, x = g • m };
    exact { x | ∃ m ∈ M, ∃ g ∈ b, x = g • m };
    · simp_all +decide [ Set.disjoint_left ];
      intro x m hm g hg hx m' hm' g' hg' h_eq
      have h_eq' : m = m' := by
        exact ExistsUnique.unique ( hM x ) ⟨ hm, g, hx ⟩ ⟨ hm', g', by aesop ⟩
      have h_eq'' : g = g' := by
        specialize h_free ( g⁻¹ * g' ) ; simp_all +decide [ mul_assoc, MulAction.mul_smul ];
        contrapose! h_free; simp_all +decide [ inv_smul_eq_iff ] ;
        exact ⟨ by rw [ inv_mul_eq_one ] ; tauto, m', h_eq.symm ⟩
      exact hab.left hg (by
      aesop);
    · exact Set.subset_univ _;
    · refine' ⟨ Set.subset_univ _, _, _ ⟩;
      · obtain ⟨ n, f, s_parts, t_parts, hs, ht, hs_disjoint, ht_disjoint, h ⟩ := hab.2.2.2.1;
        refine' ⟨ n, f, fun i => { x | ∃ m ∈ M, ∃ g ∈ s_parts i, x = g • m }, fun i => { x | ∃ m ∈ M, ∃ g ∈ t_parts i, x = g • m }, _, _, _, _, _ ⟩;
        · simp_all +decide [ Set.ext_iff ];
          intro x
          obtain ⟨ m, hm₁, hm₂ ⟩ := hM x |> ExistsUnique.exists
          obtain ⟨ i, hi ⟩ := hs (Classical.choose hm₂)
          use i, m, hm₁, Classical.choose hm₂, hi;
          exact Classical.choose_spec hm₂;
        · simp +decide [ ← ht, Set.ext_iff ];
          exact fun x => ⟨ fun ⟨ i, m, hm, g, hg, hx ⟩ => ⟨ m, hm, g, ⟨ i, hg ⟩, hx ⟩, fun ⟨ m, hm, g, ⟨ i, hg ⟩, hx ⟩ => ⟨ i, m, hm, g, hg, hx ⟩ ⟩;
        · intro i j hij x hx hx';
          intro y hy; obtain ⟨ m, hm, g, hg, rfl ⟩ := hx hy; obtain ⟨ m', hm', g', hg', hy' ⟩ := hx' hy; simp_all +decide [ Set.disjoint_left ] ;
          -- Since $g • m = g' • m'$ and $m, m' \in M$, we have $m = m'$ by the uniqueness of representatives in $M$.
          have h_eq : m = m' := by
            have := hM ( g • m );
            exact this.unique ⟨ hm, g, rfl ⟩ ⟨ hm', g', hy' ▸ rfl ⟩;
          specialize h_free ( g⁻¹ * g' ) ; simp_all +decide [ mul_smul, eq_inv_mul_iff_mul_eq ] ;
          simp_all +decide [ inv_mul_eq_iff_eq_mul, MulAction.mul_smul ];
          exact h_free ( Ne.symm <| by rintro rfl; exact hs_disjoint i j hij hg hg' ) m' ( by simp +decide [ ← hy', inv_smul_smul ] );
        · intro i j hij; rw [ Set.disjoint_left ] ; intro x hx hx'; simp_all +decide [ Set.ext_iff ] ;
          obtain ⟨ m, hm, g, hg, rfl ⟩ := hx
          obtain ⟨ m', hm', g', hg', hx'' ⟩ := hx'
          have h_eq : m = m' := by
            have := hM ( g • m );
