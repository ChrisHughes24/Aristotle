        · simp +decide [ ← h, Set.ext_iff ];
          simp +decide [ Set.mem_smul_set, eq_comm ];
          intro i x; constructor <;> rintro ⟨ m, hm, g, hg, rfl ⟩ <;> simp_all +decide [ MulAction.mul_smul ] ;
          · rcases hm with ⟨ m', hm', g, hg, rfl ⟩ ; exact ⟨ m', hm', f i * g, ⟨ g, hg, rfl ⟩, by simp +decide [ MulAction.mul_smul ] ⟩ ;
          · rcases hg with ⟨ y, hy, rfl ⟩ ; exact ⟨ _, ⟨ m, hm, y, hy, rfl ⟩, by simp +decide [ MulAction.mul_smul ] ⟩ ;
      · obtain ⟨ n, f, s_parts, t_parts, hs, ht, hs_disjoint, ht_disjoint, h_eq ⟩ := hab.2.2.2.2;
        refine' ⟨ n, fun i => f i, fun i => { x | ∃ m ∈ M, ∃ g ∈ s_parts i, x = g • m }, fun i => { x | ∃ m ∈ M, ∃ g ∈ t_parts i, x = g • m }, _, _, _, _, _ ⟩;
        · ext x;
          obtain ⟨ m, hm₁, hm₂ ⟩ := hM x |> ExistsUnique.exists;
          obtain ⟨ g, rfl ⟩ := hm₂;
          simp +decide [ Set.ext_iff ] at hs ⊢;
          exact Exists.elim ( hs g ) fun i hi => ⟨ i, m, hm₁, g, hi, rfl ⟩;
        · simp +decide [ ← ht, Set.ext_iff ];
          exact fun x => ⟨ fun ⟨ i, m, hm, g, hg, hx ⟩ => ⟨ m, hm, g, ⟨ i, hg ⟩, hx ⟩, fun ⟨ m, hm, g, ⟨ i, hg ⟩, hx ⟩ => ⟨ i, m, hm, g, hg, hx ⟩ ⟩;
        · intro i j hij; rw [ Set.disjoint_left ] ; intro x hx hx'; simp_all +decide [ Set.ext_iff ] ;
          obtain ⟨ m, hm, g, hg, rfl ⟩ := hx
          obtain ⟨ m', hm', g', hg', hx' ⟩ := hx'
          have h_eq : g • m = g' • m' := by
            exact hx';
          have h_eq : m = m' := by
            have := hM ( g • m );
            exact this.unique ⟨ hm, g, rfl ⟩ ⟨ hm', g', h_eq ⟩;
          simp_all +decide [ Set.disjoint_left ];
          specialize h_free ( g⁻¹ * g' ) ; simp_all +decide [ mul_smul, inv_smul_eq_iff ];
          exact h_free ( by rw [ inv_mul_eq_one ] ; rintro rfl; exact hs_disjoint _ _ hij hg hg' ) m' ( by rw [ hx' ] );
        · intro i j hij; rw [ Set.disjoint_left ] ; intro x hx hx'; obtain ⟨ m, hm, g, hg, rfl ⟩ := hx; obtain ⟨ m', hm', g', hg', h ⟩ := hx'; simp_all +decide [ Set.disjoint_left ] ;
          -- Since $m$ and $m'$ are in $M$, and $M$ is a set of representatives for the cosets of $G$, we have $m = m'$.
          have h_eq_m : m = m' := by
            have := hM ( g • m );
            exact this.unique ⟨ hm, g, rfl ⟩ ⟨ hm', g', h ⟩;
          -- Since $g • m = g' • m$ and the action is free, we have $g = g'$.
          have h_eq_g : g = g' := by
            specialize h_free ( g⁻¹ * g' ) ; simp_all +decide [ mul_assoc, MulAction.mul_smul ];
            contrapose! h_free;
            exact ⟨ by rw [ Ne.eq_def, inv_mul_eq_one ] ; tauto, m', by rw [ inv_smul_eq_iff, h ] ⟩;
          exact ht_disjoint i j hij ( h_eq_g ▸ hg ) ( h_eq_g ▸ hg' );
        · simp +decide [ ← h_eq, Set.ext_iff ];
          simp +decide [ Set.mem_smul_set, eq_comm ];
          intro i x; constructor <;> rintro ⟨ m, hm, g, hg, rfl ⟩ <;> simp_all +decide [ mul_assoc, MulAction.mul_smul ] ;
          · rcases hm with ⟨ m, hm, g, hg, rfl ⟩ ; exact ⟨ m, hm, f i * g, ⟨ g, hg, rfl ⟩, by simp +decide [ MulAction.mul_smul ] ⟩ ;
          · rcases hg with ⟨ y, hy, rfl ⟩ ; exact ⟨ _, ⟨ m, hm, y, hy, rfl ⟩, by simp +decide [ MulAction.mul_smul ] ⟩ ;

/-
Rotation by an angle theta about the z-axis is in SO(3).
-/
noncomputable def rot_z_angle (θ : ℝ) : Matrix (Fin 3) (Fin 3) ℝ :=
  !![Real.cos θ, -Real.sin θ, 0;
     Real.sin θ, Real.cos θ, 0;
     0, 0, 1]

theorem rot_z_angle_mem_SO3 (θ : ℝ) : rot_z_angle θ ∈ Matrix.specialOrthogonalGroup (Fin 3) ℝ := by
  constructor;
  · simp +decide [ Matrix.mem_unitaryGroup_iff ];
    unfold rot_z_angle;
    ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.mul_apply, Fin.sum_univ_succ ] <;> ring_nf <;> norm_num [ Real.sin_sq, Real.cos_sq ];
  · unfold rot_z_angle; norm_num [ Matrix.det_fin_three ] ; ring;
    simp +zetaDelta at *

/-
The z-rotation matrices form a one-parameter subgroup isomorphic to the additive group of reals (modulo 2pi). Specifically, the n-th power of a rotation by theta is a rotation by n*theta.
-/
noncomputable def rot_z_group (θ : ℝ) : Matrix.specialOrthogonalGroup (Fin 3) ℝ := ⟨rot_z_angle θ, rot_z_angle_mem_SO3 θ⟩

theorem rot_z_group_pow (θ : ℝ) (n : ℤ) : (rot_z_group θ) ^ n = rot_z_group (n * θ) := by
  induction n using Int.induction_on <;> simp_all +decide [ mul_add, zpow_add, zpow_one ];
  · ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ rot_z_group ];
    all_goals unfold rot_z_angle; norm_num;
  · simp_all +decide [ add_mul, rot_z_group, Matrix.mul_fin_three ];
    unfold rot_z_angle; ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Real.cos_add, Real.sin_add ] <;> ring;
  · simp_all +decide [ sub_eq_add_neg, zpow_add, zpow_neg, mul_add, add_mul, zpow_one ];
    have h_inv : (rot_z_group θ)⁻¹ = rot_z_group (-θ) := by
      unfold rot_z_group;
      simp +decide [ rot_z_angle, Matrix.inv_def ];
      erw [ Subtype.mk_eq_mk ] ; norm_num [ Matrix.inv_def ] ; ring;
      ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.adjugate_apply, Matrix.det_fin_three ];
    simp_all +decide [ mul_assoc, mul_comm, mul_left_comm, sub_eq_add_neg, rot_z_group ];
    unfold rot_z_angle; norm_num [ ← List.ofFn_inj ] ; ring;
    norm_num [ Real.sin_sub, Real.cos_sub ] ; ring ; norm_num

/-
The set of north and south poles.
-/
def poles : Set S2 := {⟨![0, 0, 1], by
  -- The vector [0, 0, 1] has a norm of 1, so it lies on the unit sphere.
  simp [S2];
  -- The norm of the vector [0, 0, 1] is sqrt(0^2 + 0^2 + 1^2) = sqrt(1) = 1.
  simp [EuclideanSpace.norm_eq, Fin.sum_univ_three]⟩, ⟨![0, 0, -1], by
  -- The norm of the vector [0, 0, -1] is sqrt(0^2 + 0^2 + (-1)^2) = sqrt(1) = 1, so it lies on the unit sphere.
  simp [S2, EuclideanSpace.norm_eq];
  -- The sum of the squares of the components of the vector [0, 0, -1] is 0^2 + 0^2 + (-1)^2 = 1.
  simp [Fin.sum_univ_succ, Fin.sum_univ_zero]⟩}

/-
The set of north and south poles.
-/
def z_axis_poles : Set S2 := {⟨![0, 0, 1], by
  -- The norm of the vector [0, 0, 1] is 1, so it lies on the sphere S2.
  simp [S2, EuclideanSpace.norm_eq];
  -- The sum of the squares of the components of the vector [0, 0, 1] is 0^2 + 0^2 + 1^2 = 1.
  simp [Fin.sum_univ_three]⟩, ⟨![0, 0, -1], by
  unfold S2;
  norm_num [ EuclideanSpace.norm_eq, Fin.sum_univ_succ ]⟩}

/-
Defining rotation_about_z as the group homomorphism from reals to SO(3).
-/
noncomputable def rotation_about_z (θ : ℝ) : Matrix.specialOrthogonalGroup (Fin 3) ℝ := rot_z_group θ

theorem rotation_about_z_pow (θ : ℝ) (n : ℤ) : (rotation_about_z θ) ^ n = rotation_about_z (n * θ) := rot_z_group_pow θ n

/-
Rotation about the z-axis preserves the z-coordinate.
-/
theorem rotation_about_z_preserves_z (θ : ℝ) (x : S2) : (rotation_about_z θ • x).1 2 = x.1 2 := by
  simp +decide [ rotation_about_z ];
  convert congr_arg ( fun y : EuclideanSpace ℝ ( Fin 3 ) => y 2 ) ( show ( rot_z_angle θ |> fun m => m.mulVec x.1 ) = ( rot_z_angle θ |> fun m => m.mulVec x.1 ) from rfl ) using 1;
  unfold rot_z_angle; norm_num [ Matrix.mulVec ] ;
  simp +decide [ dotProduct, Fin.sum_univ_three ]

/-
The set of angles theta such that a rotation by n*theta maps x to y is countable, provided x is not a pole.
-/
theorem countable_bad_angles_fixed (n : ℤ) (x y : S2) (hn : n ≠ 0) (hx : x ∉ z_axis_poles) :
  Set.Countable {θ : ℝ | (rotation_about_z (n * θ)) • x = y} := by
    -- Let's express the coordinates of x and y as complex numbers and use the fact that the rotation action on the first two coordinates is multiplication by a complex number.
    set z_x : ℂ := x.val 0 + x.val 1 * Complex.I
    set z_y : ℂ := y.val 0 + y.val 1 * Complex.I;
    -- Since $x \notin \text{poles}$, we have $z_x \neq 0$.
    have hz_x_ne_zero : z_x ≠ 0 := by
      simp +zetaDelta at *;
      norm_num [ Complex.ext_iff ];
      intro hx0 hx1; contrapose! hx; simp_all +decide [ z_axis_poles ] ;
      rcases x with ⟨ x, hx ⟩ ; simp_all +decide [ S2 ];
      -- Since $x$ is on the unit sphere and $x_0 = 0$ and $x_1 = 0$, we have $x_2^2 = 1$, so $x_2 = \pm 1$.
      have hx2 : x 2 = 1 ∨ x 2 = -1 := by
        exact eq_or_eq_neg_of_sq_eq_sq _ _ <| by have := hx; rw [ S2 ] at this; norm_num [ EuclideanSpace.norm_eq, Fin.sum_univ_three ] at this; nlinarith!;
      exact Or.imp ( fun h => by ext i; fin_cases i <;> tauto ) ( fun h => by ext i; fin_cases i <;> tauto ) hx2;
    -- The equation $e^{i n \theta} z_x = z_y$ implies $n \theta = \arg(z_y / z_x) + 2\pi k$ for some integer $k$.
    have h_eq : ∀ θ : ℝ, rotation_about_z (n * θ) • x = y → ∃ k : ℤ, n * θ = Complex.arg (z_y / z_x) + 2 * Real.pi * k := by
      intro θ hθ
      have h_eq : Complex.exp (Complex.I * n * θ) * z_x = z_y := by
        have h_eq : (rotation_about_z (n * θ) • x).val 0 + (rotation_about_z (n * θ) • x).val 1 * Complex.I = Complex.exp (Complex.I * n * θ) * z_x := by
          erw [ Subtype.coe_mk ] ; norm_num [ Complex.ext_iff, Complex.exp_re, Complex.exp_im, Matrix.mulVec ] ; ring;
          erw [ show ( rot_z_angle ( n * θ ) • x : EuclideanSpace ℝ ( Fin 3 ) ) = Matrix.mulVec ( rot_z_angle ( n * θ ) ) x from rfl ] ; norm_num [ Matrix.mulVec ] ; ring;
          simp +decide [ dotProduct, Fin.sum_univ_three ] ; ring!;
          simp +decide [ rot_z_angle ] ; ring!;
        aesop;
      have h_eq : Complex.exp (Complex.I * n * θ) = z_y / z_x := by
        rw [ ← h_eq, mul_div_cancel_right₀ _ hz_x_ne_zero ];
      have h_eq : ∃ k : ℤ, Complex.I * n * θ = Complex.log (z_y / z_x) + 2 * Real.pi * Complex.I * k := by
        have h_eq : Complex.exp (Complex.I * n * θ) = Complex.exp (Complex.log (z_y / z_x)) := by
          rw [ h_eq, Complex.exp_log ( div_ne_zero ( by aesop ) hz_x_ne_zero ) ];
        rw [ Complex.exp_eq_exp_iff_exists_int ] at h_eq; obtain ⟨ k, hk ⟩ := h_eq; exact ⟨ k, by linear_combination hk ⟩ ;
      simp_all +decide [ Complex.ext_iff, Complex.log_re, Complex.log_im ];
    refine' Set.Countable.mono _ ( Set.countable_range ( fun k : ℤ => ( Complex.arg ( z_y / z_x ) + 2 * Real.pi * k ) / n ) );
    exact fun θ hθ => by obtain ⟨ k, hk ⟩ := h_eq θ hθ; exact ⟨ k, by rw [ div_eq_iff ( by positivity ) ] ; linarith ⟩ ;

/-
There exists a rotation angle such that no non-trivial power maps any element of a countable set S (disjoint from poles) to another element of S.
-/
theorem exists_good_rotation_angle (S : Set S2) (hS : Set.Countable S) (h_disjoint : Disjoint S z_axis_poles) :
  ∃ θ : ℝ, ∀ (n : ℤ) (x y : S), n ≠ 0 → (rotation_about_z (n * θ)) • x.val ≠ y.val := by
    -- Let $B = \bigcup_{n \in \mathbb{Z} \setminus \{0\}} \bigcup_{x \in S} \bigcup_{y \in S} \{ \theta \in \mathbb{R} \mid R_{n\theta} x = y \}$.
    set B : Set ℝ := ⋃ (n : ℤ) (hn : n ≠ 0) (x : S) (y : S), {θ : ℝ | (rotation_about_z (n * θ)) • x.val = y.val};
    -- Since $B$ is countable, there exists some $\theta \in \mathbb{R} \setminus B$.
    obtain ⟨θ, hθ⟩ : ∃ θ : ℝ, θ ∉ B := by
      have hB_countable : Set.Countable B := by
        have hB_countable : ∀ n : ℤ, n ≠ 0 → ∀ x y : S, Set.Countable {θ : ℝ | (rotation_about_z (n * θ)) • x.val = y.val} := by
          -- Since $x$ is not a pole, we can apply the lemma countable_bad_angles_fixed.
          intros n hn x y
          have hx_not_pole : x.val ∉ z_axis_poles := by
            exact fun hx => h_disjoint.le_bot ⟨ x.2, hx ⟩
          exact countable_bad_angles_fixed n x.val y.val hn hx_not_pole;
        convert Set.countable_iUnion fun n : ℤ => Set.countable_iUnion fun hn : n ≠ 0 => Set.countable_iUnion fun x : S => Set.countable_iUnion fun y : S => hB_countable n hn x y using 1;
        · exact?;
        · exact?;
      contrapose! hB_countable;
      exact fun h => absurd ( h.measure_zero <| MeasureTheory.MeasureSpace.volume ) ( by simp +decide [ show B = Set.univ from Set.eq_univ_of_forall hB_countable ] );
    exact ⟨ θ, fun n x y hn hxy => hθ <| Set.mem_iUnion₂.mpr ⟨ n, hn, Set.mem_iUnion₂.mpr ⟨ x, y, hxy ⟩ ⟩ ⟩

/-
There exists a point on the sphere that is not in D.
-/
theorem exists_pole_not_in_D : ∃ p : S2, p ∉ D := by
  -- S2 is uncountable.
  have hS2_uncountable : ¬Set.Countable (Set.univ : Set S2) := by
    intro h;
    have := h.image ( fun x => x.val 0 );
    refine' absurd ( this.mono _ ) ( _ );
    exact Set.Icc ( -1 ) 1;
    · intro x hx; use ⟨ fun i => if i = 0 then x else if i = 1 then 0 else Real.sqrt ( 1 - x ^ 2 ), by
        simp +decide [ S2, EuclideanSpace.norm_eq ];
        simp +decide [ Fin.sum_univ_three, Real.sq_sqrt ( by nlinarith [ hx.1, hx.2 ] : 0 ≤ 1 - x ^ 2 ) ] ⟩ ; aesop;
    · exact fun h => absurd ( h.measure_zero <| MeasureTheory.MeasureSpace.volume ) ( by norm_num );
  exact not_forall.mp fun h => hS2_uncountable <| Set.Countable.mono ( by aesop_cat ) <| D_countable.mono fun x hx => by aesop_cat;

/-
Defining negation on the sphere S2.
-/
instance : Neg S2 where
  neg x := ⟨-x.1, by simp [S2, Metric.sphere, x.2]⟩

/-
Defining negation on the sphere S2.
-/
instance : Neg S2 where
  neg x := ⟨-x.1, by
    unfold S2; aesop;⟩

/-
The set D is symmetric with respect to the origin.
-/
theorem D_neg_mem (x : S2) : x ∈ D → -x ∈ D := by
  intro hx
  obtain ⟨g, hg, hx_fixed⟩ : ∃ g : FreeGroup (Fin 2), g ≠ 1 ∧ (free_group_to_SO3 g) • x = x := by
    unfold D at hx; aesop;
  have h_neg_fixed : (free_group_to_SO3 g) • -x = -x := by
    have h_neg_fixed : ∀ (M : Matrix (Fin 3) (Fin 3) ℝ) (x : EuclideanSpace ℝ (Fin 3)), (M • -x) = - (M • x) := by
      intros M x; ext i; simp [Matrix.mulVec];
    convert congr_arg Neg.neg hx_fixed using 1;
    exact Subtype.ext <| h_neg_fixed _ _;
  exact Set.mem_iUnion₂.mpr ⟨ g, hg, h_neg_fixed ⟩

#check D_neg_mem

#synth Neg S2
#check fun (x : S2) => -x

/-
Defining the subtype S2 \ D.
-/
def S2_diff_D : Type := {x : S2 // x ∉ D}

/-
Defining the action of the free group on S2 \ D.
-/
instance : MulAction (FreeGroup (Fin 2)) S2_diff_D where
  smul g x := ⟨free_group_to_SO3 g • x.1, by
    -- Since D is invariant under the group action, applying g to x should still be in D.
    have h_inv : ∀ g : FreeGroup (Fin 2), ∀ x : S2, x ∈ D → free_group_to_SO3 g • x ∈ D := by
      intros g x hx;
      exact D_invariant g ▸ Set.mem_image_of_mem _ hx;
    contrapose! h_inv;
    refine' ⟨ g⁻¹, free_group_to_SO3 g • x.val, _, _ ⟩ <;> simp_all +decide [ MulAction.mul_smul ];
    exact x.2⟩
  one_smul := by
    -- Since the identity element in the group is the identity matrix, multiplying any element by the identity matrix gives the element itself.
    have h_id : ∀ (x : S2), (1 : Matrix.specialOrthogonalGroup (Fin 3) ℝ) • x = x := by
      exact?;
    exact fun x => Subtype.ext <| h_id x.1
  mul_smul := by
    intro x y b
    generalize_proofs at *;
    -- By definition of the action, we have:
    have h_assoc : ∀ (g h : FreeGroup (Fin 2)) (x : S2), (free_group_to_SO3 (g * h)) • x = (free_group_to_SO3 g) • ((free_group_to_SO3 h) • x) := by
      simp +decide [ MulAction.mul_smul ];
    exact Subtype.ext <| h_assoc x y b.1

/-
S2 \ D is paradoxical.
-/
theorem S2_diff_D_paradoxical : @Paradoxical (FreeGroup (Fin 2)) S2_diff_D _ _ Set.univ := by
  apply paradoxical_of_free_action FreeGroup_paradoxical
  intro g hg x h_eq
  have h_eq' : free_group_to_SO3 g • x.1 = x.1 := by
    apply Subtype.ext_iff.mp h_eq
  exact free_action_on_S2_diff_D g hg x.1 x.2 h_eq'

/-
S2 \ D is paradoxical under the action of SO(3).
-/
def S2_minus_D : Set S2 := {x | x ∉ D}

theorem S2_minus_D_paradoxical_SO3 : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ S2_minus_D := by
  have hSO3 : @Paradoxical (FreeGroup (Fin 2)) S2_diff_D _ _ Set.univ := by
    -- Apply the theorem that states S2 \ D is paradoxical.
    apply S2_diff_D_paradoxical
  generalize_proofs at *;
  obtain ⟨ a, b, hab, ha, hb, ha', hb' ⟩ := hSO3
  generalize_proofs at *;
  refine' ⟨ a.image Subtype.val, b.image Subtype.val, _, _, _, _, _ ⟩;
  · rw [ Set.disjoint_left ] at * ; aesop;
  · exact Set.image_subset_iff.mpr fun x hx => x.2;
  · exact Set.image_subset_iff.mpr fun x hx => x.2;
  · obtain ⟨ n, f, s_parts, t_parts, hs, ht, hs', ht', h ⟩ := ha';
    use n, fun i => free_group_to_SO3 ( f i ), fun i => Subtype.val '' s_parts i, fun i => Subtype.val '' t_parts i;
    field_simp;
    refine' ⟨ _, _, _, _, _ ⟩;
    · simp_all +decide [ Set.ext_iff ];
      exact fun x hx => ⟨ fun ⟨ i, hi, hi' ⟩ => hi, fun hi => by obtain ⟨ i, hi' ⟩ := hs ⟨ ⟨ x, hx ⟩, hi ⟩ ; exact ⟨ i, hi, hi' ⟩ ⟩;
    · rw [ ← ht, Set.image_iUnion ];
    · exact fun i j hij => Set.disjoint_image_of_injective Subtype.coe_injective ( hs' i j hij );
    · intro i j hij; specialize ht' i j hij; rw [ Set.disjoint_left ] at *; aesop;
    · intro i; specialize h i; rw [ ← h ] ; ext; simp +decide [ Set.mem_smul_set ] ;
      constructor;
      · rintro ⟨ a, ha, ⟨ ha', ha'' ⟩, rfl ⟩ ; use by
          have := D_invariant ( f i );
          rw [ Set.ext_iff ] at this; specialize this ( free_group_to_SO3 ( f i ) • ⟨ a, ha ⟩ ) ; aesop;
        generalize_proofs at *;
        exact ⟨ a, ha, ha', ha'', rfl ⟩;
      · rintro ⟨ hx, a, b, c, d, e, f ⟩ ; use a, b ; aesop;
  · obtain ⟨ n, f, s_parts, t_parts, hs, ht, hs', ht', h ⟩ := hb';
    use n, fun i => free_group_to_SO3 ( f i ), fun i => Subtype.val '' s_parts i, fun i => Subtype.val '' t_parts i;
    field_simp;
    refine' ⟨ _, _, _, _, _ ⟩;
    · simp_all +decide [ Set.ext_iff ];
      exact fun x hx => ⟨ fun ⟨ i, hi, hi' ⟩ => hi, fun hi => by obtain ⟨ i, hi' ⟩ := hs ⟨ ⟨ x, hx ⟩, hi ⟩ ; exact ⟨ i, hi, hi' ⟩ ⟩;
    · rw [ ← ht, Set.image_iUnion ];
    · exact fun i j hij => Set.disjoint_image_of_injective Subtype.val_injective ( hs' i j hij );
    · intro i j hij; specialize ht' i j hij; rw [ Set.disjoint_left ] at *; aesop;
    · intro i; specialize h i; rw [ ← h ] ; ext; simp +decide [ Set.mem_smul_set ] ;
      constructor <;> intro h;
      · obtain ⟨ a, ha, ⟨ ha', ha'' ⟩, rfl ⟩ := h; use by
          have h_not_in_D : ∀ g : FreeGroup (Fin 2), ∀ x : S2, x ∉ D → free_group_to_SO3 g • x ∉ D := by
            intro g x hx; contrapose! hx; simp_all +decide [ D ] ;
            obtain ⟨ i, hi, hi' ⟩ := hx; use g⁻¹ * i * g; simp_all +decide [ mul_assoc, MulAction.mul_smul ] ;
            simp_all +decide [ mul_eq_one_iff_eq_inv ];
          exact h_not_in_D _ _ ha'; ; use a, ha, ha'; aesop;
      · rcases h with ⟨ hx, a, b, c, d, e, f ⟩ ; use a, b; aesop;

#synth MulAction (FreeGroup (Fin 2)) S2_diff_D

/-
The image of a paradoxical set under an equivariant embedding is paradoxical.
-/
theorem paradoxical_embedding_image {G H X Y : Type*} [Group G] [Group H] [MulAction G X] [MulAction H Y] (f : G →* H) (i : X → Y) (h_eq : ∀ g x, f g • i x = i (g • x)) (s : Set X) (h : @Paradoxical G X _ _ s) (hi : Function.Injective i) : @Paradoxical H Y _ _ (i '' s) := by
  obtain ⟨ a, b, hab₁, hab₂, hab₃, hab₄ ⟩ := h;
  refine' ⟨ i '' a, i '' b, _, _, _, _, _ ⟩ <;> simp_all +decide [ Set.disjoint_left, Set.subset_def ];
  · exact fun x hx y hy => hi.ne ( by rintro rfl; exact hab₁ hx hy );
  · exact fun x hx => ⟨ x, hab₂ x hx, rfl ⟩;
  · exact fun x hx => ⟨ x, hab₃ x hx, rfl ⟩;
  · rcases hab₄.1 with ⟨ n, g, s_parts, t_parts, hs, ht, hs_parts, ht_parts, h ⟩ ; use n, fun k => f ( g k ), fun k => i '' s_parts k, fun k => i '' t_parts k ; simp_all +decide [ Set.ext_iff ] ;
    refine' ⟨ _, _, _ ⟩ <;> simp_all +decide [ Set.mem_smul_set, hi.eq_iff ];
    · grind +ring;
    · exact fun x => ⟨ fun ⟨ i, y, hy, hx ⟩ => ⟨ y, ht y |>.1 ⟨ i, hy ⟩, hx ⟩, fun ⟨ y, hy, hx ⟩ => by obtain ⟨ i, hi ⟩ := ht y |>.2 hy; exact ⟨ i, y, hi, hx ⟩ ⟩;
    · grind;
  · rcases hab₄.2 with ⟨ n, g, s_parts, t_parts, hs, ht, hs_parts, ht_parts, h ⟩ ; use n, fun k => f ( g k ), fun k => i '' s_parts k, fun k => i '' t_parts k ; simp_all +decide [ Set.image_image ] ;
    refine' ⟨ _, _, _ ⟩;
    · simp +decide [ ← hs, Set.image_iUnion ];
    · simp +decide [ ← ht, Set.image_iUnion ];
    · intro i; ext y; simp +decide [ ← h i, h_eq ] ;
      simp +decide [ Set.mem_smul_set, h_eq ]

/-
S2 \ D is paradoxical under the action of SO(3).
-/
def S2_without_D : Set S2 := {x | x ∉ D}

theorem S2_without_D_paradoxical_SO3 : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ S2_without_D := by
  let i : S2_diff_D → S2 := Subtype.val
  have hi : Function.Injective i := Subtype.val_injective
  have h_eq : ∀ (g : FreeGroup (Fin 2)) (x : S2_diff_D), free_group_to_SO3 g • i x = i (g • x) := by
    intro g x
    rfl
  have h_image : i '' Set.univ = S2_without_D := by
    ext x
    simp [i, S2_without_D, S2_diff_D]
  rw [← h_image]
  apply paradoxical_embedding_image free_group_to_SO3 i h_eq Set.univ S2_diff_D_paradoxical hi

/-
Defining north and south poles.
-/
def north_pole : S2 := ⟨![0, 0, 1], by simp [S2, EuclideanSpace.norm_eq, Fin.sum_univ_three]⟩
def south_pole : S2 := ⟨![0, 0, -1], by simp [S2, EuclideanSpace.norm_eq, Fin.sum_univ_three]⟩

/-
For any point on the sphere, there exists a rotation mapping it to the north pole.
-/
theorem exists_rotation_map_to_north (p : S2) : ∃ g : Matrix.specialOrthogonalGroup (Fin 3) ℝ, g • p = north_pole := by
  obtain ⟨g, hg⟩ : ∃ g : Matrix (Fin 3) (Fin 3) ℝ, g ∈ Matrix.specialOrthogonalGroup (Fin 3) ℝ ∧ g.mulVec p.1 = north_pole.1 := by
    -- By definition of $S2$, we know that $p.val$ is a unit vector in $\mathbb{R}^3$.
    set u := p.val
    have hu_unit : ‖u‖ = 1 := by
      exact?;
    -- Since $u$ is a unit vector, there exists a rotation matrix $R$ such that $R u = e_3$, where $e_3$ is the unit vector in the direction of the north pole.
    obtain ⟨R, hR⟩ : ∃ R : Matrix (Fin 3) (Fin 3) ℝ, R ∈ Matrix.specialOrthogonalGroup (Fin 3) ℝ ∧ R.mulVec u = ![0, 0, 1] := by
      -- Since $u$ is a unit vector, we can construct a rotation matrix $R$ such that $R u = e_3$.
      obtain ⟨θ, ψ, hθ⟩ : ∃ θ ψ : ℝ, u = ![Real.sin ψ * Real.cos θ, Real.sin ψ * Real.sin θ, Real.cos ψ] := by
        norm_num [ EuclideanSpace.norm_eq, Fin.sum_univ_three ] at hu_unit ⊢;
        use Complex.arg (u 0 + u 1 * Complex.I), Real.arccos (u 2);
        rw [ Real.sin_arccos, Real.cos_arccos ];
        · by_cases h : u 0 + u 1 * Complex.I = 0 <;> simp_all +decide [ Complex.cos_arg, Complex.sin_arg ];
          · simp_all +decide [ Complex.ext_iff ];
            ext i; fin_cases i <;> aesop;
          · norm_num [ Complex.normSq, Complex.norm_def ] at *;
            rw [ show u 0 * u 0 + u 1 * u 1 = 1 - u 2 ^ 2 by linarith ] ; ext i ; fin_cases i <;> norm_num ; ring;
            · by_cases h' : Real.sqrt ( 1 - u 2 ^ 2 ) = 0 <;> simp_all +decide [ mul_comm, mul_assoc, mul_left_comm ];
              rw [ Real.sqrt_eq_zero' ] at h' ; nlinarith;
            · rw [ mul_div_cancel₀ _ ( ne_of_gt ( Real.sqrt_pos.mpr ( by nlinarith [ show u 0 ^ 2 + u 1 ^ 2 > 0 from not_le.mp fun h' => h <| by norm_num [ Complex.ext_iff ] ; constructor <;> nlinarith ] ) ) ) ];
              rfl;
            · rfl;
        · nlinarith;
        · nlinarith;
      -- Construct the rotation matrix $R$ as the product of a rotation around the $z$-axis by $-\theta$ and a rotation around the $y$-axis by $-\psi$.
      use !![Real.cos ψ * Real.cos θ, Real.cos ψ * Real.sin θ, -Real.sin ψ; -Real.sin θ, Real.cos θ, 0; Real.sin ψ * Real.cos θ, Real.sin ψ * Real.sin θ, Real.cos ψ];
      constructor;
      · constructor;
        · simp +decide [ Matrix.mem_unitaryGroup_iff ];
          ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ Matrix.vecMul, Matrix.vecHead, Matrix.vecTail ] <;> ring;
          all_goals repeat erw [ Matrix.cons_val_succ' ] ; norm_num [ Real.sin_sq, Real.cos_sq ] ; ring;
          · rw [ Real.sin_sq, Real.cos_sq ] ; ring;
          · aesop;
          · norm_num;
          · aesop;
          · rw [ Real.cos_sq ] ; ring;
        · norm_num [ Matrix.det_fin_three ] ; ring;
          simp +zetaDelta at *;
          nlinarith [ Real.sin_sq_add_cos_sq θ, Real.sin_sq_add_cos_sq ψ ];
      · ext i; fin_cases i <;> norm_num [ hθ, Matrix.mulVec ] <;> ring;
        · rw [ Real.sin_sq, Real.cos_sq ] ; ring;
        · rw [ Real.sin_sq, Real.sin_sq ] ; ring;
    exact ⟨ R, hR.1, hR.2 ⟩;
  exact ⟨ ⟨ g, hg.1 ⟩, Subtype.ext hg.2 ⟩

/-
There exists a rotation that moves D away from the poles.
-/
theorem exists_rotation_disjoint_poles : ∃ g : Matrix.specialOrthogonalGroup (Fin 3) ℝ, Disjoint (g • D) z_axis_poles := by
  obtain ⟨ p, hp ⟩ := exists_pole_not_in_D;
  obtain ⟨ g, hg ⟩ := exists_rotation_map_to_north p;
  -- Since $g$ maps $p$ to the north pole and $p \notin D$, it follows that $g • D$ does not contain the north pole.
  have h_not_north : north_pole ∉ g • D := by
    simp +decide [ ← hg, Set.mem_smul_set ];
    assumption;
  -- Since $g$ maps $p$ to the north pole and $p \notin D$, it follows that $g • D$ does not contain the south pole.
  have h_not_south : south_pole ∉ g • D := by
    intro h;
    -- Since $g$ maps $p$ to the north pole and $p \notin D$, it follows that $g • D$ does not contain the south pole. Use this fact.
    have h_not_south : -south_pole ∈ g • D := by
      have h_not_south : ∀ x : S2, x ∈ g • D → -x ∈ g • D := by
        intros x hx
        obtain ⟨ y, hy, rfl ⟩ := hx
        have h_neg : -y ∈ D := by
          exact?
        exact ⟨ -y, h_neg, by
          ext; simp [Matrix.mulVec];
          exact congr_fun ( show ( g • -y : EuclideanSpace ℝ ( Fin 3 ) ) = - ( g • y ) from by ext; simp +decide [ Matrix.mulVec ] ) _ ⟩;
      exact h_not_south _ h;
    convert h_not_north _;
    convert h_not_south using 1;
    ext i ; fin_cases i <;> norm_num [ north_pole, south_pole ];
    · exact Eq.symm ( by erw [ Subtype.coe_mk ] ; norm_num );
    · exact?;
    · exact Eq.symm ( by erw [ Subtype.coe_mk ] ; norm_num );
  exact ⟨ g, Set.disjoint_left.mpr fun x hx hx' => by rcases hx' with ( rfl | rfl ) <;> tauto ⟩

/-
Membership in D is invariant under negation.
-/
theorem neg_mem_D_iff (x : S2) : -x ∈ D ↔ x ∈ D := by
  constructor <;> intro h <;> contrapose! h;
  · intro hx;
    convert D_neg_mem _ hx;
    simp +decide [ S2 ];
    exact h;
  · exact fun hx => h <| D_neg_mem _ hx

/-
The set of poles consists of the north and south poles.
-/
theorem z_axis_poles_eq : z_axis_poles = {north_pole, south_pole} := by
  exact?

/-
The set E = union of rho^n D' for n in Nat.
-/
def absorbing_set (D' : Set S2) (ρ : Matrix.specialOrthogonalGroup (Fin 3) ℝ) : Set S2 := ⋃ (n : ℕ), (ρ ^ n) • D'

/-
S2 \ D is paradoxical under the action of SO(3).
-/
theorem S2_minus_D_paradoxical : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ S2_minus_D := by
  let i : S2_diff_D → S2 := Subtype.val
  have hi : Function.Injective i := Subtype.val_injective
  have h_eq : ∀ (g : FreeGroup (Fin 2)) (x : S2_diff_D), free_group_to_SO3 g • i x = i (g • x) := by
    intro g x
    rfl
  have h_image : i '' Set.univ = S2_minus_D := by
    ext x
    simp [i, S2_minus_D, S2_diff_D]
  rw [← h_image]
  apply paradoxical_embedding_image free_group_to_SO3 i h_eq Set.univ S2_diff_D_paradoxical hi

/-
The absorbing set E satisfies E = D' U rho E.
-/
theorem absorbing_set_decomp (D' : Set S2) (ρ : Matrix.specialOrthogonalGroup (Fin 3) ℝ) :
  absorbing_set D' ρ = D' ∪ ρ • absorbing_set D' ρ := by
    apply Set.ext
    intro x
    simp [absorbing_set];
    constructor <;> intro h;
    · obtain ⟨ n, hn ⟩ := h;
      rcases n <;> simp_all +decide [ pow_succ', MulAction.mul_smul, Set.mem_smul_set ];
      grind;
    · rcases h with ( h | ⟨ y, hy, rfl ⟩ );
      · exact ⟨ 0, by simpa using h ⟩;
      · rcases Set.mem_iUnion.mp hy with ⟨ n, hn ⟩ ; use n + 1 ; simp_all +decide [ pow_succ', Set.mem_smul_set ] ;
        rcases hn with ⟨ a, ha, ha', rfl ⟩ ; exact ⟨ a, ha, ha', by simp +decide [ MulAction.mul_smul ] ⟩ ;

/-
The absorbing set parts are disjoint if the rotation is good.
-/
theorem absorbing_set_disjoint (D' : Set S2) (ρ : Matrix.specialOrthogonalGroup (Fin 3) ℝ)
  (h_good : ∀ (n : ℤ) (x y : S2), x ∈ D' → y ∈ D' → n ≠ 0 → (ρ ^ n) • x ≠ y) :
  Disjoint D' (ρ • absorbing_set D' ρ) := by
    simp_all +decide [ Set.disjoint_left ];
    contrapose! h_good;
    obtain ⟨ a, ha₁, ha₂, ha₃ ⟩ := h_good;
    obtain ⟨ b, hb₁, hb₂ ⟩ := ha₃;
    obtain ⟨ n, hn ⟩ := Set.mem_iUnion.mp hb₁;
    obtain ⟨ c, hc₁, hc₂ ⟩ := Set.mem_smul_set.mp hn;
    refine' ⟨ n + 1, c, c.2, a, ha₁, hc₁, ha₂, _, _ ⟩ <;> simp_all +decide [ pow_succ', MulAction.mul_smul ];
    · linarith;
    · convert hb₂ using 1;
      convert congr_arg ( fun x => ρ • x ) hc₂ using 1 ; norm_cast ; simp +decide [ pow_succ', MulAction.mul_smul ]

/-
There exists a rotation that moves D away from the poles.
-/
theorem exists_rotation_disjoint_poles' : ∃ g : Matrix.specialOrthogonalGroup (Fin 3) ℝ, Disjoint (g • D) z_axis_poles := by
  -- Apply the theorem that states there exists a rotation ρ such that ρ • D is disjoint from the poles.
  apply exists_rotation_disjoint_poles

/-
Every set is equidecomposable to itself.
-/
theorem Equidecomposable.refl {G X : Type*} [Group G] [MulAction G X] (s : Set X) :
  @Equidecomposable G X _ _ s s := by
    use 1, 1, fun _ => s, fun _ => s; simp +decide ;
    exact Set.iUnion_const s

/-
Equidecomposability is transitive.
-/
theorem Equidecomposable.trans {G X : Type*} [Group G] [MulAction G X] {s t u : Set X} :
  @Equidecomposable G X _ _ s t → @Equidecomposable G X _ _ t u → @Equidecomposable G X _ _ s u := by
    intro hst htu;
    obtain ⟨ n₁, f₁, s₁, t₁, hs₁, ht₁, hs₁_disjoint, ht₁_disjoint, hf₁ ⟩ := hst
    obtain ⟨ n₂, f₂, t₂, u₂, ht₂, hu₂, ht₂_disjoint, hu₂_disjoint, hf₂ ⟩ := htu;
    -- Define the refined partitions s' and u' by intersecting the parts of s₁ and t₁ with the parts of t₂ and u₂.
    set s' : Fin n₁ → Fin n₂ → Set X := fun i j => s₁ i ∩ (f₁ i)⁻¹ • t₂ j
    set u' : Fin n₁ → Fin n₂ → Set X := fun i j => u₂ j ∩ (f₂ j) • (t₁ i ∩ t₂ j);
    -- Show that the refined partitions s' and u' satisfy the required conditions.
    have hs'_union : ⋃ i, ⋃ j, s' i j = s := by
      ext x; simp [s', hs₁];
      constructor <;> intro hx;
      · exact hs₁ ▸ Set.mem_iUnion.2 ⟨ hx.choose, hx.choose_spec.1 ⟩;
      · obtain ⟨ i, hi ⟩ := Set.mem_iUnion.mp ( hs₁.symm ▸ hx );
        obtain ⟨ j, hj ⟩ := Set.mem_iUnion.mp ( ht₂.symm ▸ ht₁.symm ▸ Set.mem_iUnion.mpr ⟨ i, hf₁ i ▸ Set.mem_smul_set.mpr ⟨ x, hi, rfl ⟩ ⟩ ) ; use i, hi, j; simp_all +decide [ Set.mem_smul_set ] ;
        exact ⟨ _, hj, by simp +decide [ MulAction.mul_smul ] ⟩
    have hu'_union : ⋃ i, ⋃ j, u' i j = u := by
      ext x; simp [u'];
      constructor <;> intro hx;
      · exact hu₂ ▸ Set.mem_iUnion.2 ⟨ _, hx.choose_spec.choose_spec.1 ⟩;
      · obtain ⟨ j, hj ⟩ := Set.mem_iUnion.mp ( hu₂.symm ▸ hx );
        obtain ⟨ y, hy, rfl ⟩ := hf₂ j |>.symm.subset hj;
        obtain ⟨ i, hi ⟩ := Set.mem_iUnion.mp ( ht₁.symm ▸ show y ∈ t from ht₂.symm ▸ Set.mem_iUnion.mpr ⟨ j, hy ⟩ ) ; use i, j; aesop;
    have hs'_disjoint : ∀ i j i' j', (i, j) ≠ (i', j') → Disjoint (s' i j) (s' i' j') := by
      simp +contextual [ Set.disjoint_left ];
      intro i j i' j' hij x hx hx';
      by_cases hi : i = i' <;> simp_all +decide [ Set.disjoint_left ];
      · obtain ⟨ y, hy, hy' ⟩ := hx.2; obtain ⟨ y', hy', hy'' ⟩ := hx'.2; specialize ht₂_disjoint j j' hij; aesop;
      · exact hs₁_disjoint i i' hi hx.1 hx'.1
    have hu'_disjoint : ∀ i j i' j', (i, j) ≠ (i', j') → Disjoint (u' i j) (u' i' j') := by
      intro i j i' j' hij; simp_all +decide [ Set.disjoint_left ] ;
      intro x hx₁ hx₂; cases eq_or_ne j j' <;> simp_all +decide [ Set.mem_smul_set ] ;
      · simp +zetaDelta at *;
        obtain ⟨ y, hy₁, hy₂ ⟩ := hx₁.2; obtain ⟨ z, hz₁, hz₂ ⟩ := hx₂.2; simp_all +decide [ Set.mem_smul_set_iff_inv_smul_mem ] ;
        exact ht₁_disjoint i i' hij hx₁.1 ( by simpa [ ← hy₂ ] using hx₂.2 );
      · exact hu₂_disjoint j j' ‹_› ( hx₁.1 ) ( hx₂.1 )
    have hfg : ∀ i j, (f₂ j * f₁ i) • s' i j = u' i j := by
      intro i j
      ext x
      simp [s', u', hf₁, hf₂];
      simp +decide [ ← hf₁ i, ← hf₂ j, Set.mem_smul_set, mul_assoc ];
      constructor <;> intro h;
      · rcases h with ⟨ y, ⟨ hy₁, z, hz₁, rfl ⟩, rfl ⟩ ; simp +decide [ MulAction.mul_smul ] ;
        exact ⟨ hz₁, ⟨ _, hy₁, by simp +decide [ MulAction.mul_smul ] ⟩, hz₁ ⟩;
      · rcases h with ⟨ ⟨ y, hy, rfl ⟩, z, ⟨ ⟨ w, hw, rfl ⟩, hz ⟩, h ⟩ ; use w; simp_all +decide [ MulAction.mul_smul ] ;
        exact ⟨ y, hy, by rw [ ← h, inv_smul_smul ] ⟩;
    use n₁ * n₂;
    -- Define the bijection between Fin (n₁ * n₂) and Fin n₁ × Fin n₂.
    obtain ⟨bij, hbij⟩ : ∃ bij : Fin (n₁ * n₂) ≃ Fin n₁ × Fin n₂, True := by
      exact ⟨ Fintype.equivOfCardEq ( by simp +decide ), trivial ⟩;
    use fun i => f₂ (bij i).2 * f₁ (bij i).1, fun i => s' (bij i).1 (bij i).2, fun i => u' (bij i).1 (bij i).2;
    refine' ⟨ _, _, _, _, _ ⟩;
    · convert hs'_union using 1;
      ext x; simp +decide [ Set.mem_iUnion ] ;
      exact ⟨ fun ⟨ i, hi ⟩ => ⟨ _, _, hi ⟩, fun ⟨ i, j, hi ⟩ => ⟨ bij.symm ( i, j ), by simpa using hi ⟩ ⟩;
    · convert hu'_union using 1;
      ext x; simp +decide [ Set.mem_iUnion ] ;
      exact ⟨ fun ⟨ i, hi ⟩ => ⟨ _, _, hi ⟩, fun ⟨ i, j, hi ⟩ => ⟨ bij.symm ( i, j ), by simpa using hi ⟩ ⟩;
    · exact fun i j hij => hs'_disjoint _ _ _ _ ( by simpa [ Fin.ext_iff ] using hij |> fun h => by simpa [ Fin.ext_iff ] using bij.injective.ne h );
    · exact fun i j hij => hu'_disjoint _ _ _ _ ( by simpa [ Fin.ext_iff ] using hij |> fun h => by simpa [ Fin.ext_iff ] using h |> fun h => by simpa [ Fin.ext_iff ] using bij.injective.ne h );
    · exact fun i => hfg _ _

/-
Equidecomposability is symmetric.
-/
theorem Equidecomposable.symm {G X : Type*} [Group G] [MulAction G X] {s t : Set X} :
  @Equidecomposable G X _ _ s t → @Equidecomposable G X _ _ t s := by
    intro h_trans;
    obtain ⟨ n, f, s_parts, t_parts, hs, ht, hs_parts, ht_parts, h ⟩ := h_trans;
    refine' ⟨ n, fun i => ( f i ) ⁻¹, fun i => t_parts i, fun i => s_parts i, _, _, _, _, _ ⟩ <;> simp_all +decide [ Set.ext_iff ];
    intro i x; specialize h i ( f i • x ) ; simp_all +decide [ Set.mem_inv_smul_set_iff ] ;

/-
If s is equidecomposable to t, then any two disjoint subsets of s can be transferred to disjoint subsets of t preserving equidecomposability.
-/
theorem Equidecomposable.transfer_disjoint_subsets {G X : Type*} [Group G] [MulAction G X] {s t : Set X} (hst : @Equidecomposable G X _ _ s t) {a b : Set X} (ha : a ⊆ s) (hb : b ⊆ s) (hab : Disjoint a b) :
  ∃ a' b', a' ⊆ t ∧ b' ⊆ t ∧ Disjoint a' b' ∧ @Equidecomposable G X _ _ a a' ∧ @Equidecomposable G X _ _ b b' := by
    obtain ⟨I, f, g, hf, hg, h_eq⟩ := hst;
    refine' ⟨ ⋃ i, f i • ( g i ∩ a ), ⋃ i, f i • ( g i ∩ b ), _, _, _, _, _ ⟩;
    · simp +decide [ ← h_eq.1, Set.subset_def ];
      rintro x i ⟨ y, hy, rfl ⟩ ; exact ⟨ i, h_eq.2.2.2 i ▸ Set.smul_mem_smul_set hy.1 ⟩ ;
    · simp_all +decide [ Set.subset_def, Set.mem_iUnion ];
      rintro x i ⟨ y, hy, rfl ⟩ ; exact h_eq.1 ▸ Set.mem_iUnion.2 ⟨ i, h_eq.2.2.2 i ▸ Set.smul_mem_smul_set hy.1 ⟩ ;
    · simp_all +decide [ Set.disjoint_left ];
      intro x i hx j hj; simp_all +decide [ Set.mem_smul_set, Set.ext_iff ] ;
      obtain ⟨ y, ⟨ hy₁, hy₂ ⟩, hy₃ ⟩ := hx; obtain ⟨ z, ⟨ hz₁, hz₂ ⟩, hz₃ ⟩ := hj; specialize h_eq; have := h_eq.2.1 i j; simp_all +decide [ ← eq_inv_smul_iff ] ;
      grind +ring;
    · refine' ⟨ I, fun i => f i, fun i => g i ∩ a, _, _, _ ⟩ <;> simp_all +decide [ Set.disjoint_left ];
      use fun i => f i • ( g i ∩ a );
      · simp_all +decide [ Set.ext_iff ];
        exact?;
      · simp_all +decide [ Set.ext_iff, Set.disjoint_left ];
        simp_all +decide [ Set.mem_smul_set_iff_inv_smul_mem ];
        grind +ring;
    · refine' ⟨ I, fun i => f i, fun i => g i ∩ b, _, _, _ ⟩ <;> simp_all +decide [ Set.disjoint_left ];
      use fun i => f i • ( g i ∩ b );
      · ext x; simp [hg];
        exact fun hx => by rcases Set.mem_iUnion.mp ( hg.symm ▸ hb hx ) with ⟨ i, hi ⟩ ; exact ⟨ i, hi ⟩ ;
      · simp_all +decide [ Set.ext_iff, Set.disjoint_left ];
        simp_all +decide [ Set.mem_smul_set_iff_inv_smul_mem ];
        grind

/-
If s is paradoxical and s is equidecomposable to t, then t is paradoxical.
-/
theorem Paradoxical.of_equidecomposable {G X : Type*} [Group G] [MulAction G X] {s t : Set X} :
  @Paradoxical G X _ _ s → @Equidecomposable G X _ _ s t → @Paradoxical G X _ _ t := by
    intro hs ht;
    obtain ⟨ a, b, ha, hb, hab ⟩ := hs;
    have := Equidecomposable.transfer_disjoint_subsets ht hb hab.1 ha;
    obtain ⟨ a', b', ha', hb', hab', ha'', hb'' ⟩ := this;
    refine' ⟨ a', b', _, _, _ ⟩;
    · exact hab';
    · exact ha';
    · exact ⟨ hb', Equidecomposable.trans ( Equidecomposable.symm ht ) ( Equidecomposable.trans hab.2.1 ha'' ), Equidecomposable.trans ( Equidecomposable.symm ht ) ( Equidecomposable.trans hab.2.2 hb'' ) ⟩

/-
The sphere S2 is equidecomposable to S2 \ D.
-/
theorem S2_equidecomposable_S2_minus_D :
  @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ Set.univ S2_minus_D := by
    by_contra h_contra;
    -- Let $D' = g D$ for some rotation $g$ such that $D'$ is disjoint from the poles.
    obtain ⟨g, hg⟩ : ∃ g : Matrix.specialOrthogonalGroup (Fin 3) ℝ, Disjoint (g • D) z_axis_poles := by
      exact?;
    -- Let $E = \bigcup_{n=0}^{\infty} \rho^n D'$ for some rotation $\rho$ about the z-axis such that $D'$ is disjoint from the poles.
    obtain ⟨ρ, hρ⟩ : ∃ ρ : Matrix.specialOrthogonalGroup (Fin 3) ℝ, ∀ (n : ℤ) (x y : S2), x ∈ g • D → y ∈ g • D → n ≠ 0 → (ρ ^ n) • x ≠ y := by
      obtain ⟨θ, hθ⟩ : ∃ θ : ℝ, ∀ (n : ℤ) (x y : S2), x ∈ g • D → y ∈ g • D → n ≠ 0 → (rotation_about_z (n * θ)) • x ≠ y := by
        have h_countable : Set.Countable (g • D) := by
          exact Set.Countable.image ( D_countable ) _;
        have := exists_good_rotation_angle ( g • D ) h_countable hg;
        obtain ⟨ θ, hθ ⟩ := this; use θ; intro n x y hx hy hn; specialize hθ n ⟨ x, hx ⟩ ⟨ y, hy ⟩ hn; aesop;
      use rotation_about_z θ;
      convert hθ using 6;
      rw [ rotation_about_z_pow ];
    -- Then $E = D' \cup \rho E$ and $D'$ is disjoint from $\rho E$.
    have hE : absorbing_set (g • D) ρ = g • D ∪ ρ • absorbing_set (g • D) ρ ∧ Disjoint (g • D) (ρ • absorbing_set (g • D) ρ) := by
      exact ⟨ absorbing_set_decomp _ _, absorbing_set_disjoint _ _ hρ ⟩;
    -- So $S2 = (S2 \ E) \cup E \sim (S2 \ E) \cup \rho E = S2 \ D'$.
    have hS2_decomp : @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ Set.univ (Set.univ \ (g • D)) := by
      have hS2_decomp : @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ (Set.univ \ absorbing_set (g • D) ρ ∪ absorbing_set (g • D) ρ) (Set.univ \ absorbing_set (g • D) ρ ∪ ρ • absorbing_set (g • D) ρ) := by
        refine' ⟨ _, _ ⟩;
        exact 2;
        refine' ⟨ fun i => if i = 0 then 1 else ρ, fun i => if i = 0 then Set.univ \ absorbing_set ( g • D ) ρ else absorbing_set ( g • D ) ρ, fun i => if i = 0 then Set.univ \ absorbing_set ( g • D ) ρ else ρ • absorbing_set ( g • D ) ρ, _, _, _, _, _ ⟩ <;> simp +decide [ Fin.forall_fin_two ];
        · ext x; simp [Set.mem_iUnion];
          exact em' _;
        · ext; simp [Set.mem_union, Set.mem_iUnion];
        · exact ⟨ Set.disjoint_sdiff_left, Set.disjoint_sdiff_right ⟩;
        · simp +decide [ Set.disjoint_left ] at hE ⊢;
          grind +ring;
      convert hS2_decomp using 1;
      · ext x; by_cases hx : x ∈ absorbing_set ( g • D ) ρ <;> simp +decide [ hx ] ;
      · ext x;
        by_cases hx : x ∈ absorbing_set ( g • D ) ρ <;> simp +decide [ hx ];
        · exact ⟨ fun hx' => Or.resolve_left ( hE.1.subset hx ) hx', fun hx' => fun hx'' => hE.2.le_bot ⟨ hx'', hx' ⟩ ⟩;
        · exact fun hx' => hx <| hE.1.symm ▸ Set.mem_union_left _ hx';
    -- Since $g$ is a rotation, $S2 \ D' \sim S2 \ D$.
    have hS2_D'_sim_S2_D : @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ (Set.univ \ (g • D)) (Set.univ \ D) := by
      refine' ⟨ 1, _, _ ⟩ <;> norm_num [ Set.ext_iff ];
      exact fun _ => g⁻¹;
      refine' ⟨ fun _ => { x : S2 | x ∉ g • D }, _, fun _ => { x : S2 | x ∉ D }, _, _ ⟩ <;> simp +decide [ Set.ext_iff ];
      intro a ha; rw [ Set.mem_smul_set_iff_inv_smul_mem ] ; simp +decide [ Set.mem_smul_set_iff_inv_smul_mem ] ;
    apply h_contra;
    convert hS2_decomp.trans hS2_D'_sim_S2_D using 1;
    ext; simp [S2_minus_D]

/-
The Banach-Tarski paradox for the sphere S2: S2 is paradoxical.
-/
theorem S2_paradoxical : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ Set.univ := by
  -- Apply the transfer of paradoxicality under equidecomposability.
  apply Paradoxical.of_equidecomposable;
  apply S2_minus_D_paradoxical_SO3;
  convert S2_equidecomposable_S2_minus_D.symm using 1

/-
Checking the type of affine isometries and the closed ball.
-/
#check EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)
#check Metric.closedBall (0 : EuclideanSpace ℝ (Fin 3)) 1

/-
The sector of the entire sphere is equal to the unit ball minus the origin.
-/
def Ball_without_origin : Set (EuclideanSpace ℝ (Fin 3)) := Metric.ball 0 1 \ {0}

def Sector (S : Set S2) : Set (EuclideanSpace ℝ (Fin 3)) :=
  {v | ∃ (r : ℝ) (x : S2), 0 < r ∧ r < 1 ∧ x ∈ S ∧ v = r • x.1}

theorem Sector_univ_eq_Ball_without_origin : Sector Set.univ = Ball_without_origin := by
  unfold Sector Ball_without_origin;
  ext v;
  constructor <;> intro h;
  · obtain ⟨ r, x, hr, hr', _, rfl ⟩ := h;
    simp +decide [ hr.ne', hr'.ne', norm_smul, x.2 ];
    exact ⟨ abs_lt.mpr ⟨ by linarith, by linarith ⟩, by intro h; have := x.2; simp_all +decide [ S2 ] ⟩;
  · use ‖v‖, ⟨‖v‖⁻¹ • v, by
      simp_all +decide [ S2 ];
      rw [ norm_smul, norm_inv, norm_norm, inv_mul_cancel₀ ( norm_ne_zero_iff.mpr h.2 ) ]⟩
    generalize_proofs at *;
    aesop

/-
If two subsets of the sphere are equidecomposable, their sectors are equidecomposable in 3D space.
-/
theorem Sector_equidecomposable {S T : Set S2} (h : @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ S T) :
  @Equidecomposable (Matrix.specialOrthogonalGroup (Fin 3) ℝ) (EuclideanSpace ℝ (Fin 3)) _ _ (Sector S) (Sector T) := by
    obtain ⟨ n, ( f : Fin n → Matrix.specialOrthogonalGroup ( Fin 3 ) ℝ ), ( S_parts : Fin n → Set S2 ), ( T_parts : Fin n → Set S2 ), hS, hT, h_disj, h_equis ⟩ := h;
    refine' ⟨ n, fun i => f i, fun i => Sector ( S_parts i ), fun i => Sector ( T_parts i ), _, _, _, _ ⟩ <;> simp_all +decide [ Set.ext_iff ];
    · intro x; constructor <;> intro hx <;> simp_all +decide [ Sector ] ;
      · rcases hx with ⟨ i, r, hr₀, hr₁, a, ⟨ ha₁, ha₂ ⟩, rfl ⟩ ; exact ⟨ r, hr₀, hr₁, a, ⟨ ha₁, hS _ _ |>.1 ⟨ i, ha₂ ⟩ ⟩, rfl ⟩ ;
      · rcases hx with ⟨ r, hr₀, hr₁, a, ⟨ ha₁, ha₂ ⟩, rfl ⟩ ; specialize hS a ha₁; aesop;
    · intro x; constructor <;> intro hx <;> simp_all +decide [ Sector ] ;
      · rcases hx with ⟨ i, r, hr₀, hr₁, a, ⟨ ha₁, ha₂ ⟩, rfl ⟩ ; exact ⟨ r, hr₀, hr₁, a, ⟨ ha₁, hT _ _ |>.1 ⟨ i, ha₂ ⟩ ⟩, rfl ⟩ ;
      · rcases hx with ⟨ r, hr₀, hr₁, a, ⟨ ha₁, ha₂ ⟩, rfl ⟩ ; rcases hT a ha₁ |>.2 ha₂ with ⟨ i, hi ⟩ ; use i, r, hr₀, hr₁, a ; aesop;
    · intro i j hij; specialize h_disj i j hij; simp_all +decide [ Set.disjoint_left ] ;
      rintro v ⟨ r, x, hr, hx, hx', rfl ⟩ ⟨ s, y, hs, hy, hy', h ⟩ ; specialize h_disj x.1 x.2 ; simp_all +decide [ Set.mem_smul_set, smul_smul ] ;
      have := congr_arg ( fun z => ‖z‖ ) h ; norm_num [ norm_smul, hr.le, hs.le ] at this;
      rw [ abs_of_pos hr, abs_of_pos hs ] at this ; simp_all +decide [ ne_of_gt ];
      exact h_disj ( by rw [ smul_right_inj hs.ne' ] at h; aesop );
    · constructor;
      · intro i j hij; rw [ Set.disjoint_left ] ; intro x hx hx'; obtain ⟨ r₁, x₁, hr₁, hx₁, hx₁', rfl ⟩ := hx; obtain ⟨ r₂, x₂, hr₂, hx₂, hx₂', hx₂'' ⟩ := hx'; simp_all +decide [ Set.disjoint_left ] ;
        -- Since $r₁ • x₁ = r₂ • x₂$, we have $x₁ = (r₂ / r₁) • x₂$.
        have h_eq : x₁.val = (r₂ / r₁) • x₂.val := by
          rw [ div_eq_inv_mul, MulAction.mul_smul, ← hx₂'', inv_smul_smul₀ hr₁.ne' ];
        -- Since $x₁$ and $x₂$ are points on the sphere $S2$, their norms are 1. Therefore, $r₂ / r₁ = 1$, implying $r₂ = r₁$.
        have h_r_eq : r₂ = r₁ := by
          have h_r_eq : ‖x₁.val‖ = ‖(r₂ / r₁) • x₂.val‖ := by
            rw [h_eq];
          norm_num [ norm_smul, hr₁.ne', hr₂.ne' ] at h_r_eq;
          rw [ eq_div_iff ] at h_r_eq <;> cases abs_cases r₁ <;> cases abs_cases r₂ <;> linarith;
        simp_all +decide [ ne_of_gt ];
        exact h_equis.1 i j hij _ _ hx₁' ( by simpa [ show x₁ = x₂ from Subtype.ext h_eq ] using hx₂' );
      · intro i x; constructor <;> intro hx <;> simp_all +decide [ Set.mem_smul_set, Sector ] ;
        · rcases hx with ⟨ y, ⟨ r, hr₀, hr₁, a, ⟨ ha₀, ha₁ ⟩, rfl ⟩, rfl ⟩ ; specialize h_equis ; have := h_equis.2 i a ha₀ ; simp_all +decide [ Set.disjoint_left ] ;
          refine' ⟨ r, hr₀, hr₁, f i • a, _, _ ⟩ <;> simp_all +decide [ Set.mem_smul_set, MulAction.mul_smul ];
          · exact h_equis.2 i _ _ |>.1 ⟨ _, ha₀, ha₁, rfl ⟩ |> fun h => ⟨ by
              grind, h ⟩
            skip;
          · exact?;
        · rcases hx with ⟨ r, hr₀, hr₁, a, ⟨ ha₁, ha₂ ⟩, rfl ⟩ ; specialize h_equis ; have := h_equis.2 i a ha₁ ; simp_all +decide [ Subtype.ext_iff ] ;
          obtain ⟨ b, hb₁, hb₂, hb₃ ⟩ := h_equis.2 i a ha₁ |>.2 ha₂;
          refine' ⟨ r • b, ⟨ r, hr₀, hr₁, b, ⟨ hb₁, hb₂ ⟩, rfl ⟩, _ ⟩ ; simp_all +decide [ smul_smul, MulAction.mul_smul ];
          rw [ ← hb₃, SMulCommClass.smul_comm ];
          exact?

/-
Disjoint subsets of the sphere generate disjoint sectors.
-/
theorem Sector_disjoint {S T : Set S2} (h : Disjoint S T) : Disjoint (Sector S) (Sector T) := by
  simp_all +decide [ Set.disjoint_left ];
  rintro _ ⟨ r₁, x₁, hr₁, hx₁, h₁, rfl ⟩ ⟨ r₂, x₂, hr₂, hx₂, h₂, h₃ ⟩;
  -- Since $r₁ • x₁ = r₂ • x₂$, we have $‖r₁ • x₁‖ = ‖r₂ • x₂‖$, which implies $r₁ = r₂$.
  have hr_eq : r₁ = r₂ := by
    replace h₃ := congr_arg ( fun v => ‖v‖ ) h₃ ; simp_all +decide [ norm_smul, abs_of_pos ];
  -- Since $r₁ • x₁ = r₂ • x₂$ and $r₁ = r₂$, we have $x₁ = x₂$.
  have hx_eq : x₁ = x₂ := by
    exact Subtype.ext <| smul_right_injective _ hr₁.ne' <| by aesop;
  aesop

/-
The unit ball minus the origin is paradoxical.
-/
theorem Ball_without_origin_paradoxical : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) (EuclideanSpace ℝ (Fin 3)) _ _ Ball_without_origin := by
  -- By definition of equidecomposable, we need to show that S2 is paradoxical.
  have h_paradoxical_S2 : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) S2 _ _ Set.univ := by
    exact?;
  obtain ⟨ A, B, h ⟩ := h_paradoxical_S2;
  obtain ⟨ h₁, h₂, h₃, h₄, h₅ ⟩ := h;
  -- By definition of equidecomposable, we need to show that Sector(S2) is paradoxical.
  have h_sector_paradoxical : @Paradoxical (Matrix.specialOrthogonalGroup (Fin 3) ℝ) (EuclideanSpace ℝ (Fin 3)) _ _ (Sector Set.univ) := by
    refine' ⟨ Sector A, Sector B, _, _, _ ⟩;
    · exact?;
    · exact fun x hx => by obtain ⟨ r, x, hr, hx', hx'', rfl ⟩ := hx; exact ⟨ r, x, hr, hx', Set.mem_univ _, rfl ⟩ ;
    · refine' ⟨ _, _, _ ⟩;
      · exact fun x hx => by obtain ⟨ r, y, hr, hy, hy', rfl ⟩ := hx; exact ⟨ r, y, hr, hy, Set.mem_univ _, rfl ⟩ ;
      · exact?;
      · exact?;
  convert h_sector_paradoxical using 1;
  exact Sector_univ_eq_Ball_without_origin.symm

/-
Checking for Group and MulAction instances for AffineIsometryEquiv.
-/
#check EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)
#synth Group (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3))
#synth MulAction (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3))

/-
Equidecomposability is preserved when moving to a larger group that acts compatibly.
-/
theorem Equidecomposable.of_subgroup {G H X : Type*} [Group G] [Group H] [MulAction G X] [MulAction H X] (f : H →* G) (hf : ∀ (h : H) (x : X), (f h) • x = h • x) {s t : Set X} :
  @Equidecomposable H X _ _ s t → @Equidecomposable G X _ _ s t := by
    intro h;
    obtain ⟨ n, p, q, hp, hq, h_eq ⟩ := h;
    refine' ⟨ n, fun i => f ( p i ), q, hp, _, _, _, _ ⟩ <;> simp_all +decide [ Finset.card_univ, Set.ext_iff ];
    simp_all +decide [ Set.mem_smul_set, hf ]

/-
Paradoxicality is preserved when moving to a larger group that acts compatibly.
-/
theorem Paradoxical.of_subgroup {G H X : Type*} [Group G] [Group H] [MulAction G X] [MulAction H X] (f : H →* G) (hf : ∀ (h : H) (x : X), (f h) • x = h • x) {s : Set X} :
  @Paradoxical H X _ _ s → @Paradoxical G X _ _ s := by
    intro h;
    obtain ⟨a, b, ha, hb, hab, h1, h2⟩ := h;
    exact ⟨ a, b, ha, hb, hab, Equidecomposable.of_subgroup f hf h1, Equidecomposable.of_subgroup f hf h2 ⟩

/-
Definition of the affine isometry corresponding to a rotation matrix.
-/
def toAffine (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) : EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3) :=
  let f := Matrix.toEuclideanLin g.1
  let f_inv := Matrix.toEuclideanLin g⁻¹.1
  have h_iso : ∀ x, ‖f x‖ = ‖x‖ := by
    intro x; have := g.2.1; simp_all +decide [ Matrix.mulVec, dotProduct ] ; ring!;
    have h_norm_preserved : ∀ (x : EuclideanSpace ℝ (Fin 3)), (g.val.mulVec x) ⬝ᵥ (g.val.mulVec x) = x ⬝ᵥ x := by
      intro x; have := this.2; simp_all +decide [ Matrix.mulVec, dotProduct ] ; ring!;
      have h_norm_preserved : ∀ (x : EuclideanSpace ℝ (Fin 3)), (g.val.mulVec x) ⬝ᵥ (g.val.mulVec x) = x ⬝ᵥ x := by
        intro x
        have h_unitary : g.val.transpose * g.val = 1 := by
          exact?
        simp +decide [ Matrix.dotProduct_mulVec, Matrix.vecMul_mulVec, h_unitary ];
      simpa [ sq, Matrix.mulVec, dotProduct ] using h_norm_preserved x;
    simp_all +decide [ EuclideanSpace.norm_eq, dotProduct ];
    simp_all +decide [ sq, Matrix.toEuclideanLin ]
  let l_iso : EuclideanSpace ℝ (Fin 3) ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin 3) :=
    { f with
      invFun := f_inv
      left_inv := by
        have h_inv : ∀ x : EuclideanSpace ℝ (Fin 3), f_inv (f x) = x := by
          intro x
          have h_inv : g⁻¹ * g = 1 := by
            exact Subtype.ext <| by simp +decide [ Matrix.mul_nonsing_inv ] ;
          -- Since $g⁻¹ * g = 1$, we have $f_inv (f x) = (g⁻¹ * g) • x = 1 • x = x$.
          have h_inv : f_inv (f x) = (g⁻¹ * g).val.mulVec x := by
            convert Matrix.mulVec_mulVec _ _ _ using 1
            generalize_proofs at *; (
            exact?)
          generalize_proofs at *; (
          aesop
          skip)
        generalize_proofs at *; (
        exact h_inv)
      right_inv := by
        intro x; simp +decide [ Matrix.toEuclideanLin ] ;
        have h_inv : f_inv ∘ₗ f = LinearMap.id := by
          ext x; simp [f, f_inv];
          have h_inv : g⁻¹ * g = 1 := by
            exact Subtype.ext <| by simp +decide [ Matrix.mul_nonsing_inv ] ;
          have h_inv : Matrix.toEuclideanLin (g⁻¹.val * g.val) = LinearMap.id := by
            have h_inv : Matrix.toEuclideanLin (1 : Matrix (Fin 3) (Fin 3) ℝ) = LinearMap.id := by
              ext; simp [Matrix.toEuclideanLin];
            convert h_inv using 1;
            congr! 1;
            exact Subtype.ext_iff.mp ‹g⁻¹ * g = 1›;
          convert congr_arg ( fun f => f x ‹_› ) h_inv using 1;
          simp +decide [ Matrix.toEuclideanLin, Matrix.mulVec ];
        have h_inv : f ∘ₗ f_inv = LinearMap.id := by
          exact?;
        exact LinearMap.congr_fun h_inv x
      norm_map' := h_iso }
  l_iso.toAffineIsometryEquiv

/-
Definition of the affine isometry corresponding to a rotation matrix.
-/
def rotationToAffine (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) : EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3) :=
  let f := Matrix.toEuclideanLin g.1
  let f_inv := Matrix.toEuclideanLin g⁻¹.1
  let l_equiv : EuclideanSpace ℝ (Fin 3) ≃ₗ[ℝ] EuclideanSpace ℝ (Fin 3) :=
    { f with
      invFun := f_inv
      left_inv := by
        intro x; exact (by
        convert congr_arg ( fun m => m.mulVec x ) ( show g⁻¹.1 * g.1 = 1 from ?_ ) using 1 ; simp +decide [ Matrix.mulVec ];
        · ext i; exact (by
          simp +decide [ Matrix.mulVec, dotProduct, f, f_inv ];
          simp +decide [ Matrix.toEuclideanLin, Matrix.mulVec, dotProduct, Fin.sum_univ_three ]);
        · norm_num [ Matrix.one_mulVec ];
        · exacts [ Subtype.ext_iff.mp ( inv_mul_cancel g ) ])
      right_inv := by
        -- Since $g$ is in the special orthogonal group, its inverse is also in the group, and their product is the identity matrix.
        have h_inv : g.1 * g⁻¹.1 = 1 := by
          -- Since $g$ is in the special orthogonal group, we have $g * g⁻¹ = 1$ by definition of the inverse in the group.
          have h_inv : g * g⁻¹ = 1 := by
            exact Subtype.ext <| by simp +decide [ Matrix.mul_nonsing_inv ] ;
          generalize_proofs at *; (
          exact congr_arg Subtype.val h_inv)
        generalize_proofs at *; (
        intro x; exact (by
        convert congr_arg ( fun m : Matrix ( Fin 3 ) ( Fin 3 ) ℝ => m.mulVec x ) h_inv using 1;
        · convert Matrix.mulVec_mulVec _ _ _ using 1;
          exact?;
        · norm_num [ Matrix.mulVec ]);) }
  let l_iso : EuclideanSpace ℝ (Fin 3) ≃ₗᵢ[ℝ] EuclideanSpace ℝ (Fin 3) :=
    { l_equiv with
      norm_map' := by
        intro x; rw [ EuclideanSpace.norm_eq, EuclideanSpace.norm_eq ] ; simp +decide [ Matrix.toEuclideanLin ] ; ring;
        have h_iso : ∀ x : EuclideanSpace ℝ (Fin 3), ∑ i, (g.1.mulVec x) i ^ 2 = ∑ i, x i ^ 2 := by
          intro x; have := g.2; simp_all +decide [ Matrix.mulVec, dotProduct ] ; ring;
          have h_iso : ∀ x : EuclideanSpace ℝ (Fin 3), ∑ i, (g.1.mulVec x) i ^ 2 = ∑ i, x i ^ 2 := by
            intro x
            have h_iso : (g.1.mulVec x) ⬝ᵥ (g.1.mulVec x) = x ⬝ᵥ x := by
              have h_iso : (g.1.transpose * g.1) = 1 := by
                have := g.2; simp_all +decide [ Matrix.mul_eq_one_comm ] ;
                exact g.2.1.2;
              simp +decide [ Matrix.dotProduct_mulVec, Matrix.vecMul_mulVec, h_iso ]
            simpa only [ sq, dotProduct ] using h_iso;
          exact h_iso x;
        exact congr_arg Real.sqrt ( h_iso x ) }
  l_iso.toAffineIsometryEquiv

/-
The map from rotation matrices to affine isometries is injective.
-/
theorem rotationToAffine_injective : Function.Injective rotationToAffine := by
  intro g h hgh;
  unfold rotationToAffine at hgh;
  simp_all +decide [ AffineIsometryEquiv.ext_iff, LinearMap.ext_iff ];
  ext i j; have := congr_fun ( hgh ( EuclideanSpace.single j 1 ) ) i; simp_all +decide [ Matrix.toEuclideanLin ] ;

/-
The map from rotation matrices to affine isometries preserves multiplication.
-/
theorem rotationToAffine_mul (g h : Matrix.specialOrthogonalGroup (Fin 3) ℝ) :
  rotationToAffine (g * h) = rotationToAffine g * rotationToAffine h := by
    unfold rotationToAffine;
    ext x; exact (by
    simp +decide [ Matrix.toEuclideanLin ])

/-
The affine isometry corresponding to a rotation matrix acts on vectors as the rotation matrix does.
-/
theorem rotationToAffine_smul (g : Matrix.specialOrthogonalGroup (Fin 3) ℝ) (x : EuclideanSpace ℝ (Fin 3)) :
  rotationToAffine g x = g • x := by
    exact?

/-
The map from rotation matrices to affine isometries preserves the identity element.
-/
theorem rotationToAffine_one : rotationToAffine 1 = 1 := by
  unfold rotationToAffine;
  unfold Matrix.toEuclideanLin; aesop;

/-
The group homomorphism from rotation matrices to affine isometries.
-/
def rotationToAffineHom : Matrix.specialOrthogonalGroup (Fin 3) ℝ →* EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3) where
  toFun := rotationToAffine
  map_one' := rotationToAffine_one
  map_mul' := rotationToAffine_mul

/-
The unit ball minus the origin is paradoxical under the group of affine isometries.
-/
theorem Ball_without_origin_paradoxical_affine :
  @Paradoxical (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3)) _ _ Ball_without_origin := by
    -- Apply the `Paradoxical.of_subgroup` theorem, which requires showing that the subgroup's action is compatible with the larger group's action and that the set is paradoxical under the subgroup.
    apply Paradoxical.of_subgroup rotationToAffineHom (by
    exact?);
    -- Apply the theorem that states the unit ball minus the origin is paradoxical.
    apply Ball_without_origin_paradoxical

/-
Definition of the affine rotation used to absorb the origin.
-/
def Ball : Set (EuclideanSpace ℝ (Fin 3)) := Metric.ball 0 1

noncomputable def rho_aff : EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3) :=
  let v : EuclideanSpace ℝ (Fin 3) := ![1/2, 0, 0]
  let T_v := AffineIsometryEquiv.constVAdd ℝ (EuclideanSpace ℝ (Fin 3)) v
  let T_neg_v := AffineIsometryEquiv.constVAdd ℝ (EuclideanSpace ℝ (Fin 3)) (-v)
  let R := rotationToAffine (rotation_about_z 1)
  T_v.trans (R.trans T_neg_v)

/-
The cosine of a natural number is never -1.
-/
theorem cos_nat_ne_neg_one (n : ℕ) : Real.cos n ≠ -1 := by
  by_contra h_cos_eq_neg_one
  obtain ⟨k, hk⟩ : ∃ k : ℤ, n = (2 * k + 1) * Real.pi := by
    rw [ ← Real.cos_pi, Real.cos_eq_cos_iff ] at h_cos_eq_neg_one;
    rcases h_cos_eq_neg_one with ⟨ k, hk | hk ⟩ <;> [ exact ⟨ -k, by push_cast; linarith ⟩ ; exact ⟨ k - 1, by push_cast; linarith ⟩ ];
  -- This implies $\pi = \frac{n}{2k + 1}$, so $\pi$ is rational, which is false.
  have h_pi_rational : ∃ q : ℚ, Real.pi = q := by
    exact ⟨ n / ( 2 * k + 1 ), by push_cast [ hk ] ; rw [ mul_div_cancel_left₀ _ ( by rcases k with ⟨ _ | k ⟩ <;> norm_num at * <;> nlinarith [ Real.pi_gt_three ] ) ] ⟩;
  exact irrational_pi <| by aesop;

/-
The orbit of the origin under the affine rotation.
-/
def D_origin : Set (EuclideanSpace ℝ (Fin 3)) := {x | ∃ n : ℕ, x = (rho_aff ^ n) 0}

/-
Explicit formula for the orbit of the origin under the affine rotation.
-/
theorem rho_aff_pow_apply_zero (n : ℕ) :
  (rho_aff ^ n) 0 = (rotation_about_z n) • ![1/2, 0, 0] - ![1/2, 0, 0] := by
    induction n <;> simp_all +decide [ pow_succ' ];
    · -- By definition of rotation_about_z, we have rotation_about_z 0 = 1.
      have h_rotation_zero : rotation_about_z 0 = 1 := by
        unfold rotation_about_z;
        exact Subtype.ext <| by ext i j; fin_cases i <;> fin_cases j <;> norm_num [ rot_z_group, rot_z_angle ] ;
      aesop;
    · unfold rho_aff;
      unfold rotationToAffine; norm_num [ rotation_about_z_pow ] ; ring;
      unfold rotation_about_z; norm_num [ Matrix.toEuclideanLin, Matrix.mulVec ] ; ring;
      ext i ; fin_cases i <;> norm_num [ Matrix.mulVec, rot_z_group ] ; ring!;
      · norm_num [ rot_z_angle, Matrix.mulVec, dotProduct ] ; ring;
        norm_num [ Fin.sum_univ_succ, Matrix.vecHead, Matrix.vecTail ] ; ring;
        erw [ Pi.sub_apply ] ; norm_num [ Matrix.vecHead, Matrix.vecTail, Real.cos_add, Real.sin_add ] ; ring;
      · norm_num [ Fin.sum_univ_succ, Matrix.mulVec, dotProduct, rot_z_angle ] ; ring!;
        erw [ Pi.sub_apply ] ; norm_num [ Real.sin_add, Real.cos_add ] ; ring!;
      · unfold rot_z_angle; norm_num [ Matrix.mulVec ] ; ring!;
        erw [ Pi.sub_apply ] ; norm_num [ Matrix.vecHead, Matrix.vecTail ];
        rfl

/-
The orbit of the origin under the affine rotation is contained in the ball.
-/
theorem D_origin_subset_Ball : D_origin ⊆ Ball := by
  rintro x ⟨ n, rfl ⟩;
  rw [ rho_aff_pow_apply_zero ];
  -- By definition of $D_{\text{origin}}$, we know that $(rotation\_about\_z n) • ![1/2, 0, 0] - ![1/2, 0, 0]$ is in the ball.
  simp [Ball];
  norm_num [ Norm.norm ];
  norm_num [ rotation_about_z ];
  norm_num [ rot_z_group, Matrix.mulVec ];
  norm_num [ Fin.sum_univ_succ, rot_z_angle ];
  norm_num [ Matrix.vecHead, Matrix.vecTail, sub_eq_add_neg ];
  erw [ Matrix.cons_val_succ' ] ; norm_num ; ring_nf ; norm_num;
  rw [ ← Real.sqrt_eq_rpow, Real.sqrt_lt' ] <;> nlinarith [ Real.cos_sq' n, show Real.cos n > -1 from by exact lt_of_le_of_ne ( Real.neg_one_le_cos _ ) ( Ne.symm <| by exact fun h => by have := cos_nat_ne_neg_one n; aesop ) ]

/-
The squared norm of the n-th point in the orbit of the origin.
-/
theorem norm_sq_rho_aff_pow_apply_zero (n : ℕ) : ‖(rho_aff ^ n) 0‖^2 = (1 - Real.cos n) / 2 := by
  rw [ rho_aff_pow_apply_zero ];
  -- Apply the rotation to the vector ![1/2, 0, 0].
  have h_rotate : rotation_about_z n • ![1 / 2, 0, 0] = ![1 / 2 * Real.cos n, 1 / 2 * Real.sin n, 0] := by
    unfold rotation_about_z ;
    unfold rot_z_group;
    norm_num [ rot_z_angle, Matrix.mulVec ];
    ext i; fin_cases i <;> norm_num [ Matrix.vecHead, Matrix.vecTail ] ;
  norm_num [ EuclideanSpace.norm_eq, Fin.sum_univ_three, h_rotate ] ; ring;
  erw [ Real.sq_sqrt ] <;> norm_num ; ring ; norm_num [ Real.sin_sq, Real.cos_sq ] ; ring;
  · erw [ Pi.sub_apply, Pi.sub_apply, Pi.sub_apply ] ; norm_num ; ring;
    erw [ Matrix.cons_val_succ' ] ; norm_num ; ring;
    rw [ Real.sin_sq ] ; ring;
  · positivity

/-
The cosine of a positive natural number is never 1.
-/
theorem cos_nat_ne_one_of_pos (n : ℕ) (h : n > 0) : Real.cos n ≠ 1 := by
  -- Assume for contradiction that $\cos(n) = 1$. Then $n = 2k\pi$ for some integer $k$.
  by_contra h_contra
  obtain ⟨k, hk⟩ : ∃ k : ℤ, n = 2 * k * Real.pi := by
    rw [ Real.cos_eq_one_iff ] at h_contra; obtain ⟨ k, hk ⟩ := h_contra; exact ⟨ k, by linarith ⟩ ;
  -- Since π is irrational, the only way for n to be an integer multiple of 2π is if k is zero. But since n is positive, k can't be zero. This leads to a contradiction.
  have h_irr : Irrational Real.pi := by
    exact?;
  exact h_irr ⟨ n / ( 2 * k ), by push_cast [ hk ] ; rw [ mul_div_cancel_left₀ _ ( by aesop ) ] ⟩

/-
The affine rotation maps the orbit of the origin to the orbit minus the origin.
-/
theorem rho_aff_maps_D_origin : rho_aff '' D_origin = D_origin \ {0} := by
  ext x
  simp [D_origin];
  constructor;
  · rintro ⟨ y, ⟨ n, rfl ⟩, rfl ⟩ ; use ⟨ n + 1, by simp +decide [ pow_succ' ] ⟩ ; intro h; have := congr_arg ( fun z => ‖z‖ ) h; norm_num [ norm_sq_rho_aff_pow_apply_zero ] at this;
    have := norm_sq_rho_aff_pow_apply_zero ( n + 1 ) ; simp_all +decide [ pow_succ' ] ;
    exact absurd this ( by linarith [ Real.cos_le_one ( n + 1 ), show Real.cos ( n + 1 ) < 1 from lt_of_le_of_ne ( Real.cos_le_one _ ) fun h => by exact absurd ( cos_nat_ne_one_of_pos ( n + 1 ) ( Nat.succ_pos _ ) ) ( by norm_num [ h ] ) ] );
  · rintro ⟨ ⟨ n, rfl ⟩, hn ⟩;
    refine' ⟨ _, ⟨ n - 1, rfl ⟩, _ ⟩ ; rcases n with ( _ | n ) <;> simp_all +decide [ pow_succ', mul_assoc ]

/-
The unit ball is equidecomposable to the unit ball minus the origin.
-/
theorem Ball_equidecomposable_Ball_without_origin :
  @Equidecomposable (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3)) _ _ Ball Ball_without_origin := by
    refine' ⟨ 2, _ ⟩;
    refine' ⟨ fun i => if i = 0 then 1 else rho_aff, fun i => if i = 0 then Ball \ D_origin else D_origin, fun i => if i = 0 then Ball \ D_origin else D_origin \ { 0 }, _, _, _, _, _ ⟩ <;> simp +decide [ Fin.forall_fin_two ];
    · ext x; by_cases hx : x ∈ D_origin <;> simp +decide [ hx ] ;
      exact D_origin_subset_Ball hx;
    · ext x;
      by_cases hx : x ∈ D_origin <;> simp +decide [ hx ];
      · exact ⟨ fun h => ⟨ by
          exact D_origin_subset_Ball hx, h ⟩, fun h => h.2 ⟩;
      · exact ⟨ fun hx' => ⟨ hx', by rintro rfl; exact hx ⟨ 0, by norm_num ⟩ ⟩, fun hx' => hx'.1 ⟩;
    · exact ⟨ Set.disjoint_sdiff_left, Set.disjoint_sdiff_right ⟩;
    · exact ⟨ Set.disjoint_left.mpr fun x hx₁ hx₂ => hx₁.2 hx₂.1, Set.disjoint_left.mpr fun x hx₁ hx₂ => hx₂.2 hx₁.1 ⟩;
    · convert rho_aff_maps_D_origin using 1

/-
The Banach-Tarski paradox for the unit ball: the ball is paradoxical.
-/
theorem Ball_paradoxical :
  @Paradoxical (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3)) _ _ Ball := by
    -- Since the ball is equidecomposable to the ball minus the origin, and the ball minus the origin is paradoxical, the ball must also be paradoxical.
    have h_ball_paradoxical : @Equidecomposable (EuclideanSpace ℝ (Fin 3) ≃ᵃⁱ[ℝ] EuclideanSpace ℝ (Fin 3)) (EuclideanSpace ℝ (Fin 3)) _ _ Ball Ball_without_origin := by
      exact?;
    -- Apply the fact that if a set is equidecomposable to a paradoxical set, then it must be paradoxical.
    apply Paradoxical.of_equidecomposable;
    exact Ball_without_origin_paradoxical_affine;
    -- Apply the symmetry of equidecomposability.
    apply Equidecomposable.symm h_ball_paradoxical
