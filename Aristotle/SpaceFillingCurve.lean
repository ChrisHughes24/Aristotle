            convert h_cont ( n + 1 ) using 1 ; push_cast ; ring;
          have := h_right ( 2 * n + 2 ) ⟨ by linarith, by linarith ⟩;
          rw [ Metric.continuousWithinAt_iff ] at *;
          exact fun ε hε => by obtain ⟨ δ, hδ, H ⟩ := this ε hε; exact ⟨ Min.min δ 2, lt_min hδ zero_lt_two, fun x hx₁ hx₂ => H ⟨ by linarith [ hx₁.out ], by linarith [ hx₁.out, abs_lt.mp hx₂, min_le_left δ 2, min_le_right δ 2 ] ⟩ ( by exact lt_of_lt_of_le hx₂ ( min_le_left _ _ ) ) ⟩ ;
        exact continuousAt_iff_continuous_left'_right'.mpr ⟨ h_left, h_right ⟩;
      grind

/-
The range of the Cantor function with parameter 1/3 is contained in [0, 1.5].
-/
lemma range_cantorFunction_third_subset_Icc_three_halves : Set.range (Cardinal.cantorFunction (1/3)) ⊆ Set.Icc 0 (3/2) := by
  intro x hx
  obtain ⟨y, rfl⟩ := hx
  have h_bound : ∀ (x : ℕ → Bool), (Cardinal.cantorFunction (1/3) x) ≤ 3/2 := by
    intro x
    have h_sum : ∑' (n : ℕ), (1/3 : ℝ) ^ n * (if x n = Bool.true then 1 else 0) ≤ ∑' (n : ℕ), (1/3 : ℝ) ^ n := by
      exact Summable.tsum_le_tsum ( fun n => mul_le_of_le_one_right ( by positivity ) ( by split_ifs <;> norm_num ) ) ( by exact Summable.of_nonneg_of_le ( fun n => by positivity ) ( fun n => mul_le_of_le_one_right ( by positivity ) ( by split_ifs <;> norm_num ) ) ( summable_geometric_of_lt_one ( by norm_num ) ( by norm_num ) ) ) ( by exact summable_geometric_of_lt_one ( by norm_num ) ( by norm_num ) );
    convert h_sum using 1 ; norm_num [ Cardinal.cantorFunction ];
    · exact tsum_congr fun n => by unfold Cardinal.cantorFunctionAux; aesop;
    · rw [ tsum_geometric_of_lt_one ] <;> norm_num
  have h_nonneg : ∀ (x : ℕ → Bool), 0 ≤ (Cardinal.cantorFunction (1/3) x) := by
    intro x
    simp [Cardinal.cantorFunction];
    apply_rules [ tsum_nonneg ] ; norm_num [ Cardinal.cantorFunctionAux ];
    exact fun i => by cases x i <;> norm_num;
  exact ⟨h_nonneg y, h_bound y⟩

/-
A surjective Peano map from the unit interval to the unit square.
-/
def peano_map_surj (t : Set.Icc (0 : ℝ) 1) : Set.Icc (0 : ℝ) 1 × Set.Icc (0 : ℝ) 1 :=
  let (u, v) := cantor_extension (t.val * 1.5)
  (retraction_Icc u, retraction_Icc v)

lemma continuous_peano_map_surj : Continuous peano_map_surj := by
  -- The peano_map_surj is a composition of continuous functions, hence it is continuous.
  have h_cont : Continuous (fun x : Set.Icc (0 : ℝ) 1 => cantor_extension x.val) := by
    exact continuous_cantor_extension.comp continuous_subtype_val;
  convert h_cont using 1;
  constructor;
  · exact?;
  · intro h_cont
    have h_cont_retraction : Continuous (fun x : ℝ => retraction_Icc x) := by
      exact continuous_retraction_Icc
    have h_cont_peano : Continuous (fun x : ℝ => (retraction_Icc (cantor_extension x).1, retraction_Icc (cantor_extension x).2)) := by
      exact Continuous.prodMk ( h_cont_retraction.comp ( continuous_fst.comp ( continuous_cantor_extension ) ) ) ( h_cont_retraction.comp ( continuous_snd.comp ( continuous_cantor_extension ) ) )
    exact (by
    convert h_cont_peano.comp ( show Continuous fun t : Set.Icc ( 0 : ℝ ) 1 => ( t : ℝ ) * 1.5 by continuity ) using 1)

/-
The map peano_map_surj is surjective onto the unit square.
-/
lemma surjective_peano_map_surj : Function.Surjective peano_map_surj := by
  intro y;
  -- By surjectivity of `peano_extended`, there exists `x ∈ [0, 1.5]` such that `peano_extended x = y`.
  obtain ⟨x, hx⟩ : ∃ x : ℝ, x ∈ Set.Icc (0 : ℝ) 1.5 ∧ peano_extended x = (y.1.val, y.2.val) := by
    have := surjective_peano_extended_on_Icc;
    exact this ⟨ y.1.2, y.2.2 ⟩;
  use ⟨x / 1.5, by
    exact ⟨ div_nonneg hx.1.1 ( by norm_num ), div_le_one_of_le₀ hx.1.2 ( by norm_num ) ⟩⟩
  generalize_proofs at *;
  unfold peano_map_surj;
  norm_num +zetaDelta at *;
  unfold peano_extended at hx; aesop;

/-
A scaled Peano map that maps the real line (via retraction) to the square [-n-1, n+1] x [-n-1, n+1].
-/
def peano_on_square_surj (n : ℕ) (t : ℝ) : ℝ × ℝ :=
  let (u, v) := peano_map_surj (retraction_Icc t)
  let s := (2 * n + 2 : ℝ)
  (s * u - (n + 1), s * v - (n + 1))

/-
The scaled surjective Peano map is continuous.
-/
lemma continuous_peano_on_square_surj (n : ℕ) : Continuous (peano_on_square_surj n) := by
  apply_rules [ Continuous.prodMk, Continuous.mul, Continuous.sub, continuous_const ];
  · apply_rules [ Continuous.min, Continuous.max, continuous_const, continuous_id ];
    exact Continuous.fst ( Classical.choose_spec exists_extension_cantor_surjection |>.1.comp <| Continuous.mul ( continuous_subtype_val.comp continuous_retraction_Icc ) continuous_const );
  · apply_rules [ Continuous.min, Continuous.max, continuous_const, continuous_id ];
    apply_rules [ Continuous.snd, Continuous.mul, continuous_const, continuous_id ];
    apply_rules [ Continuous.comp, continuous_const, continuous_id ];
    any_goals continuity;
    · exact Classical.choose_spec exists_extension_cantor_surjection |>.1;
    · apply_rules [ Continuous.mul, continuous_const, continuous_subtype_val.comp continuous_retraction_Icc ]

/-
The scaled Peano map is surjective onto the square [-n-1, n+1] x [-n-1, n+1].
-/
lemma surjective_peano_on_square_surj (n : ℕ) : Set.SurjOn (peano_on_square_surj n) Set.univ (Set.prod (Set.Icc (-(n + 1 : ℝ)) (n + 1)) (Set.Icc (-(n + 1 : ℝ)) (n + 1))) := by
  intro x hx;
  -- Let's choose any $t \in [0, 1]$ such that $peano_map_surj t = (u, v)$ where $u = \frac{x.1 + n + 1}{2n + 2}$ and $v = \frac{x.2 + n + 1}{2n + 2}$.
  obtain ⟨t, ht⟩ : ∃ t : Set.Icc (0 : ℝ) 1, peano_map_surj t = (⟨(x.1 + n + 1) / (2 * n + 2), by
    exact ⟨ div_nonneg ( by linarith [ hx.1.1 ] ) ( by linarith ), div_le_one_of_le₀ ( by linarith [ hx.1.2 ] ) ( by linarith ) ⟩⟩, ⟨(x.2 + n + 1) / (2 * n + 2), by
    exact ⟨ div_nonneg ( by linarith [ hx.2.1 ] ) ( by linarith ), div_le_one_of_le₀ ( by linarith [ hx.2.2 ] ) ( by linarith ) ⟩⟩) := by
    exact surjective_peano_map_surj _
  generalize_proofs at *;
  unfold peano_on_square_surj;
  use t.val;
  field_simp;
  rw [ show retraction_Icc ( t : ℝ ) = t from ?_ ];
  · simp +zetaDelta at *;
    exact Prod.mk_inj.mpr ⟨ by rw [ ht ] ; norm_num; nlinarith [ mul_div_cancel₀ ( x.1 + n + 1 ) ( by linarith : ( 2 * n + 2 : ℝ ) ≠ 0 ) ], by rw [ ht ] ; norm_num; nlinarith [ mul_div_cancel₀ ( x.2 + n + 1 ) ( by linarith : ( 2 * n + 2 : ℝ ) ≠ 0 ) ] ⟩;
  · exact Subtype.ext <| retraction_Icc_val_eq_self t.2

/-
A piece of the surjective global Peano curve.
-/
def piece_surj (n : ℕ) (t : ℝ) : ℝ × ℝ :=
  if t ≤ 1 then peano_on_square_surj n t
  else segment_R2 (peano_on_square_surj n 1) (peano_on_square_surj (n + 1) 0) (t - 1)

lemma continuous_piece_surj (n : ℕ) : Continuous (piece_surj n) := by
  refine' Continuous.if _ _ _;
  · erw [ frontier_Iic ] ; norm_num [ segment_R2 ];
  · exact?;
  · exact continuous_segment_R2 _ _ |> Continuous.comp <| continuous_sub_right _

/-
A global surjective Peano map from the reals to the plane.
-/
def global_peano_surj (t : ℝ) : ℝ × ℝ :=
  if t ≤ 0 then peano_on_square_surj 0 0
  else
    let n := Nat.floor (t / 2)
    let rem := t - 2 * n
    piece_surj n rem

/-
The global surjective Peano map is continuous.
-/
lemma continuous_global_peano_surj : Continuous global_peano_surj := by
  refine' continuous_iff_continuousAt.mpr _;
  intro x
  by_cases hx : x ≤ 0;
  · by_cases hx' : x = 0;
    · -- For t approaching 0 from the left, the function is constant, so it's continuous.
      have h_left : Filter.Tendsto (fun t => global_peano_surj t) (nhdsWithin 0 (Set.Iio 0)) (nhds (global_peano_surj 0)) := by
        have h_left : ∀ᶠ t in nhdsWithin 0 (Set.Iio 0), global_peano_surj t = peano_on_square_surj 0 0 := by
          exact Filter.eventually_of_mem self_mem_nhdsWithin fun t ht => if_pos ht.out.le;
        rw [ Filter.tendsto_congr' h_left ] ; norm_num [ hx' ];
        unfold global_peano_surj; norm_num [ hx' ] ;
      have h_right : Filter.Tendsto (fun t => global_peano_surj t) (nhdsWithin 0 (Set.Ioi 0)) (nhds (global_peano_surj 0)) := by
        have h_piece : ∀ᶠ t in nhdsWithin 0 (Set.Ioi 0), global_peano_surj t = piece_surj 0 t := by
          filter_upwards [ Ioo_mem_nhdsGT_of_mem ⟨ le_rfl, zero_lt_one ⟩ ] with t ht using by rw [ global_peano_surj ] ; rw [ show Nat.floor ( t / 2 ) = 0 from Nat.floor_eq_zero.mpr <| by linarith [ ht.1, ht.2 ] ] ; aesop;
        rw [ Filter.tendsto_congr' h_piece ];
        convert Filter.Tendsto.mono_left ( continuous_piece_surj 0 |> Continuous.continuousAt ) inf_le_left using 1 ; norm_num [ piece_surj ];
        unfold global_peano_surj; norm_num;
      exact hx'.symm ▸ continuousAt_iff_continuous_left'_right'.mpr ⟨ h_left, h_right ⟩;
    · rw [ continuousAt_congr ];
      exacts [ show ContinuousAt ( fun t => peano_on_square_surj 0 0 ) x from continuousAt_const, Filter.eventuallyEq_of_mem ( Iio_mem_nhds ( lt_of_le_of_ne hx hx' ) ) fun t ht => if_pos ht.out.le ];
  · by_cases hx' : ∃ n : ℕ, x = 2 * n;
    · obtain ⟨n, hn⟩ : ∃ n : ℕ, x = 2 * n := hx'
      have h_lhs : Filter.Tendsto (fun t => global_peano_surj t) (nhdsWithin x (Set.Iio x)) (nhds (piece_surj (n - 1) 2)) := by
        have h_lhs : ∀ᶠ t in nhdsWithin x (Set.Iio x), global_peano_surj t = piece_surj (n - 1) (t - 2 * (n - 1)) := by
          rw [ eventually_nhdsWithin_iff ];
          rw [ Metric.eventually_nhds_iff ];
          use 1; norm_num [ hn ];
          intro y hy₁ hy₂; rcases n with ( _ | n ) <;> norm_num [ global_peano_surj ] at *;
          · linarith;
          · rw [ if_neg ( by linarith [ abs_lt.mp hy₁ ] ) ];
            norm_num [ show ⌊y / 2⌋₊ = n by exact Nat.floor_eq_iff ( by linarith [ abs_lt.mp hy₁ ] ) |>.2 ⟨ by linarith [ abs_lt.mp hy₁ ], by linarith [ abs_lt.mp hy₁ ] ⟩ ];
        rw [ Filter.tendsto_congr' h_lhs ] ; convert Filter.Tendsto.comp ( continuous_piece_surj ( n - 1 ) |> Continuous.continuousAt ) ( continuousWithinAt_id.sub continuousWithinAt_const ) using 2 ; norm_num [ hn ] ; ring;
      have h_rhs : Filter.Tendsto (fun t => global_peano_surj t) (nhdsWithin x (Set.Ioi x)) (nhds (piece_surj n 0)) := by
        have h_rhs : ∀ᶠ t in nhdsWithin x (Set.Ioi x), global_peano_surj t = piece_surj n (t - 2 * n) := by
          filter_upwards [ Ioo_mem_nhdsGT_of_mem ⟨ le_rfl, show x < 2 * ( n + 1 ) by linarith ⟩ ] with t ht;
          unfold global_peano_surj;
          norm_num [ show ⌊t / 2⌋₊ = n by exact Nat.floor_eq_iff ( by linarith [ ht.1 ] ) |>.2 ⟨ by linarith [ ht.1 ], by linarith [ ht.2 ] ⟩ ];
          exact fun h => False.elim <| h.not_lt <| by linarith [ ht.1 ] ;
        rw [ Filter.tendsto_congr' h_rhs ] ; exact Continuous.continuousWithinAt ( by exact continuous_piece_surj n |> Continuous.comp <| continuous_sub_right _ ) |> fun h => h.trans <| by norm_num [ hn ] ;
      have h_eq : piece_surj (n - 1) 2 = piece_surj n 0 := by
        rcases n with ( _ | n ) <;> norm_num [ piece_surj ] at *;
        · linarith;
        · unfold segment_R2; norm_num;
      have h_cont : ContinuousAt global_peano_surj x := by
        refine' continuousAt_iff_continuous_left'_right'.mpr _;
        simp_all +decide [ ContinuousWithinAt ];
        convert And.intro h_lhs h_rhs using 2 <;> norm_num [ hn, global_peano_surj ];
        · exact fun h => False.elim <| h.not_lt <| by positivity;
        · exact fun h => False.elim <| h.not_lt <| by positivity;
      exact h_cont;
    · -- Since $x$ is not of the form $2n$, there exists an $n$ such that $2n < x < 2(n+1)$.
      obtain ⟨n, hn⟩ : ∃ n : ℕ, 2 * n < x ∧ x < 2 * (n + 1) := by
        exact ⟨ ⌊x / 2⌋₊, lt_of_le_of_ne ( by linarith [ Nat.floor_le ( show 0 ≤ x / 2 by linarith ) ] ) fun h => hx' ⟨ _, h.symm ⟩, by linarith [ Nat.lt_floor_add_one ( x / 2 ) ] ⟩;
      -- Since $2n < x < 2(n+1)$, we have $global_peano_surj(x) = piece_surj(n, x - 2n)$.
      have h_eq : ∀ᶠ t in nhds x, global_peano_surj t = piece_surj n (t - 2 * n) := by
        filter_upwards [ Ioo_mem_nhds hn.1 hn.2 ] with t ht;
        unfold global_peano_surj;
        rw [ if_neg ( by linarith [ ht.1 ] ) ];
        norm_num [ show ⌊t / 2⌋₊ = n by exact Nat.floor_eq_iff ( by linarith [ ht.1 ] ) |>.2 ⟨ by linarith [ ht.1 ], by linarith [ ht.2 ] ⟩ ];
      exact ContinuousAt.congr ( show ContinuousAt ( fun t => piece_surj n ( t - 2 * n ) ) x from ContinuousAt.comp ( continuous_piece_surj n |> Continuous.continuousAt ) ( continuousAt_id.sub continuousAt_const ) ) ( Filter.eventuallyEq_of_mem h_eq fun t ht => ht.symm )

/-
The global surjective Peano map is surjective.
-/
lemma surjective_global_peano_surj : Function.Surjective global_peano_surj := by
  intro y
  obtain ⟨n, hn⟩ : ∃ n : ℕ, y ∈ Set.prod (Set.Icc (-(n + 1 : ℝ)) (n + 1)) (Set.Icc (-(n + 1 : ℝ)) (n + 1)) := by
    exact ⟨ Nat.ceil ( |y.1| + |y.2| ), ⟨ ⟨ by cases abs_cases y.1 <;> cases abs_cases y.2 <;> linarith [ Nat.le_ceil ( |y.1| + |y.2| ) ], by cases abs_cases y.1 <;> cases abs_cases y.2 <;> linarith [ Nat.le_ceil ( |y.1| + |y.2| ) ] ⟩, ⟨ by cases abs_cases y.1 <;> cases abs_cases y.2 <;> linarith [ Nat.le_ceil ( |y.1| + |y.2| ) ], by cases abs_cases y.1 <;> cases abs_cases y.2 <;> linarith [ Nat.le_ceil ( |y.1| + |y.2| ) ] ⟩ ⟩ ⟩;
  -- By `surjective_peano_on_square_surj n`, there exists `t' \in R` such that `peano_on_square_surj n t' = y`.
  obtain ⟨t', ht'⟩ : ∃ t' : ℝ, peano_on_square_surj n t' = y := by
    have := surjective_peano_on_square_surj n;
    exact this hn |> fun ⟨ t', ht', ht'' ⟩ => ⟨ t', ht'' ⟩;
  -- By `surjective_peano_on_square_surj n`, there exists `t' \in [0, 1]` such that `peano_on_square_surj n t' = y`.
  obtain ⟨t', ht'⟩ : ∃ t' ∈ Set.Icc 0 1, peano_on_square_surj n t' = y := by
    -- By definition of `peano_on_square_surj`, if `t'` is not in `[0, 1]`, then `peano_on_square_surj n t'` is equal to `peano_on_square_surj n (retraction_Icc t')`.
    have h_retraction : peano_on_square_surj n t' = peano_on_square_surj n (retraction_Icc t') := by
      unfold peano_on_square_surj;
      unfold retraction_Icc; aesop;
    exact ⟨ _, ⟨ by exact ( retraction_Icc t' ) |>.2.1, by exact ( retraction_Icc t' ) |>.2.2 ⟩, h_retraction.symm.trans ht' ⟩;
  use 2 * n + t';
  unfold global_peano_surj;
  split_ifs <;> norm_num at *;
  · norm_num [ show t' = 0 by linarith ] at *;
    norm_cast at * ; aesop;
  · norm_num [ show ⌊ ( 2 * n + t' : ℝ ) / 2⌋₊ = n by exact Nat.floor_eq_iff ( by linarith ) |>.2 ⟨ by linarith, by linarith ⟩ ];
    unfold piece_surj; aesop;

/-
There exists a continuous surjection from the real line to the plane.
-/
theorem exists_continuous_surjection_R_R2 : ∃ f : ℝ → ℝ × ℝ, Continuous f ∧ Function.Surjective f := by
  exact ⟨ _, continuous_global_peano_surj, surjective_global_peano_surj ⟩
