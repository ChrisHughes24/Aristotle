/-
The Cantor surjection maps a sequence of booleans to a point in the unit square.
-/
def cantor_surjection (x : ℕ → Bool) : ℝ × ℝ :=
  let (y, z) := cantor_square_homeomorph x
  (Cardinal.cantorFunction (1/2) y / 2, Cardinal.cantorFunction (1/2) z / 2)

