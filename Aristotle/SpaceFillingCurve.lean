/-
A piece of the global Peano curve, defined for t in [0, 2]. It traverses the n-th square for t in [0, 1] and connects to the (n+1)-th square for t in [1, 2].
-/
def piece (n : ℕ) (t : ℝ) : ℝ × ℝ :=
  if t ≤ 1 then peano_on_square n t
  else segment_R2 (peano_on_square n 1) (peano_on_square (n + 1) 0) (t - 1)

/-
A global Peano curve mapping the real line to the plane. It is constructed by stitching together scaled Peano curves on expanding squares.
-/
def global_peano (t : ℝ) : ℝ × ℝ :=
  if t ≤ 0 then peano_on_square 0 0
  else
    let n := Nat.floor (t / 2)
    let rem := t - 2 * n
    piece n rem

